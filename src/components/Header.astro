---
// Navigation data derived from manifest
const navLinks = [
  {
    label: 'Benefits',
    href: '/benefits/',
    children: [
      { label: 'Security', href: '/benefits/ballistic-resistance/' },
      { label: 'Safety & Security', href: '/benefits/safety-and-security/' },
      { label: 'Privacy', href: '/benefits/privacy-window-film-philadelphia/' },
      { label: 'Decorative', href: '/benefits/decorative-promotional/' },
      { label: 'Anti-Graffiti', href: '/benefits/anti-graffiti/' },
      { label: 'Energy Savings', href: '/benefits/energy-saving-window-film-philadephia/' },
      { label: 'Glare Reduction', href: '/benefits/glare-reduction/' },
      { label: 'UV Protection', href: '/benefits/uv-blocking-window-film-philadelphia/' },
      { label: 'Bird Strike Prevention', href: '/benefits/bird-strike-prevention/' },
      { label: 'Bomb Blast Protection', href: '/benefits/blast-mitigation/' },
      { label: 'Elevator Refinishing', href: '/benefits/elevator-refinishing/' },
      { label: 'Exterior Refinishing', href: '/benefits/exterior-window-film/' },
      { label: 'Exterior Building Wraps', href: '/benefits/exterior-building-wraps/' },
      { label: 'Mirror Refinishing', href: '/benefits/mirror-refinishing/' },
      { label: 'School Security', href: '/benefits/school-security-window-film/' },
      { label: 'Updating Surfaces', href: '/benefits/updating-surfaces/' },
    ],
  },
  {
    label: 'Applications',
    href: '/applications/',
    children: [
      { label: 'Arenas & Stadiums', href: '/applications/arenas-stadiums/' },
      { label: 'Churches', href: '/applications/churches/' },
      { label: 'Hotels', href: '/applications/hotel-window-film/' },
      { label: 'Mass Transit', href: '/applications/mass-transit/' },
      { label: 'Museums & Libraries', href: '/applications/museums-libraries/' },
      { label: 'Office', href: '/applications/office/' },
      { label: 'Restaurants & Bars', href: '/applications/restaurants-window-film-philadelphia/' },
      { label: 'Retail', href: '/applications/retail/' },
      { label: 'Schools & Universities', href: '/applications/schools-universities/' },
      { label: 'Secured Buildings', href: '/applications/secured-buildings/' },
    ],
  },
  {
    label: 'Products',
    href: '/products/',
    children: [
      { label: '3M', href: '/products/3m-window-film/' },
      { label: 'Bird Divert', href: '/products/bird-divert/' },
      { label: 'C-Bond', href: '/products/c-bond-window-film/' },
      { label: 'Casper Cloaking Film', href: '/products/casper-cloaking-film/' },
      { label: 'Hanita Coatings', href: '/products/hanita-coatings-window-film/' },
      { label: 'HDclear', href: '/products/hdclear-window-film/' },
      { label: 'Huper Optik', href: '/products/huper-optik/' },
      { label: 'LLumar', href: '/products/llumar/' },
      { label: 'Madico', href: '/products/madico-window-film/' },
      { label: 'NanoTint', href: '/products/nanotint-window-film/' },
      { label: 'SolarGard', href: '/products/solar-gard-window-film/' },
      { label: 'Solyx', href: '/products/solyx-window-film/' },
      { label: 'Vista', href: '/products/vista-window-film/' },
    ],
  },
  {
    label: 'Resources',
    href: '/resources/',
    children: [
      { label: 'FAQ', href: '/resources/commercial-faq/' },
      { label: 'Commercial Guide', href: '/resources/commercial-guide/' },
      { label: 'Fact Sheet', href: '/resources/window-film-fact-sheet/' },
      { label: 'Pricing', href: '/resources/window-film-pricing/' },
      { label: 'Maintenance & Care', href: '/resources/maintenance-and-care/' },
      { label: 'Warranty', href: '/resources/warranty/' },
      { label: 'Property Code', href: '/resources/property-code/' },
      { label: 'Alternatives', href: '/resources/window-film-alternatives/' },
      { label: 'Window Replacement Alternative', href: '/resources/window-replacement-alternative/' },
      { label: 'Architects & Builders', href: '/resources/architects-builders/' },
    ],
  },
  {
    label: 'Government',
    href: '/government-buildings/',
  },
  {
    label: 'Process',
    href: '/process/',
  },
  {
    label: 'Cities',
    href: '/cities/',
    children: [
      { label: 'Philadelphia', href: '/cities/philadelphia/' },
      { label: 'Camden', href: '/cities/camden/' },
      { label: 'Reading', href: '/cities/reading/' },
