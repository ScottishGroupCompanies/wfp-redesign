---
// CTAStrip.astro — global "Get Your Free Quote Today" section
// Jotform 231236977587168 replaces the button on every page
---

<section class="cta-strip">
  <div class="container">
    <h2>Get Your Free Quote Today</h2>
    <p>Philadelphia's leading window film contractor. Contact us for a free consultation and estimate.</p>
    <div class="cta-strip__form">
      <script type="text/javascript" src="https://form.jotform.com/jsform/231236977587168"></script>
    </div>
  </div>
</section>

<style>
.cta-strip__form {
  display: flex;
  justify-content: center;
  width: 100%;
  margin-top: 1.75rem;
}

/* Jotform injects an iframe — centre it and cap the width */
.cta-strip__form iframe,
.cta-strip__form > div,
.cta-strip__form > form {
  max-width: 700px;
  width: 100%;
  margin: 0 auto;
}
</style>
