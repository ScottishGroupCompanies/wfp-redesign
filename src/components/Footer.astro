---
const phone = '(267) 394-7980';
const email = 'contact@windowfilmphiladelphia.net';

const footerLinks = {
  Benefits: [
    { label: 'Security Film', href: '/benefits/safety-and-security/' },
    { label: 'Privacy Film', href: '/benefits/privacy-window-film-philadelphia/' },
    { label: 'Energy Savings', href: '/benefits/energy-saving-window-film-philadephia/' },
    { label: 'Decorative Film', href: '/benefits/decorative-promotional/' },
    { label: 'Anti-Graffiti', href: '/benefits/anti-graffiti/' },
    { label: 'Glare Reduction', href: '/benefits/glare-reduction/' },
    { label: 'UV Protection', href: '/benefits/uv-blocking-window-film-philadelphia/' },
    { label: 'Bird Strike Prevention', href: '/benefits/bird-strike-prevention/' },
  ],
  Applications: [
    { label: 'Office', href: '/applications/office/' },
    { label: 'Retail', href: '/applications/retail/' },
    { label: 'Schools', href: '/applications/schools-universities/' },
    { label: 'Hotels', href: '/applications/hotel-window-film/' },
    { label: 'Churches', href: '/applications/churches/' },
    { label: 'Museums & Libraries', href: '/applications/museums-libraries/' },
    { label: 'Arenas & Stadiums', href: '/applications/arenas-stadiums/' },
    { label: 'Government', href: '/government-buildings/' },
  ],
  Resources: [
    { label: 'Commercial Guide', href: '/resources/commercial-guide/' },
    { label: 'FAQ', href: '/resources/commercial-faq/' },
    { label: 'Window Film Pricing', href: '/resources/window-film-pricing/' },
    { label: 'Maintenance & Care', href: '/resources/maintenance-and-care/' },
    { label: 'Warranty', href: '/resources/warranty/' },
    { label: 'Window Film Alternatives', href: '/resources/window-film-alternatives/' },
  ],
  Company: [
    { label: 'Our Process', href: '/process/' },
    { label: 'Contact Us', href: '/contact/' },
    { label: 'Philadelphia', href: '/cities/philadelphia/' },
    { label: 'Camden', href: '/cities/camden/' },
    { label: 'Reading', href: '/cities/reading/' },
    { label: 'Upper Darby', href: '/cities/upper-darby-township/' },
  ],
};

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-top">
    <!-- Brand column -->
    <div class="footer-brand">
      <div class="footer-logo">
        Window Film Philadelphia<span>.</span>
      </div>
      <p class="footer-tagline">Philadelphia's leading commercial and residential window film contractor. Serving Philadelphia, Camden, Reading, and surrounding counties since 2008.</p>
      <p class="footer-contact-line">
        <a href="tel:+12673947980">{phone}</a>
        &nbsp;&bull;&nbsp;
        <a href={`mailto:${email}`}>{email}</a>
      </p>
    </div>

    <!-- Link columns -->
    {Object.entries(footerLinks).map(([group, links]) => (
      <div class="footer-col">
        <h5>{group}</h5>
        {links.map((l) => (
          <a href={l.href}>{l.label}</a>
        ))}
      </div>
    ))}
  </div>

  <div class="footer-bottom">
    <span>&copy; {currentYear} Window Film Philadelphia. All rights reserved.</span>
    <span>Philadelphia, PA &bull; {phone}</span>
  </div>
</footer>

<style>
.site-footer {
  background: #1a1f22;
  color: rgba(255, 255, 255, 0.6);
}

/* ── TOP GRID ── */
.footer-top {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
  gap: 48px;
  padding: 72px 5% 48px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

/* Brand column */
.footer-logo {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 22px;
  font-weight: 600;
  color: #fff;
  margin-bottom: 16px;
  letter-spacing: -0.3px;
}
.footer-logo span {
  color: var(--green, #81AB4C);
}
.footer-tagline {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 14px;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.55);
  margin-bottom: 20px;
}
.footer-contact-line {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px;
  color: rgba(255, 255, 255, 0.55);
  margin: 0;
}
.footer-contact-line a {
  color: rgba(255, 255, 255, 0.75);
  text-decoration: none;
  transition: color 0.2s;
}
.footer-contact-line a:hover {
  color: #fff;
}

/* Link columns */
.footer-col h5 {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  color: #fff;
  margin-bottom: 20px;
}
.footer-col a {
  display: block;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 14px;
  color: rgba(255, 255, 255, 0.55);
  text-decoration: none;
  padding: 4px 0;
  transition: color 0.2s;
}
.footer-col a:hover {
  color: #fff;
}

/* ── BOTTOM BAR ── */
.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24px 5%;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px;
  color: rgba(255, 255, 255, 0.35);
  flex-wrap: wrap;
  gap: 8px;
}

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
  .footer-top {
    grid-template-columns: 1fr 1fr 1fr;
    gap: 32px;
    padding: 48px 5% 32px;
  }
  .footer-brand {
    grid-column: 1 / -1;
  }
}

@media (max-width: 640px) {
  .footer-top {
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .footer-bottom {
    flex-direction: column;
    text-align: center;
  }
}

@media (max-width: 400px) {
  .footer-top {
    grid-template-columns: 1fr;
  }
}
</style>
