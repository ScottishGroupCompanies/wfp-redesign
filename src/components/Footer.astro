---
const phone = '(267) 394-7980';
const email = 'contact@windowfilmphiladelphia.net';

const resourcesLinks = [
  { label: 'Commercial Guide',        href: '/resources/commercial-guide/' },
  { label: 'FAQ',                     href: '/resources/commercial-faq/' },
  { label: 'Window Film Pricing',     href: '/resources/window-film-pricing/' },
  { label: 'Maintenance & Care',      href: '/resources/maintenance-and-care/' },
  { label: 'Warranty',                href: '/resources/warranty/' },
  { label: 'Window Film Alternatives',href: '/resources/window-film-alternatives/' },
];

const companyLinks = [
  { label: 'Our Process',   href: '/process/' },
  { label: 'Contact Us',    href: '/contact/' },
  { label: 'Philadelphia',  href: '/cities/philadelphia/' },
  { label: 'Camden',        href: '/cities/camden/' },
  { label: 'Reading',       href: '/cities/reading/' },
  { label: 'Upper Darby',   href: '/cities/upper-darby-township/' },
];

const currentYear = new Date().getFullYear();
---

<footer class="s-footer">

  <!-- Footer container (rounded, dark, inside the backdrop) -->
  <div class="s-footer__container">

    <!-- ── FOOTER BODY: 3-column grid ── -->
    <div class="s-footer__body">

      <!-- COLUMN 1: Brand -->
      <div class="s-footer__brand">
        <img
          src="/images/2021-08-window-film-philadelphia-dark.png"
          alt="Window Film Philadelphia"
          class="s-footer__logo-img"
        />
        <div class="s-footer__tagline-wrap">
          <p class="s-footer__tagline">
            Philadelphia's leading commercial and residential window film contractor.
            Serving Philadelphia, Camden, Reading, and surrounding counties since 2008.
          </p>
        </div>
      </div>

      <!-- COLUMN 2: Resources + Company (nested 2-column) -->
      <div class="s-footer__col-group">
        <div class="s-footer__nav-col">
          <h6 class="s-footer__nav-label">Resources</h6>
          {resourcesLinks.map((l) => (
            <a href={l.href} class="s-footer__link">{l.label}</a>
          ))}
        </div>
        <div class="s-footer__nav-col">
          <h6 class="s-footer__nav-label">Company</h6>
          {companyLinks.map((l) => (
            <a href={l.href} class="s-footer__link">{l.label}</a>
          ))}
        </div>
      </div>

      <!-- COLUMN 3: Contact -->
      <div class="s-footer__contact">
        <a href="tel:+12673947980" class="s-footer__phone">{phone}</a>
        <a href={`mailto:${email}`} class="s-footer__email">{email}</a>
        <div class="s-footer__social-wrap">
          <p class="s-footer__social">
            <a href="https://www.facebook.com/windowfilmphiladelphia" target="_blank" rel="noopener">Facebook</a>
            <span>&nbsp;&middot;&nbsp;</span>
            <a href="https://www.instagram.com/windowfilmphiladelphia" target="_blank" rel="noopener">Instagram</a>
            <span>&nbsp;&middot;&nbsp;</span>
            <a href="https://www.pinterest.com/windowfilmphiladelphia" target="_blank" rel="noopener">Pinterest</a>
            <span>&nbsp;&middot;&nbsp;</span>
            <a href="https://www.linkedin.com/company/window-film-philadelphia" target="_blank" rel="noopener">LinkedIn</a>
          </p>
        </div>
      </div>

    </div><!-- end .s-footer__body -->

    <!-- ── FOOTER GUTTER ── -->
    <div class="s-footer__gutter">
      <span>&copy; {currentYear} Window Film Philadelphia. All rights reserved.</span>
      <span>Philadelphia, PA &bull; {phone}</span>
    </div>

  </div><!-- end .s-footer__container -->

</footer>

<style>
/* ── FOOTER BACKDROP ── */
.s-footer {
  background-color: #1a1f1e;
  background-image: url('/images/wfp-footer-bg-commercial-window-film.webp');
  background-size: cover;
  background-position: center;
  padding-top: 300px;
  position: relative;
  z-index: 1;
  margin-top: -40px;
}

/* ── FOOTER CONTAINER ── */
.s-footer__container {
  max-width: 1270px;
  margin: 0 auto;
  margin-bottom: 30px;
  background: #ffffff;
  border-radius: var(--radius-xl, 40px);
  padding: 60px 60px 0;
  overflow: hidden;
}

/* ── FOOTER BODY ── */
.s-footer__body {
  display: grid;
  grid-template-columns: 1.2fr 1fr 1fr;
  gap: 48px;
  padding-bottom: 52px;
}

/* ── BRAND COLUMN ── */
.s-footer__brand {
  display: flex;
  flex-direction: column;
  padding-right: 48px;
  border-right: 1px solid rgba(0, 0, 0, 0.1);
}

.s-footer__logo-img {
  max-width: 280px;
  height: auto;
  display: block;
  margin-bottom: 20px;
}

.s-footer__tagline-wrap {
  margin-top: auto;
}

.s-footer__tagline {
  font-family: var(--font-body);
  font-size: 14px;
  line-height: 1.7;
  color: var(--text-mid, #4a4a4a);
  margin: 0;
}

/* ── NAV GROUP (Resources + Company side by side) ── */
.s-footer__col-group {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32px;
  padding-right: 48px;
  border-right: 1px solid rgba(0, 0, 0, 0.1);
}

.s-footer__nav-label {
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--text-mid, #4a4a4a);
  margin-bottom: 16px;
}

.s-footer__link {
  display: block;
  font-family: var(--font-body);
  font-size: 14px;
  color: var(--text-mid, #4a4a4a);
  text-decoration: none;
  padding: 4px 0;
  transition: color 0.2s;
}
.s-footer__link:hover { color: var(--green); }

/* ── CONTACT COLUMN ── */
.s-footer__contact {
  display: flex;
  flex-direction: column;
}

.s-footer__phone {
  display: block;
  font-family: var(--font-body);
  font-size: 28px;
  font-weight: 500;
  color: var(--text-mid, #4a4a4a);
  text-decoration: none;
  line-height: 1.2;
  margin-bottom: 10px;
  transition: color 0.2s;
}
.s-footer__phone:hover { color: var(--green); }

.s-footer__email {
  display: block;
  font-family: var(--font-body);
  font-size: 20px;
  font-weight: 400;
  color: var(--text-mid, #4a4a4a);
  text-decoration: none;
  line-height: 1.3;
  margin-bottom: 20px;
  transition: color 0.2s;
}
.s-footer__email:hover { color: var(--green); }

.s-footer__social-wrap {
  margin-top: auto;
}

.s-footer__social {
  font-family: var(--font-body);
  font-size: 13px;
  color: var(--text-mid, #4a4a4a);
  margin: 0;
}
.s-footer__social a {
  color: var(--text-mid, #4a4a4a);
  text-decoration: none;
  transition: color 0.2s;
}
.s-footer__social a:hover { color: var(--green); }

/* ── FOOTER GUTTER ── */
.s-footer__gutter {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24px 0;
  border-top: 1px solid rgba(0, 0, 0, 0.1);
  font-family: var(--font-body);
  font-size: 13px;
  color: var(--text-mid, #4a4a4a);
  flex-wrap: wrap;
  gap: 8px;
}

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
  .s-footer__body {
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }
  .s-footer__brand { grid-column: 1 / -1; }
  .s-footer__contact { grid-column: 1 / -1; }
}

@media (max-width: 640px) {
  .s-footer__container {
    padding: 40px 24px 0;
    border-radius: 12px 12px 0 0;
  }
  .s-footer__body {
    grid-template-columns: 1fr;
    gap: 36px;
  }
  .s-footer__brand,
  .s-footer__contact {
    grid-column: 1;
  }
  .s-footer__col-group {
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .s-footer__phone { font-size: 22px; }
  .s-footer__email { font-size: 16px; }
  .s-footer__gutter {
    flex-direction: column;
    text-align: center;
    padding: 20px 0;
  }
}
</style>