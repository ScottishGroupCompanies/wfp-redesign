---
/**
 * SchemaOrg.astro
 * Renders one <script type="application/ld+json"> tag per schema object.
 * Pass an array of plain objects — this component handles serialisation.
 */
export interface Props {
  schemas: Record<string, unknown>[];
}
const { schemas } = Astro.props;
---
{schemas.map((schema) => (
  <script type="application/ld+json" set:html={JSON.stringify(schema, null, 0)} />
))}
