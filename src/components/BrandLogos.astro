---
// BrandLogos.astro — "Proudly Offering" brand logo strip
// Two rows of 6 logos each, white background, centred heading

const logos = [
  // Row 1
  { file: '2021-09-3m-window-film-philadelphia.jpg',              alt: '3M Window Film' },
  { file: '2021-09-llumar-window-film-philadelphia.jpg',          alt: 'LLumar Window Film' },
  { file: '2021-09-vista-window-film-philadelphia.jpg',           alt: 'Vista Window Film' },
  { file: '2021-09-solar-gard-window-film-philadelphia.jpg',      alt: 'Solar Gard Window Film' },
  { file: '2021-09-huper-optik-window-film-philadelphia.jpg',     alt: 'Huper Optik Window Film' },
  { file: '2021-09-casper-window-film-philadelphia.jpg',          alt: 'Casper Cloaking Film' },
  // Row 2
  { file: '2021-09-cbond-window-film-philadelphia.jpg',           alt: 'C-Bond Window Film' },
  { file: '2021-09-madico-window-film-philadelphia.jpg',          alt: 'Madico Window Film' },
  { file: '2021-09-hdclear-window-film-philadelphia.jpg',         alt: 'HDClear Window Film' },
  { file: '2021-09-hanita-coatings-window-film-philadelphia.jpg', alt: 'Hanita Coatings Window Film' },
  { file: '2021-09-solyx-window-film-philadelphia.jpg',           alt: 'Solyx Window Film' },
  { file: '2021-09-graffiti-shield-window-film-philadelphia.jpg', alt: 'Graffiti Shield Window Film' },
];

const row1 = logos.slice(0, 6);
const row2 = logos.slice(6, 12);
---

<section class="brand-logos">
  <div class="container">
    <h2 class="brand-logos__title">Proudly Offering</h2>
    <div class="brand-logos__row">
      {row1.map((logo) => (
        <div class="brand-logos__item">
          <img
            src={`/images/${logo.file}`}
            alt={logo.alt}
            loading="lazy"
          />
        </div>
      ))}
    </div>
    <div class="brand-logos__row">
      {row2.map((logo) => (
        <div class="brand-logos__item">
          <img
            src={`/images/${logo.file}`}
            alt={logo.alt}
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.brand-logos {
  background: var(--color-bg-white);
  padding: 3rem var(--section-pad-x);
  border-top: 1px solid var(--color-border);
}

.brand-logos__title {
  text-align: center;
  margin-bottom: 2rem;
  font-size: clamp(1.2rem, 2.5vw, 1.6rem);
  color: var(--color-charcoal);
}

.brand-logos__row {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 1.5rem;
  align-items: center;
  justify-items: center;
}

.brand-logos__row + .brand-logos__row {
  margin-top: 1.5rem;
}

.brand-logos__item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0.5rem;
}

.brand-logos__item img {
  max-height: 60px;
  width: auto;
  max-width: 100%;
  object-fit: contain;
  filter: grayscale(20%);
  opacity: 0.85;
  transition: opacity 200ms ease, filter 200ms ease;
}

.brand-logos__item img:hover {
  filter: grayscale(0%);
  opacity: 1;
}

@media (max-width: 768px) {
  .brand-logos__row {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 480px) {
  .brand-logos__row {
    grid-template-columns: repeat(2, 1fr);
  }
}
</style>
