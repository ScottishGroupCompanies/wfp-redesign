---
import BaseLayout from '../layouts/BaseLayout.astro';
import InnerPageHero from '../components/InnerPageHero.astro';
import BrandLogos from '../components/BrandLogos.astro';
import { Icon } from 'astro-icon/components';

const title = 'Benefits | Window Film Philadelphia | Leading Window Film Solutions';
const description = 'Explore the full range of window film benefits for Philadelphia properties — energy savings, privacy, security, UV protection, glare reduction, and more.';

const benefits = [
  {
    label: 'UV Protection',
    desc: 'Blocks up to 99.9% of UV rays — protecting furnishings, flooring, and building occupants without reducing natural light.',
    img: '/images/2021-08-philadelphia-window-film-uv-protection.jpg',
    alt: 'UV protection window film Philadelphia',
    href: '/benefits/uv-blocking-window-film-philadelphia/',
  },
  {
    label: 'Glare Reduction',
    desc: 'Selectively filters glare-causing light to improve screen visibility and comfort in offices, classrooms, and homes.',
    img: '/images/2021-08-philadelphia-window-film-glare-reduction.jpg',
    alt: 'Glare reduction window film Philadelphia',
    href: '/benefits/glare-reduction/',
  },
  {
    label: 'Anti-Graffiti',
    desc: 'Sacrificial films protect glass and metal surfaces — peel and replace rather than replacing the glass when tagged.',
    img: '/images/2021-09-anti-graffiti-film-philadelphia.jpg',
    alt: 'Anti-graffiti window film Philadelphia',
    href: '/benefits/anti-graffiti/',
  },
  {
    label: 'Decorative & Promotional',
    desc: 'Custom logos, frosted patterns, and branded graphics that enhance privacy and aesthetics in any interior space.',
    img: '/images/2021-10-decorative-promotional-window-film-philadelphia.jpg',
    alt: 'Decorative promotional window film Philadelphia',
    href: '/benefits/decorative-promotional/',
  },
  {
    label: 'Exterior Building Wraps',
    desc: 'Full-building graphics for brand visibility and advertising campaigns without permanent modification.',
    img: '/images/2021-10-building-wrap-philadelphia.jpg',
    alt: 'Exterior building wrap Philadelphia',
    href: '/benefits/exterior-building-wraps/',
  },
  {
    label: 'Ballistic Resistance',
    desc: 'Advanced multi-layer systems for schools, banks, and government buildings that resist gunfire and forced entry.',
    img: '/images/2021-08-philadelphia-window-film-ballistic-resistant-window-film.jpg',
    alt: 'Ballistic resistance window film Philadelphia',
    href: '/benefits/ballistic-resistance/',
  },
  {
    label: 'Bomb Blast Protection',
    desc: 'Retains shattered glass fragments during explosions, dramatically reducing injury and property damage.',
    img: '/images/2021-08-philadelphia-window-film-bomb-blast-protection.jpg',
    alt: 'Bomb blast protection window film Philadelphia',
    href: '/benefits/blast-mitigation/',
  },
  {
    label: 'Exterior Refinishing',
    desc: 'Mask glass defects and update building aesthetics without renovation — ideal for hotels, high-rises, and historic properties.',
    img: '/images/2021-08-philadelphia-window-film-exterior-refinishing.jpg',
    alt: 'Exterior refinishing window film Philadelphia',
    href: '/benefits/exterior-window-film/',
  },
  {
    label: 'Mirror Refinishing',
    desc: 'Restore and protect mirrors and decorative glass surfaces with protective film overlays — eliminating costly replacements.',
    img: '/images/2021-08-philadelphia-hd-clear-conference-room-window-film.jpg',
    alt: 'Mirror refinishing window film Philadelphia',
    href: '/benefits/mirror-refinishing/',
  },
  {
    label: 'Bird Strike Prevention',
    desc: 'Virtually invisible fritted film patterns alert birds to glass barriers, preventing collisions without obstructing your view.',
    img: '/images/2021-08-philadelphia-window-film-bird-strike-protection.jpg',
    alt: 'Bird strike prevention window film Philadelphia',
    href: '/benefits/bird-strike-prevention/',
  },
  {
    label: 'School Security Film',
    desc: 'Fortify classroom and entry glass against forced entry and accidental impact with certified security film systems.',
    img: '/images/2021-09-classroom-window-film-philadelphia.jpg',
    alt: 'School security window film Philadelphia',
    href: '/benefits/school-security-window-film/',
  },
  {
    label: 'Updating Surfaces',
    desc: 'Transform elevator cabs, lobby surfaces, and interior metal with decorative film — no renovation required.',
    img: '/images/2021-08-philadelphia-window-film-elavator-surface-refinishing.jpg',
    alt: 'Surface updating window film Philadelphia',
    href: '/benefits/updating-surfaces/',
  },
];

const featuredBenefits = [
  {
    number: '01',
    heading: 'Energy Savings & Solar Control',
    body: 'Window film boosts glazing performance, reducing energy costs and addressing hot and cold spots throughout your property. Our films can reduce cooling costs by up to 30% — available in both clear and tinted options.',
    img: '/images/2021-08-philadelphia-window-film-energy-savings.jpg',
    alt: 'Energy saving window film Philadelphia',
    href: '/benefits/energy-saving-window-film-philadephia/',
    cta: 'Explore Energy Saving Film',
  },
  {
    number: '02',
    heading: 'Safety & Security Film',
    body: 'Safety and security window film significantly enhances the durability and strength of your existing glass. This passive, 24/7 security system protects against natural disasters, break-ins, burglaries, and more.',
    img: '/images/safety-and-security-window-film-philadelphia.png',
    alt: 'Safety and security window film Philadelphia',
    href: '/benefits/safety-and-security/',
    cta: 'Explore Security Film',
  },
  {
    number: '03',
    heading: 'Privacy & Decorative Film',
    body: 'Window film provides a variety of privacy solutions for conference rooms, waiting areas, patient rooms, and home windows. Custom logos, etched and frosted patterns available from leading brands.',
    img: '/images/2021-08-philadelphia-window-film-glare-privacy.jpg',
    alt: 'Privacy window film Philadelphia',
    href: '/benefits/privacy-window-film-philadelphia/',
    cta: 'Explore Privacy Film',
  },
];

const whyItems = [
  { icon: 'lucide:award',       title: '15+ Years Experience',       sub: 'Serving Philadelphia since 2008' },
  { icon: 'lucide:badge-check', title: 'Factory-Certified Installers', sub: '3M, LLumar, Vista, Solar Gard' },
  { icon: 'lucide:file-check',  title: 'Lifetime Warranty',           sub: 'On all residential & commercial films' },
  { icon: 'lucide:calendar',    title: 'Free Consultations',          sub: 'On-site estimates, no obligation' },
  { icon: 'lucide:star',        title: '4.9 Google Rating',           sub: '5,000+ projects completed' },
  { icon: 'lucide:map-pin',     title: 'Philadelphia-Based',          sub: 'Local crews, same-week scheduling' },
  { icon: 'lucide:layers',      title: 'Premium Film Brands',         sub: '3M, LLumar, Vista, Solar Gard, Madico' },
  { icon: 'lucide:umbrella',    title: 'Fully Insured',               sub: 'Licensed & insured in PA and NJ' },
];
---

<BaseLayout title={title} description={description} canonical="https://www.windowfilmphiladelphia.net/benefits/">

<InnerPageHero
  title="Window Film Benefits"
  bgImage="/images/wfp-premium-films-v2.jpg"
  desc="Explore the full range of window film solutions for Philadelphia properties."
/>

<div class="ip-page-body">

<!-- ══════════════════════════════════════
     INTRO — 2-col: big heading left, text + CTAs right
     ══════════════════════════════════════ -->
<section class="bp-intro">
  <div class="bp-intro__inner">
    <div class="bp-intro__left">
      <span class="bp-eyebrow">What We Offer</span>
      <h1 class="bp-intro__title">Everything Window Film Can Do for Your Property</h1>
    </div>
    <div class="bp-intro__right">
      <p class="bp-intro__lead">From energy savings and UV protection to ballistic resistance and decorative design — window film is one of the most versatile property upgrades available. Explore the full range of benefits below and find the right solution for your Philadelphia home or business.</p>
      <div class="bp-intro__ctas">
        <a href="/contact/" class="bp-btn bp-btn--primary">Get a Free Quote</a>
        <a href="/process/" class="bp-btn bp-btn--ghost">Our Process</a>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     STATS — 2-col: hero image + 2×2 card grid
     ══════════════════════════════════════ -->
<section class="bp-stats">
  <div class="bp-stats__inner">

    <div class="bp-stats__hero-img">
      <img src="/images/wfp-bp-stats-large.jpg" alt="Commercial window film installation Philadelphia" loading="lazy" />
    </div>

    <div class="bp-stats__grid">

      <div class="bp-stat-card">
        <div class="bp-stat-card__top">
          <div class="bp-stat-card__label">Years of Experience</div>
          <div class="bp-stat-card__rule"></div>
        </div>
        <div class="bp-stat-card__bottom">
          <div class="bp-stat-card__num">15<span class="bp-stat-card__accent">+</span></div>
          <div class="bp-stat-card__sub">Serving Philadelphia since 2008</div>
        </div>
      </div>

      <div class="bp-stat-card">
        <div class="bp-stat-card__top">
          <div class="bp-stat-card__label">Projects Completed</div>
          <div class="bp-stat-card__rule"></div>
        </div>
        <div class="bp-stat-card__bottom">
          <div class="bp-stat-card__num">5k<span class="bp-stat-card__accent">+</span></div>
          <div class="bp-stat-card__sub">Residential &amp; commercial installs</div>
        </div>
      </div>

      <div class="bp-stat-card">
        <div class="bp-stat-card__top">
          <div class="bp-stat-card__label">Google Rating</div>
          <div class="bp-stat-card__rule"></div>
        </div>
        <div class="bp-stat-card__bottom">
          <div class="bp-stat-card__num">4.9<span class="bp-stat-card__accent">★</span></div>
          <div class="bp-stat-card__sub">Average customer rating</div>
        </div>
      </div>

      <div class="bp-stat-card bp-stat-card--img">
        <img src="/images/wfp-bp-stats-card.jpg" alt="Window film professionals Philadelphia" loading="lazy" />
      </div>

    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     FEATURED BENEFITS — numbered alternating rows
     ══════════════════════════════════════ -->
<section class="bp-featured">
  <div class="bp-featured__hd">
    <span class="bp-eyebrow">Why Window Film Philadelphia</span>
    <h2 class="bp-featured__title">The difference you'll notice<br/>from day one</h2>
  </div>

  {featuredBenefits.map((b, i) => (
    <div class={`bp-feat-row fade-in${i % 2 === 1 ? ' bp-feat-row--rev' : ''}`}>
      <div class="bp-feat-row__img">
        <img src={b.img} alt={b.alt} width="600" height="480" loading="lazy" />
        <span class="bp-feat-row__pill">{b.heading}</span>
      </div>
      <div class="bp-feat-row__content">
        <span class="bp-feat-row__num">{b.number}</span>
        <h3 class="bp-feat-row__heading">{b.heading}</h3>
        <p class="bp-feat-row__body">{b.body}</p>
        <a href={b.href} class="bp-feat-row__cta">
          {b.cta}
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/></svg>
        </a>
      </div>
    </div>
  ))}
</section>

<!-- ══════════════════════════════════════
     ALL BENEFITS GRID — icon cards
     ══════════════════════════════════════ -->
<section class="bp-all">
  <div class="bp-all__hd">
    <span class="bp-eyebrow">Full Range of Solutions</span>
    <h2 class="bp-all__title">Take a brief look at all the benefits we offer</h2>
  </div>
  <div class="bp-all__grid">
    {benefits.map((b, i) => (
      <a href={b.href} class="bp-all__card fade-in" style={`transition-delay: ${(i % 4) * 80}ms`}>
        <div class="bp-all__card-img">
          <img src={b.img} alt={b.alt} loading="lazy" />
        </div>
        <div class="bp-all__card-body">
          <h3 class="bp-all__card-title">{b.label}</h3>
          <div class="bp-all__card-rule"></div>
          <p class="bp-all__card-desc">{b.desc}</p>
        </div>
      </a>
    ))}
  </div>
</section>

<!-- ══════════════════════════════════════
     WHY US — 4-col icon grid
     ══════════════════════════════════════ -->
<section class="bp-why">
  <div class="bp-why__hd">
    <span class="bp-eyebrow">Why Window Film Philadelphia</span>
    <h2 class="bp-why__title">Genuine partner in every aspect of your project</h2>
  </div>
  <div class="bp-why__grid">
    {whyItems.map((item) => (
      <div class="bp-why__item fade-in">
        <div class="bp-why__icon"><Icon name={item.icon} width="32" height="32" /></div>
        <div class="bp-why__divider"></div>
        <h4 class="bp-why__item-title">{item.title}</h4>
        <p class="bp-why__item-sub">{item.sub}</p>
      </div>
    ))}
  </div>
</section>

<!-- ══════════════════════════════════════
     FAQ ACCORDION
     ══════════════════════════════════════ -->
<section class="bp-faq">
  <div class="bp-faq__hd">
    <span class="bp-eyebrow">FAQ</span>
    <h2 class="bp-faq__title">Common questions about window film benefits</h2>
  </div>
  <div class="bp-faq__item bp-faq__item--open">
    <div class="bp-faq__q">Can one film provide multiple benefits? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Yes — many films are multi-functional. For example, a solar control film simultaneously rejects heat, blocks UV rays, reduces glare, and can add privacy. Our team will help you select a film that addresses all your goals in one installation.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">How long does window film last? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Most residential and commercial films are designed to last 10–20 years. All our installations include a lifetime manufacturer warranty against peeling, bubbling, and fading for the original property owner.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">Will window film affect my view or natural light? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Modern window films are engineered to maintain a natural view while controlling light and heat. Many energy-saving films are nearly invisible. We offer a range of visible light transmission (VLT) levels to suit your preference.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">Is window film a good investment for commercial properties? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Absolutely. Commercial window film typically pays for itself within 3–5 years through HVAC energy savings alone. It also reduces glare, protects furnishings, and enhances the building's security profile.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">Can window film be applied to any type of glass? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Window film can be applied to most flat glass surfaces — single-pane, double-pane, tempered, laminated, and more. Our team will assess your specific glass type during the free consultation to recommend the right film and confirm compatibility.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">How do I care for window film after installation? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Window film is low-maintenance. Allow 30 days for the film to fully cure after installation. After that, clean with a soft cloth and mild soap or ammonia-free glass cleaner. Avoid abrasive scrubbers. See our <a href="/resources/maintenance-and-care/">Maintenance &amp; Care guide</a> for full details.</div>
  </div>
</section>

<!-- ══════════════════════════════════════
     BRAND LOGOS
     ══════════════════════════════════════ -->
<BrandLogos />

<!-- ══════════════════════════════════════
     CTA BANNER
     ══════════════════════════════════════ -->
<div class="bp-cta fade-in">
  <h2>Ready to experience the benefits of <em>window film?</em></h2>
  <div class="bp-cta__btns">
    <a href="/contact/" class="bp-btn bp-btn--white">Get a Free Quote</a>
    <a href="tel:+12673947980" class="bp-btn bp-btn--green">Call (267) 394-7980</a>
  </div>
</div>

</div><!-- end ip-page-body -->

</BaseLayout>

<style>
/* ── PAGE BODY WRAPPER ── */
.ip-page-body {
  position: relative;
  background: #ffffff;
  border-top-left-radius: 40px;
  border-top-right-radius: 40px;
  border-bottom-left-radius: 40px;
  border-bottom-right-radius: 40px;
  margin-top: -40px;
  z-index: 10;
  overflow: visible;
  padding-bottom: 80px;
}

/* ── EYEBROW ── */
.bp-eyebrow {
  display: inline-block;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--green, #81AB4C);
  margin-bottom: 16px;
}

/* ── BUTTONS ── */
.bp-btn {
  display: inline-block; padding: 14px 28px;
  border-radius: var(--radius-pill, 100px);
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; font-weight: 500;
  text-decoration: none; transition: all 0.2s;
  border: 2px solid transparent; white-space: nowrap;
}
.bp-btn--primary { background: var(--green, #81AB4C); color: #fff; border-color: var(--green, #81AB4C); }
.bp-btn--primary:hover { background: #6e9640; border-color: #6e9640; transform: translateY(-2px); color: #fff; }
.bp-btn--ghost { background: transparent; color: var(--brand, #272E32); border-color: var(--brand, #272E32); }
.bp-btn--ghost:hover { background: var(--brand, #272E32); color: #fff; transform: translateY(-2px); }
.bp-btn--white { background: #fff; color: var(--brand, #272E32); border-color: #fff; font-weight: 600; }
.bp-btn--white:hover { background: var(--off-white, #F7F6F3); transform: translateY(-2px); }
.bp-btn--green { background: var(--green, #81AB4C); color: #fff; border-color: var(--green, #81AB4C); }
.bp-btn--green:hover { background: #6e9640; transform: translateY(-2px); color: #fff; }

/* ── INTRO ── */
.bp-intro {
  padding: 80px 10%;
  border-top-left-radius: 40px;
  border-top-right-radius: 40px;
  overflow: hidden;
}
.bp-intro__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}
.bp-intro__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(36px, 4.5vw, 58px);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -1px;
  color: var(--text-dark, #1a1a1a);
  margin: 0;
}
.bp-intro__lead {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 17px;
  color: var(--text-mid, #4a4a4a);
  line-height: 1.75;
  margin-bottom: 32px;
}
.bp-intro__ctas { display: flex; gap: 14px; flex-wrap: wrap; }

/* ── STATS ── */
.bp-stats {
  background: #ffffff;
  padding: 80px 10%;
}
.bp-stats__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  align-items: stretch;
}
.bp-stats__hero-img {
  border-radius: 32px;
  overflow: hidden;
  min-height: 500px;
}
.bp-stats__hero-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.bp-stats__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  gap: 16px;
  height: 100%;
}
.bp-stat-card {
  background: var(--off-white, #F7F6F3);
  border-radius: 24px;
  padding: 28px 28px 32px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.bp-stat-card--img {
  padding: 0;
  overflow: hidden;
}
.bp-stat-card--img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.bp-stat-card__label {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text-light, #888);
  margin-bottom: 10px;
}
.bp-stat-card__rule {
  width: 100%;
  height: 1px;
  background: var(--light-gray, #EFEFED);
}
.bp-stat-card__num {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(44px, 4vw, 64px);
  font-weight: 700;
  color: var(--text-dark, #1a1a1a);
  line-height: 1;
  margin-bottom: 10px;
}
.bp-stat-card__accent {
  color: var(--green, #81AB4C);
}
.bp-stat-card__sub {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px;
  color: var(--text-light, #888);
  line-height: 1.4;
}

/* ── FEATURED BENEFITS ── */
.bp-featured {
  padding: 100px 10%;
  background: var(--off-white, #F7F6F3);
}
.bp-featured__hd {
  margin-bottom: 72px;
}
.bp-featured__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(32px, 4vw, 52px);
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: -0.5px;
  color: var(--text-dark, #1a1a1a);
  margin: 0;
}
.bp-feat-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  margin-bottom: 100px;
}
.bp-feat-row:last-child { margin-bottom: 0; }
.bp-feat-row--rev .bp-feat-row__img { order: 2; }
.bp-feat-row--rev .bp-feat-row__content { order: 1; }
.bp-feat-row__img {
  position: relative;
  height: 480px;
  border-radius: 32px;
  overflow: hidden;
}
.bp-feat-row__img img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}
.bp-feat-row__pill {
  position: absolute; bottom: 24px; left: 24px;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(8px);
  padding: 10px 18px;
  border-radius: 100px;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px; font-weight: 600;
  color: var(--brand, #272E32);
  box-shadow: 0 4px 16px rgba(0,0,0,0.1);
}
.bp-feat-row__num {
  display: block;
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 72px;
  font-weight: 700;
  color: var(--green, #81AB4C);
  line-height: 1;
  opacity: 0.25;
  margin-bottom: -8px;
}
.bp-feat-row__heading {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(24px, 3vw, 36px);
  font-weight: 700;
  color: var(--text-dark, #1a1a1a);
  line-height: 1.2;
  margin-bottom: 20px;
  letter-spacing: -0.3px;
}
.bp-feat-row__body {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 16px;
  color: var(--text-mid, #4a4a4a);
  line-height: 1.8;
  margin-bottom: 28px;
}
.bp-feat-row__cta {
  display: inline-flex; align-items: center; gap: 8px;
