---
import BaseLayout from '../layouts/BaseLayout.astro';
import BackAndForthSection from '../components/BackAndForthSection.astro';

const title = 'Welcome | Window Film Philadelphia | Leading Window Film Solutions';
const description = 'Window Film Philadelphia is honored to provide leading window film solutions for Philadelphia properties. Schedule your free consultation!';
import BrandLogos from '../components/BrandLogos.astro';
import CTAStrip from '../components/CTAStrip.astro';
---

<BaseLayout title={title} description={description} canonical='https://www.windowfilmphiladelphia.net/'>
  <section class="page-hero" style="background-image: linear-gradient(rgba(40,40,40,0.62), rgba(40,40,40,0.80)), url('/images/window-film-contractor-philadelphia.jpg'); background-size: cover; background-position: center;">
    <div class="container">
      <h1>Welcome to Window Film Philadelphia!</h1>
    </div>
  </section>

  <BackAndForthSection
  heading={'Welcome to Window Film Philadelphia!'}
  body={'Window Film Philadelphia proudly serves residential and commercial properties throughout the Philadelphia metropolitan area. Our experienced team is always available to help you transform your property with our incredible, effective solutions. From energy savings to custom decorative printing, window film has exclusive benefits to offer your upcoming project. Work with our trusted contractors to save money, improve productivity, and much more.'}
  imageSrc={'/images/window-film-contractor-philadelphia.jpg'}
  imageAlt={'window film contractor philadelphia'}
  flip={false}
  altBg={false}
/>

  <BackAndForthSection
  heading={'Trusted Experts for Window Film in Philadelphia'}
  body={'We’re honored to provide industry-leading solutions to address a number of property concerns. With partnerships with all of the top window film manufacturers, we’re able to provide the most extensive range of window film solutions for both residential and commercial properties. Our experts are always here to help you with your project goals.'}
  imageSrc={'/images/2021-08-residential.png'}
  imageAlt={''}
  flip={true}
  altBg={true}
/>

  <BackAndForthSection
  heading={'Why Window Film?'}
  body={'Window film is a highly versatile solution that can address a wide variety of both residential and commercial property concerns. With extensive specialty and multi-purpose products available, this cost-effective alternative can you achieve your project goals without major renovations. Experience effective solutions that include energy conservation, glare reduction, UV protection, decor, security, and much more. Schedule a consultation to learn more about the benefits of window film in Philadelphia today!'}
  imageSrc={'/images/2021-08-commercial.png'}
  imageAlt={''}
  flip={false}
  altBg={false}
/>

  <BrandLogos />
  <CTAStrip />
</BaseLayout>
