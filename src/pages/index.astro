<script>
  // Apply data-bg backgrounds to cards
  document.querySelectorAll('.hp-svc-card[data-bg]').forEach(card => {
    card.style.backgroundImage = `url('${card.dataset.bg}')`;
  });

  // Run IntersectionObserver when the browser is idle — keeps it off
  // the critical path during initial paint.
  const registerFadeIns = () => {
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.12 });
    document.querySelectorAll('.fade-in').forEach(el => obs.observe(el));
  };

  if ('requestIdleCallback' in window) {
    requestIdleCallback(registerFadeIns);
  } else {
    // Fallback for Safari < 16
    setTimeout(registerFadeIns, 200);
  }
</script>
