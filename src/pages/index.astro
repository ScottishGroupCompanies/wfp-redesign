  z-index: 1;
  padding: 200px 5% 400px;
  width: 100%;
  max-width: 100%;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hp-hero__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(255,255,255,0.15);
  color: #fff;
  padding: 6px 14px;
  border-radius: var(--radius-pill, 100px);
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  margin-bottom: 24px;
  backdrop-filter: blur(4px);
}
.hp-hero__eyebrow::before {
  content: '';
  width: 6px; height: 6px;
  background: var(--green, #81AB4C);
  border-radius: 50%;
}

.hp-hero h1 {
  font-family: var(--font-serif);
  font-size: clamp(38px, 5vw, 62px);
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -1px;
  color: #fff;
  margin-bottom: 24px;
  text-align: center;
}
.hp-hero h1 em { font-style: italic; color: var(--green, #81AB4C); }

.hp-hero__lead {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 18px;
  color: rgba(255,255,255,0.9);
  line-height: 1.7;
  max-width: 560px;
  margin-bottom: 40px;
}

.hp-hero__ctas {
  display: flex;
  gap: 14px;
  align-items: center;
  flex-wrap: nowrap;
}

/* Shared button styles scoped to homepage */
.s-btn {
  display: inline-block;
  padding: 14px 28px;
  border-radius: var(--radius-pill, 100px);
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px;
  font-weight: 500;
  text-decoration: none;
  transition: all 0.2s;
  border: 2px solid transparent;
  white-space: nowrap;
  cursor: pointer;
}
.s-btn--primary {
  background: var(--green, #81AB4C);
  color: #fff;
  border-color: var(--green, #81AB4C);
}
.s-btn--primary:hover { background: #6e9640; border-color: #6e9640; transform: translateY(-2px); color: #fff; }
.s-btn--ghost {
  background: transparent;
  color: #fff;
  border-color: rgba(255,255,255,0.7);
}
.s-btn--ghost:hover { background: rgba(255,255,255,0.12); border-color: #fff; transform: translateY(-2px); color: #fff; }
.s-btn--white {
  background: #fff;
  color: var(--brand, #272E32);
  border-color: #fff;
  font-weight: 800;
}
.s-btn--white:hover { background: var(--off-white, #F7F6F3); transform: translateY(-2px); color: var(--brand, #272E32); }
.s-btn--green {
  background: var(--green, #81AB4C);
  color: #fff;
  border-color: var(--green, #81AB4C);
}
.s-btn--green:hover { background: #6e9640; border-color: #6e9640; transform: translateY(-2px); color: #fff; }

.hp-hero__trust {
  margin-top: 48px;
  padding-top: 32px;
  border-top: 1px solid rgba(255,255,255,0.25);
  display: flex;
  gap: 32px;
  align-items: center;
}
.hp-trust-divider { width: 1px; height: 40px; background: rgba(255,255,255,0.25); }
.hp-trust-stat__num {
  font-family: var(--font-serif);
  font-size: 26px;
  font-weight: 800;
  color: #fff;
  display: block;
}
.hp-trust-stat__num span { color: var(--green, #81AB4C); }
.hp-trust-stat__lbl {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px;
  color: rgba(255,255,255,0.65);
}

/* ── LOCATION STRIP ── */
.hp-strip { background: var(--off-white, #F7F6F3); padding: 28px 5%; overflow: hidden; }
.hp-strip__label {
  text-align: center;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 12px; font-weight: 800; letter-spacing: 1px;
  text-transform: uppercase; color: var(--text-light, #888);
  margin-bottom: 20px;
}
.hp-strip__overflow { overflow: hidden; }
.hp-strip__scroll {
  display: flex; gap: 48px; align-items: center;
  animation: s-scroll 28s linear infinite;
  animation-delay: 0.5s;
  width: max-content;
}
@keyframes s-scroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
.hp-strip__item {
  font-family: var(--font-serif);
  font-size: 16px; font-weight: 800;
  color: var(--text-light, #888); white-space: nowrap;
}
.hp-strip__sep {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  color: var(--light-gray, #EFEFED); font-size: 20px;
}

/* ── SHARED SECTION HEADER ── */
.hp-section-hd { text-align: center; margin-bottom: 52px; }
.hp-section-sub {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 17px; color: var(--text-mid, #4a4a4a);
  line-height: 1.7; max-width: 540px; margin: 0 auto;
}
.hp-section-hd .section-title { margin: 0 auto 16px; }

/* ── FROSTED GLASS SERVICE STRIP ── */
.hp-glass {
  position: relative;
  z-index: 20;
  padding: 0 5% 0;
  top: -120px;
}
.hp-glass__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  max-width: 1200px;
  margin: -160px auto 0;
}
.hp-glass__card {
  background: rgba(30, 30, 30, 0.65);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  padding: 60px 32px;
  transition: transform 0.25s, box-shadow 0.25s;
}
.hp-glass__card:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
}
.hp-glass__card .hp-svc-card__icon {
  background: transparent;
  margin-bottom: 16px;
}
.hp-glass__card .hp-svc-card__icon--svg {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  color: var(--green, #81AB4C);
}
.hp-glass__card .hp-glass__hr {
  border: none;
  height: 1px;
  background: rgba(255, 255, 255, 0.15);
  margin-bottom: 16px;
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94),
              background 0.2s ease;
}
.hp-glass__card:hover .hp-glass__hr {
  transform: scaleX(1);
  background: var(--green, #81AB4C);
}
.hp-glass__card h3 {
  font-family: var(--font-serif);
  font-size: 20px; font-weight: 800;
  color: #fff; margin-bottom: 12px;
}
.hp-glass__card p {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; color: rgba(255, 255, 255, 0.75);
  line-height: 1.65; margin: 0;
}
.hp-svc-card__link--light {
  color: rgba(255, 255, 255, 0.85) !important;
}
.hp-svc-card__link--light:hover {
  color: #fff !important;
}

/* ── LOCATION SCROLL STRIP ── */
.hp-strip {
  background: var(--off-white, #F7F6F3);
  padding: 28px 5%;
  overflow: hidden;
}
.hp-strip__label {
  text-align: center;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 12px; font-weight: 800; letter-spacing: 1px;
  text-transform: uppercase; color: var(--text-light, #888);
  margin-bottom: 20px;
}
.hp-strip__overflow { overflow: hidden; }
.hp-strip__scroll {
  display: flex; gap: 48px; align-items: center;
  animation: s-scroll 28s linear infinite;
  width: max-content;
}
@keyframes s-scroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
.hp-strip__item {
  font-family: var(--font-serif);
  font-size: 16px; font-weight: 800;
  color: var(--text-light, #888); white-space: nowrap;
}
.hp-strip__sep {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  color: var(--light-gray, #EFEFED); font-size: 20px;
}

/* ── SERVICES GRID (What We Do) — two-row card grid ── */
.hp-svc-grid {
  display: flex;
  flex-direction: column;
  gap: 20px;
  padding: 0 5% 80px;
  max-width: 1200px;
  margin: 0 auto;
}
/* Each row: 3 equal cards */
.hp-svc-grid__row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}
/* Bottom row: 2 cards, each roughly half the width of the top row's content area */
.hp-svc-grid__row--bottom {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  max-width: calc(1920px * 2 / 3);
}
/* CTA text below the card grid */
.hp-svc-grid__cta {
  text-align: center;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px;
  font-weight: 700;
  color: #1a1a1a;
  padding-bottom: 20px;
}
.hp-svc-grid__cta a {
  color: #1a1a1a;
  text-decoration: underline;
  text-underline-offset: 3px;
}
.hp-svc-grid__cta a:hover {
  color: var(--green);
}
/* All cards: same height (370px min) */

/* Card — white background, all corners 20px */
.hp-svc-card {
  background-color: #FFFFFF;
  border-radius: 20px;
  overflow: hidden;
  text-decoration: none;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  position: relative;
  min-height: 370px;
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}

/* Radial green fill — starts at top-right, expands outward on hover */
.hp-svc-card::before {
  content: '';
  position: absolute;
  top: -100%;
  right: -100%;
  width: 200%;
  height: 200%;
  border-radius: 50%;
  background: var(--green, #81AB4C);
  transform: scale(0);
  transform-origin: center;
  transition: transform 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  z-index: 1;
  pointer-events: none;
}

/* Image — bottom of card */
.hp-svc-card__img {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 65%;
  object-fit: cover;
  object-position: bottom center;
  z-index: 2;
  pointer-events: none;
}

/* Title — top-left */
.hp-svc-card h3 {
  font-family: var(--font-serif);
  font-size: 20px;
  font-weight: 800;
  color: #222;
  margin: 0;
  line-height: 1.3;
  position: relative;
  z-index: 3;
  padding: 24px 24px 0;
  transition: color 0.3s ease;
}

/* Button — inside card, top-right */
.hp-svc-card__btn {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--green);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  color: #FFFFFF;
  z-index: 6;
  transition: background 0.3s, color 0.3s;
  cursor: pointer;
  pointer-events: auto;
}

/* Hover — card itself is the hover target */
.hp-svc-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 48px rgba(0,0,0,0.15);
}
.hp-svc-card:hover::before {
  transform: scale(2);
}
.hp-svc-card:hover h3 {
  color: #fff;
}
.hp-svc-card:hover .hp-svc-card__btn {
  background: #FFFFFF;
  color: #000000;
  border-color: var(--green, #81AB4C);
}


@media (max-width: 768px) {
  .hp-svc-grid {
    padding: 0 5% 60px;
  }
  .hp-svc-grid__row,
  .hp-svc-grid__row--bottom {
    grid-template-columns: 1fr;
  }
  .hp-svc-card {
    min-height: 280px;
  }
}

/* ── STATS ── */
.hp-stats {
  background: #ffffff;
  padding: 0 5% 80px;
}
.hp-stats__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  align-items: stretch;
}
.hp-stats__hero-img {
  border-radius: 32px;
  overflow: hidden;
  min-height: 500px;
}
.hp-stats__hero-img img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}
.hp-stats__cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  gap: 16px;
  height: 100%;
}
.hp-stat-card {
  background: var(--off-white, #F7F6F3);
  border-radius: 24px;
  padding: 28px 28px 32px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.hp-stat-card--img { padding: 0; overflow: hidden; }
.hp-stat-card--img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.hp-stat-card__label {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 11px; font-weight: 700; letter-spacing: 2px;
  text-transform: uppercase; color: var(--text-light, #888);
  margin-bottom: 10px;
}
.hp-stat-card__rule { width: 100%; height: 1px; background: var(--light-gray, #EFEFED); }
.hp-stat-card__num {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(44px, 4vw, 64px); font-weight: 700;
  color: var(--text-dark, #1a1a1a); line-height: 1; margin-bottom: 10px;
}
.hp-stat-card__accent { color: var(--green, #81AB4C); }
.hp-stat-card__sub {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px; color: var(--text-light, #888); line-height: 1.4;
}

/* ── WHY US ── */
.hp-why { background: var(--off-white, #F7F6F3); padding: 100px 5%; }
.hp-why__row {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 80px; align-items: center; margin-bottom: 80px;
}
.hp-why__row:last-of-type { margin-bottom: 0; }
.hp-why__row--rev .hp-why__img  { order: 2; }
.hp-why__row--rev .hp-why__content { order: 1; }
.hp-why__img {
  height: 420px; border-radius: var(--radius-xl, 40px);
  overflow: hidden; background: var(--light-gray, #EFEFED); position: relative;
}
.hp-why__img img { width: 100%; height: 100%; object-fit: cover; }
.hp-why__pill {
  position: absolute; top: 24px; right: 24px;
  background: #fff; padding: 10px 18px;
  border-radius: var(--radius-pill, 100px);
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px; font-weight: 800; color: var(--brand, #272E32);
  box-shadow: 0 4px 16px rgba(0,0,0,0.1);
}
.hp-why__num {
  font-family: var(--font-serif);
  font-size: 64px; font-weight: 800;
  color: var(--green); line-height: 1; margin-bottom: 4px;
}
.hp-why__content h3 {
  font-family: var(--font-serif);
  font-size: 30px; font-weight: 800;
  color: var(--text-dark, #1a1a1a); line-height: 1.2; margin-bottom: 16px;
}
.hp-why__content p {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 16px; color: var(--text-mid, #4a4a4a);
  line-height: 1.75; margin-bottom: 24px;
}
.hp-why__pts { list-style: none; padding: 0; }
.hp-why__pts li {
  display: flex; align-items: flex-start; gap: 10px;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; color: var(--text-mid, #4a4a4a); padding: 6px 0;
}
.hp-why__pts li::before {
  content: '✓'; color: var(--green, #81AB4C);
  font-weight: 700; font-size: 14px; margin-top: 2px; flex-shrink: 0;
}

/* ── HOW IT WORKS ── */
.hp-how { background: var(--off-white, #F7F6F3); padding: 100px 5%; }
.hp-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
.hp-step {
  background: #fff; border-radius: var(--radius-lg, 24px);
  padding: 32px 24px; position: relative; transition: transform 0.2s;
}
.hp-step:hover { transform: translateY(-4px); }
.hp-step__num {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px; font-weight: 800; color: var(--green, #81AB4C);
  margin-bottom: 20px; letter-spacing: 0.5px;
}
.hp-step__icon {
  width: 48px; height: 48px;
  border-radius: var(--radius-md, 16px);
  background: var(--green-light, #eef4e4);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 20px;
}
.hp-step h4 {
  font-family: var(--font-serif);
  font-size: 18px; font-weight: 800;
  color: var(--text-dark, #1a1a1a); margin-bottom: 10px;
}
.hp-step p {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 14px; color: var(--text-mid, #4a4a4a);
  line-height: 1.65; margin: 0;
}
.hp-step__connector {
  position: absolute; top: 44px; right: -12px;
  width: 24px; height: 2px;
  background: var(--light-gray, #EFEFED); z-index: 1;
}
.hp-step:last-child .hp-step__connector { display: none; }

/* ── TESTIMONIALS ── */
.hp-testi {
  background: #fff;
  padding: 0px 0;
  padding-bottom: 100px;
}
.hp-testi__grid {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 5%;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.hp-testi__card {
  background: var(--off-white, #F7F6F3);
  border-radius: var(--radius-lg, 24px); padding: 32px 28px;
}
.hp-testi__stars { color: var(--green, #81AB4C); font-size: 16px; margin-bottom: 16px; letter-spacing: 2px; }
.hp-testi__quote {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; color: var(--text-mid, #4a4a4a);
  line-height: 1.75; margin-bottom: 24px; font-style: italic;
}
.hp-testi__author { display: flex; align-items: center; gap: 12px; }
.hp-testi__avatar {
  width: 44px; height: 44px; border-radius: 50%;
  background: var(--brand, #272E32); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 14px; font-weight: 800; flex-shrink: 0;
}
.hp-testi__name {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 14px; font-weight: 800; color: var(--text-dark, #1a1a1a);
}
.hp-testi__loc {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px; color: var(--text-light, #888);
}

/* ── CTA SECTION (wrapper) ── */
.hp-cta-section {
  position: relative;
  background: #FFFFFF;
  border-bottom-left-radius: 40px;
  border-bottom-right-radius: 40px;
  overflow: visible;
  z-index: 2;
  padding-bottom: 60px;
}

/* ── CTA BANNER ── */
.hp-cta {
  background: var(--brand, #272E32);
  border-radius: var(--radius-xl, 40px);
  padding: 72px 60px;
  display: flex; align-items: center; justify-content: space-between;
  gap: 40px; margin: 0 5% 100px;
}
.hp-cta h2 {
  font-family: var(--font-serif);
  font-size: 36px; font-weight: 800; color: #fff;
  line-height: 1.2; max-width: 480px; margin: 0;
}
.hp-cta h2 em { font-style: italic; color: var(--green, #81AB4C); }
.hp-cta__btns { display: flex; gap: 14px; flex-shrink: 0; }

/* ── RESPONSIVE ── */
@media (max-width: 860px) {
  .hp-hero { padding: 80px 5% 60px; }
  .hp-hero__content { padding: 60px 5% 160px; }
  .hp-hero h1 { font-size: clamp(32px, 6vw, 48px); }
  .hp-hero__ctas { flex-wrap: wrap; justify-content: center; }
  .hp-glass { margin-top: -120px; }
  .hp-glass__grid { margin: -120px auto 0; }
  .hp-glass__grid { grid-template-columns: 1fr; gap: 16px; }
  .hp-glass { padding: 0 5% 40px; }
  .hp-services { padding: 60px 5% 80px; }
  .hp-strip__scroll { animation-duration: 40s; }
  .hp-stats__inner { grid-template-columns: 1fr; }
  .hp-stats__hero-img { min-height: 360px; }
  .hp-why__row,
  .hp-why__row--rev { grid-template-columns: 1fr; gap: 32px; }
  .hp-why__row--rev .hp-why__img    { order: 0; }
  .hp-why__row--rev .hp-why__content { order: 1; }
  .hp-why__img { height: 280px; }
  .hp-steps { grid-template-columns: repeat(2, 1fr); }
  .hp-step__connector { display: none; }
  .hp-testi__grid { grid-template-columns: 1fr; }
  .hp-cta { flex-direction: column; padding: 48px 32px; text-align: center; }
  .hp-cta h2 { font-size: 28px; max-width: 100%; }
}

/* ── APPLICATIONS — sticky scroll section ── */
.hp-apps {
  position: relative;
  height: 300vh;
  margin: 0;
}
.hp-apps__sticky {
  position: sticky;
  top: 20vh;
  height: 100vh;
  overflow: hidden;
}
.hp-apps__inner {
  display: grid;
  grid-template-columns: 50% 50%;
  height: 85vh;
}
.hp-apps__text {
  background: #1a1a1a;
  padding: 80px 60px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
  overflow: hidden;
}
.hp-apps__pics {
  position: relative;
  overflow: hidden;
}
.hp-apps__img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  transform: translateY(100%);
  opacity: 0;
  transition: transform 0.8s cubic-bezier(0.76, 0, 0.24, 1), opacity 0.4s ease;
  will-change: transform;
}
.hp-apps__img.hp-apps__img--active {
  transform: translateY(0);
  opacity: 1;
  z-index: 1;
}
.hp-apps__img.hp-apps__img--exit {
  transform: translateY(-100%);
}
.hp-apps__slide {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 15vh;
  left: 0;
  padding: 80px 60px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.5s ease, transform 0.5s ease;
  transition-delay: 0.2s;
