---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Window Film Philadelphia | Leading Window Film Solutions';
const description = 'Window Film Philadelphia provides professional window film installation for homes, businesses, and commercial properties throughout the Philadelphia metro area. Free quotes!';
---

<BaseLayout title={title} description={description} canonical="https://www.windowfilmphiladelphia.net/">

<!-- ══════════════════════════════════════
     HERO — 2-col: copy left, image right
     ══════════════════════════════════════ -->
<section class="hp-hero">
  <div class="hp-hero__content">
    <div class="hp-hero__eyebrow">Serving Philadelphia Since 2008</div>
    <h1>Window Film Solutions <em>Done Right,</em> Every Time</h1>
    <p class="hp-hero__lead">Professional window film installation for homes, businesses, and commercial properties throughout Philadelphia and the surrounding metro area. Trusted by thousands of Pennsylvania and New Jersey clients.</p>
    <div class="hp-hero__ctas">
      <a href="/contact/" class="s-btn s-btn--primary">Get a Free Quote</a>
      <a href="/process/" class="s-btn s-btn--ghost">Our Process</a>
    </div>
    <div class="hp-hero__trust">
      <div class="hp-trust-stat">
        <span class="hp-trust-stat__num">15<span>+</span></span>
        <span class="hp-trust-stat__lbl">Years of experience</span>
      </div>
      <div class="hp-trust-divider"></div>
      <div class="hp-trust-stat">
        <span class="hp-trust-stat__num">5k<span>+</span></span>
        <span class="hp-trust-stat__lbl">Projects completed</span>
      </div>
      <div class="hp-trust-divider"></div>
      <div class="hp-trust-stat">
        <span class="hp-trust-stat__num">4.9<span>★</span></span>
        <span class="hp-trust-stat__lbl">Average rating</span>
      </div>
    </div>
  </div>
  <div class="hp-hero__visual">
    <div class="hp-hero__img-wrap">
      <img
        src="/images/window-film-contractor-philadelphia.jpg"
        alt="Window film contractor Philadelphia"
        width="600"
        height="460"
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <div class="hp-hero__badge">
      <div class="hp-hero__badge-icon">🏅</div>
      <div>
        <div class="hp-hero__badge-title">#1 in Philadelphia</div>
        <div class="hp-hero__badge-sub">Window Film Installer</div>
      </div>
    </div>
    <div class="hp-hero__accent">Lifetime Warranty Included</div>
  </div>
</section>

<!-- ══════════════════════════════════════
     LOCATION SCROLL STRIP
     ══════════════════════════════════════ -->
<div class="hp-strip">
  <p class="hp-strip__label">Proudly serving the greater Philadelphia area</p>
  <div class="hp-strip__overflow">
    <div class="hp-strip__scroll">
      <span class="hp-strip__item">Philadelphia</span><span class="hp-strip__sep">·</span>
      <span class="hp-strip__item">Camden, NJ</span><span class="hp-strip__sep">·</span>
      <span class="hp-strip__item">Reading</span><span class="hp-strip__sep">·</span>
      <span class="hp-strip__item">Upper Darby</span><span class="hp-strip__sep">·</span>
      <span class="hp-strip__item">Cherry Hill</span><span class="hp-strip__sep">·</span>
      <span class="hp-strip__item">Wilmington</span><span class="hp-strip__sep">·</span>
      <span class="hp-strip__item">Allentown</span><span class="hp-strip__sep">·</span>
      <span class="hp-strip__item">Bucks County</span><span class="hp-strip__sep">·</span>
      <!-- duplicate for seamless loop -->
      <span class="hp-strip__item">Philadelphia</span><span class="hp-strip__sep">·</span>
      <span class="hp-strip__item">Camden, NJ</span><span class="hp-strip__sep">·</span>
      <span class="hp-strip__item">Reading</span><span class="hp-strip__sep">·</span>
      <span class="hp-strip__item">Upper Darby</span><span class="hp-strip__sep">·</span>
      <span class="hp-strip__item">Cherry Hill</span><span class="hp-strip__sep">·</span>
      <span class="hp-strip__item">Wilmington</span><span class="hp-strip__sep">·</span>
      <span class="hp-strip__item">Allentown</span><span class="hp-strip__sep">·</span>
      <span class="hp-strip__item">Bucks County</span>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
     SERVICES GRID
     ══════════════════════════════════════ -->
<section class="hp-services">
  <div class="hp-section-hd">
    <p class="section-eyebrow">What We Do</p>
    <h2 class="section-title">Expert film solutions for <em>every surface</em></h2>
    <p class="hp-section-sub">From homes to high-rises, storefronts to secured facilities — we handle every project with precision and care.</p>
  </div>
  <div class="hp-services__grid">
    <div class="hp-svc-card fade-in">
      <div class="hp-svc-card__icon">🏠</div>
      <h3>Residential Film</h3>
      <p>Reduce heat, glare, and UV damage while adding privacy and style to your home. Energy savings from day one.</p>
      <a href="/benefits/" class="hp-svc-card__link">Learn more →</a>
    </div>
    <div class="hp-svc-card fade-in fade-in-delay-1">
      <div class="hp-svc-card__icon">🏢</div>
      <h3>Commercial Film</h3>
      <p>Protect your assets, reduce HVAC load, and create a professional appearance for offices and retail spaces.</p>
      <a href="/applications/" class="hp-svc-card__link">Learn more →</a>
    </div>
    <div class="hp-svc-card fade-in fade-in-delay-2">
      <div class="hp-svc-card__icon">🛡️</div>
      <h3>Security Film</h3>
      <p>Ballistic-resistant and blast-mitigation films that hold glass together on impact — protecting people and property.</p>
      <a href="/benefits/safety-and-security/" class="hp-svc-card__link">Learn more →</a>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     STATS BAND
     ══════════════════════════════════════ -->
<div class="hp-stats">
  <div class="hp-stats__grid">
    <div class="hp-stat fade-in">
      <span class="hp-stat__num">15<span class="hp-stat__sfx">+</span></span>
      <span class="hp-stat__lbl">Years in business</span>
    </div>
    <div class="hp-stat fade-in fade-in-delay-1">
      <span class="hp-stat__num">5k<span class="hp-stat__sfx">+</span></span>
      <span class="hp-stat__lbl">Projects completed</span>
    </div>
    <div class="hp-stat fade-in fade-in-delay-2">
      <span class="hp-stat__num">50<span class="hp-stat__sfx">+</span></span>
      <span class="hp-stat__lbl">Cities served</span>
    </div>
    <div class="hp-stat fade-in fade-in-delay-3">
      <span class="hp-stat__num">4.9<span class="hp-stat__sfx">★</span></span>
      <span class="hp-stat__lbl">Average Google rating</span>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
     WHY US — alternating rows
     ══════════════════════════════════════ -->
<section class="hp-why">
  <div class="hp-section-hd">
    <p class="section-eyebrow">Why Window Film Philadelphia</p>
    <h2 class="section-title">The difference you'll notice from day one</h2>
  </div>

  <div class="hp-why__row fade-in">
    <div class="hp-why__img">
      <img src="/images/window-film-contractor-philadelphia-1.jpg" alt="Premium window film installation Philadelphia" width="500" height="420" loading="lazy" />
      <span class="hp-why__pill">Lifetime Warranty</span>
    </div>
    <div class="hp-why__content">
      <div class="hp-why__num">01</div>
      <h3>Premium films from the world's top manufacturers</h3>
      <p>We only install films from 3M, LLumar, Vista, Solar Gard, Madico, and more — brands with proven track records and manufacturer-backed warranties that last the lifetime of your film.</p>
      <ul class="hp-why__pts">
        <li>Blocks up to 99% of UV radiation</li>
        <li>Rejects up to 80% of solar heat</li>
        <li>Scratch-resistant hard coat on all films</li>
      </ul>
    </div>
  </div>

  <div class="hp-why__row hp-why__row--rev fade-in">
    <div class="hp-why__img">
      <img src="/images/window-film-contractor-philadelphia-2.jpg" alt="Expert window film installers Philadelphia" width="500" height="420" loading="lazy" />
      <span class="hp-why__pill">Expert Installers</span>
    </div>
    <div class="hp-why__content">
      <div class="hp-why__num">02</div>
      <h3>Installers who treat your property like their own</h3>
      <p>Every member of our installation team is factory-trained and certified. We show up on time, work clean, and leave no trace except a flawless result — guaranteed every time.</p>
      <ul class="hp-why__pts">
        <li>Factory-certified installation team</li>
        <li>Residential &amp; commercial specialists</li>
        <li>Free on-site consultations available</li>
      </ul>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     HOW IT WORKS — 4-step grid
     ══════════════════════════════════════ -->
<section class="hp-how">
  <div class="hp-section-hd">
    <p class="section-eyebrow">The Process</p>
    <h2 class="section-title">From quote to done in <em>four simple steps</em></h2>
  </div>
  <div class="hp-steps">
    <div class="hp-step fade-in">
      <div class="hp-step__num">Step 01</div>
      <div class="hp-step__icon">💬</div>
      <h4>Free consultation</h4>
      <p>Tell us about your project online or by phone. We'll recommend the right film and provide an estimate.</p>
      <div class="hp-step__connector"></div>
    </div>
    <div class="hp-step fade-in fade-in-delay-1">
      <div class="hp-step__num">Step 02</div>
      <div class="hp-step__icon">📋</div>
      <h4>Custom proposal</h4>
      <p>Receive a detailed written quote with film options, pricing, and an expected energy savings projection.</p>
      <div class="hp-step__connector"></div>
    </div>
    <div class="hp-step fade-in fade-in-delay-2">
      <div class="hp-step__num">Step 03</div>
      <div class="hp-step__icon">🛠️</div>
      <h4>Professional install</h4>
      <p>Our certified crew arrives on schedule, installs cleanly, and ensures every panel is perfect before leaving.</p>
      <div class="hp-step__connector"></div>
    </div>
    <div class="hp-step fade-in fade-in-delay-3">
      <div class="hp-step__num">Step 04</div>
      <div class="hp-step__icon">✅</div>
      <h4>Lifetime support</h4>
      <p>Every job comes with a lifetime warranty. If anything goes wrong, we make it right — no questions asked.</p>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     TESTIMONIALS — 3-col cards
     ══════════════════════════════════════ -->
<section class="hp-testi">
  <div class="hp-section-hd">
    <p class="section-eyebrow">Client Reviews</p>
    <h2 class="section-title">What Philadelphia customers are saying</h2>
  </div>
  <div class="hp-testi__grid">
    <div class="hp-testi__card fade-in">
      <div class="hp-testi__stars">★★★★★</div>
      <p class="hp-testi__quote">"The team was professional, fast, and the finished result looks incredible. Our living room is so much cooler now — already seeing the difference on our energy bill."</p>
      <div class="hp-testi__author">
        <div class="hp-testi__avatar">JR</div>
        <div>
          <div class="hp-testi__name">Jennifer R.</div>
          <div class="hp-testi__loc">Residential · Philadelphia, PA</div>
        </div>
      </div>
    </div>
    <div class="hp-testi__card fade-in fade-in-delay-1">
      <div class="hp-testi__stars">★★★★★</div>
      <p class="hp-testi__quote">"Had our entire 3rd-floor office done. The crew was on time, respectful of our workspace, and the film looks great. We'll use Window Film Philadelphia for every project."</p>
      <div class="hp-testi__author">
        <div class="hp-testi__avatar">MT</div>
        <div>
          <div class="hp-testi__name">Marcus T.</div>
          <div class="hp-testi__loc">Commercial · Center City, PA</div>
        </div>
      </div>
    </div>
    <div class="hp-testi__card fade-in fade-in-delay-2">
      <div class="hp-testi__stars">★★★★★</div>
      <p class="hp-testi__quote">"The security film on our storefront gives us real peace of mind. Professional team, clean work, and completed exactly on schedule."</p>
      <div class="hp-testi__author">
        <div class="hp-testi__avatar">BK</div>
        <div>
          <div class="hp-testi__name">Brian K.</div>
          <div class="hp-testi__loc">Commercial · South Philly, PA</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     CTA BANNER — dark rounded block
     ══════════════════════════════════════ -->
<div class="hp-cta fade-in">
  <h2>Ready to transform your <em>home or business?</em></h2>
  <div class="hp-cta__btns">
    <a href="/contact/" class="s-btn s-btn--white">Get a Free Quote</a>
    <a href="tel:+12673947980" class="s-btn s-btn--green">Call (267) 394-7980</a>
  </div>
</div>

</BaseLayout>

<style>
/* ── HERO ── */
.hp-hero {
  min-height: 92vh;
  padding: 80px 5% 60px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
  background: #fff;
}

.hp-hero__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--green-light, #eef4e4);
  color: #5a7a33;
  padding: 6px 14px;
  border-radius: var(--radius-pill, 100px);
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  margin-bottom: 24px;
}
.hp-hero__eyebrow::before {
  content: '';
  width: 6px; height: 6px;
  background: var(--green, #81AB4C);
  border-radius: 50%;
}

.hp-hero h1 {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(38px, 5vw, 62px);
  font-weight: 600;
  line-height: 1.1;
  letter-spacing: -1px;
  color: var(--text-dark, #1a1a1a);
  margin-bottom: 24px;
}
.hp-hero h1 em { font-style: italic; color: var(--green, #81AB4C); }

.hp-hero__lead {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 18px;
  color: var(--text-mid, #4a4a4a);
  line-height: 1.7;
  max-width: 480px;
  margin-bottom: 40px;
}

.hp-hero__ctas {
  display: flex;
  gap: 14px;
  align-items: center;
  flex-wrap: wrap;
}

/* Shared button styles scoped to homepage */
.s-btn {
  display: inline-block;
  padding: 14px 28px;
  border-radius: var(--radius-pill, 100px);
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px;
  font-weight: 500;
  text-decoration: none;
  transition: all 0.2s;
  border: 2px solid transparent;
  white-space: nowrap;
  cursor: pointer;
}
.s-btn--primary {
  background: var(--green, #81AB4C);
  color: #fff;
  border-color: var(--green, #81AB4C);
}
.s-btn--primary:hover { background: #6e9640; border-color: #6e9640; transform: translateY(-2px); color: #fff; }
.s-btn--ghost {
  background: transparent;
  color: var(--brand, #272E32);
  border-color: var(--brand, #272E32);
}
.s-btn--ghost:hover { background: var(--brand, #272E32); color: #fff; transform: translateY(-2px); }
.s-btn--white {
  background: #fff;
  color: var(--brand, #272E32);
  border-color: #fff;
  font-weight: 600;
}
.s-btn--white:hover { background: var(--off-white, #F7F6F3); transform: translateY(-2px); color: var(--brand, #272E32); }
.s-btn--green {
  background: var(--green, #81AB4C);
  color: #fff;
  border-color: var(--green, #81AB4C);
}
.s-btn--green:hover { background: #6e9640; border-color: #6e9640; transform: translateY(-2px); color: #fff; }

.hp-hero__trust {
  margin-top: 48px;
  padding-top: 32px;
  border-top: 1px solid var(--light-gray, #EFEFED);
  display: flex;
  gap: 32px;
  align-items: center;
}
.hp-trust-divider { width: 1px; height: 40px; background: var(--light-gray, #EFEFED); }
.hp-trust-stat__num {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 26px;
  font-weight: 600;
  color: var(--brand, #272E32);
  display: block;
}
.hp-trust-stat__num span { color: var(--green, #81AB4C); }
.hp-trust-stat__lbl {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px;
  color: var(--text-light, #888);
}

.hp-hero__visual { position: relative; height: 560px; }
.hp-hero__img-wrap {
  width: 100%; height: 460px;
  background: var(--brand, #272E32);
  border-radius: var(--radius-xl, 40px);
  overflow: hidden;
}
.hp-hero__img-wrap img { width: 100%; height: 100%; object-fit: cover; }
.hp-hero__badge {
  position: absolute; bottom: -20px; left: -20px;
  background: #fff;
  padding: 16px 20px;
  border-radius: var(--radius-lg, 24px);
  box-shadow: 0 8px 32px rgba(0,0,0,0.12);
  display: flex; align-items: center; gap: 12px;
  min-width: 200px;
}
.hp-hero__badge-icon {
  width: 44px; height: 44px;
  border-radius: 12px;
  background: var(--green-light, #eef4e4);
  display: flex; align-items: center; justify-content: center;
  font-size: 20px;
}
.hp-hero__badge-title {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; font-weight: 600; color: var(--text-dark, #1a1a1a);
}
.hp-hero__badge-sub {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 12px; color: var(--text-light, #888);
}
.hp-hero__accent {
  position: absolute; top: 20px; right: -24px;
  width: 120px; height: 120px;
  background: var(--green-light, #eef4e4);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 13px; font-weight: 600; color: #5a7a33;
  text-align: center; line-height: 1.3; padding: 16px;
}

/* ── LOCATION STRIP ── */
.hp-strip { background: var(--off-white, #F7F6F3); padding: 28px 5%; overflow: hidden; }
.hp-strip__label {
  text-align: center;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 12px; font-weight: 600; letter-spacing: 1px;
  text-transform: uppercase; color: var(--text-light, #888);
  margin-bottom: 20px;
}
.hp-strip__overflow { overflow: hidden; }
.hp-strip__scroll {
  display: flex; gap: 48px; align-items: center;
  animation: s-scroll 28s linear infinite;
  animation-delay: 0.5s;
  width: max-content;
}
@keyframes s-scroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
.hp-strip__item {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 16px; font-weight: 600;
  color: var(--text-light, #888); white-space: nowrap;
}
.hp-strip__sep {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  color: var(--light-gray, #EFEFED); font-size: 20px;
}

/* ── SHARED SECTION HEADER ── */
.hp-section-hd { text-align: center; margin-bottom: 52px; }
.hp-section-sub {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 17px; color: var(--text-mid, #4a4a4a);
  line-height: 1.7; max-width: 540px; margin: 0 auto;
}
.hp-section-hd .section-title { margin: 0 auto 16px; }

/* ── SERVICES ── */
.hp-services { background: #fff; padding: 100px 5%; }
.hp-services__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.hp-svc-card {
  background: var(--off-white, #F7F6F3);
  border-radius: var(--radius-lg, 24px);
  padding: 36px 28px;
  transition: transform 0.25s, box-shadow 0.25s;
  position: relative; overflow: hidden;
}
.hp-svc-card::after {
  content: ''; position: absolute; bottom: 0; left: 0; right: 0;
  height: 3px; background: var(--green, #81AB4C);
  transform: scaleX(0); transform-origin: left; transition: transform 0.3s;
}
.hp-svc-card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(0,0,0,0.1); }
.hp-svc-card:hover::after { transform: scaleX(1); }
.hp-svc-card__icon {
  width: 52px; height: 52px;
  border-radius: var(--radius-md, 16px);
  background: var(--brand, #272E32); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 22px; margin-bottom: 24px;
}
.hp-svc-card h3 {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 20px; font-weight: 600;
  color: var(--text-dark, #1a1a1a); margin-bottom: 12px;
}
.hp-svc-card p {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; color: var(--text-mid, #4a4a4a);
  line-height: 1.65; margin: 0;
}
.hp-svc-card__link {
  display: inline-flex; align-items: center; gap: 6px;
  margin-top: 20px;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 14px; font-weight: 600;
  color: var(--green, #81AB4C); text-decoration: none;
  transition: gap 0.2s;
}
.hp-svc-card__link:hover { gap: 10px; }

/* ── STATS BAND ── */
.hp-stats { background: var(--brand, #272E32); padding: 80px 5%; }
.hp-stats__grid { display: grid; grid-template-columns: repeat(4, 1fr); }
.hp-stat {
  text-align: center; padding: 20px;
  border-right: 1px solid rgba(255,255,255,0.12);
}
.hp-stat:last-child { border-right: none; }
.hp-stat__num {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 52px; font-weight: 600; color: #fff;
  display: block; line-height: 1;
}
.hp-stat__sfx { color: var(--green, #81AB4C); }
.hp-stat__lbl {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 14px; color: rgba(255,255,255,0.55);
  margin-top: 8px; display: block;
}

/* ── WHY US ── */
.hp-why { background: var(--off-white, #F7F6F3); padding: 100px 5%; }
.hp-why__row {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 80px; align-items: center; margin-bottom: 80px;
}
.hp-why__row:last-of-type { margin-bottom: 0; }
.hp-why__row--rev .hp-why__img  { order: 2; }
.hp-why__row--rev .hp-why__content { order: 1; }
.hp-why__img {
  height: 420px; border-radius: var(--radius-xl, 40px);
  overflow: hidden; background: var(--light-gray, #EFEFED); position: relative;
}
.hp-why__img img { width: 100%; height: 100%; object-fit: cover; }
.hp-why__pill {
  position: absolute; top: 24px; right: 24px;
  background: #fff; padding: 10px 18px;
  border-radius: var(--radius-pill, 100px);
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px; font-weight: 600; color: var(--brand, #272E32);
  box-shadow: 0 4px 16px rgba(0,0,0,0.1);
}
.hp-why__num {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 64px; font-weight: 600;
  color: var(--light-gray, #EFEFED); line-height: 1; margin-bottom: 4px;
}
.hp-why__content h3 {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 30px; font-weight: 600;
  color: var(--text-dark, #1a1a1a); line-height: 1.2; margin-bottom: 16px;
}
.hp-why__content p {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 16px; color: var(--text-mid, #4a4a4a);
  line-height: 1.75; margin-bottom: 24px;
}
.hp-why__pts { list-style: none; padding: 0; }
.hp-why__pts li {
  display: flex; align-items: flex-start; gap: 10px;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; color: var(--text-mid, #4a4a4a); padding: 6px 0;
}
.hp-why__pts li::before {
  content: '✓'; color: var(--green, #81AB4C);
  font-weight: 700; font-size: 14px; margin-top: 2px; flex-shrink: 0;
}

/* ── HOW IT WORKS ── */
.hp-how { background: var(--off-white, #F7F6F3); padding: 100px 5%; }
.hp-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
.hp-step {
  background: #fff; border-radius: var(--radius-lg, 24px);
  padding: 32px 24px; position: relative; transition: transform 0.2s;
}
.hp-step:hover { transform: translateY(-4px); }
.hp-step__num {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px; font-weight: 600; color: var(--green, #81AB4C);
  margin-bottom: 20px; letter-spacing: 0.5px;
}
.hp-step__icon {
  width: 48px; height: 48px;
  border-radius: var(--radius-md, 16px);
  background: var(--green-light, #eef4e4);
  display: flex; align-items: center; justify-content: center;
  font-size: 20px; margin-bottom: 20px;
}
.hp-step h4 {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 18px; font-weight: 600;
  color: var(--text-dark, #1a1a1a); margin-bottom: 10px;
}
.hp-step p {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 14px; color: var(--text-mid, #4a4a4a);
  line-height: 1.65; margin: 0;
}
.hp-step__connector {
  position: absolute; top: 44px; right: -12px;
  width: 24px; height: 2px;
  background: var(--light-gray, #EFEFED); z-index: 1;
}
.hp-step:last-child .hp-step__connector { display: none; }

/* ── TESTIMONIALS ── */
.hp-testi { background: #fff; padding: 100px 5%; }
.hp-testi__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.hp-testi__card {
  background: var(--off-white, #F7F6F3);
  border-radius: var(--radius-lg, 24px); padding: 32px 28px;
}
.hp-testi__stars { color: var(--green, #81AB4C); font-size: 16px; margin-bottom: 16px; letter-spacing: 2px; }
.hp-testi__quote {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; color: var(--text-mid, #4a4a4a);
  line-height: 1.75; margin-bottom: 24px; font-style: italic;
}
.hp-testi__author { display: flex; align-items: center; gap: 12px; }
.hp-testi__avatar {
  width: 44px; height: 44px; border-radius: 50%;
  background: var(--brand, #272E32); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 14px; font-weight: 600; flex-shrink: 0;
}
.hp-testi__name {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 14px; font-weight: 600; color: var(--text-dark, #1a1a1a);
}
.hp-testi__loc {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px; color: var(--text-light, #888);
}

/* ── CTA BANNER ── */
.hp-cta {
  background: var(--brand, #272E32);
  border-radius: var(--radius-xl, 40px);
  padding: 72px 60px;
  display: flex; align-items: center; justify-content: space-between;
  gap: 40px; margin: 0 5% 100px;
}
.hp-cta h2 {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 36px; font-weight: 600; color: #fff;
  line-height: 1.2; max-width: 480px; margin: 0;
}
.hp-cta h2 em { font-style: italic; color: var(--green, #81AB4C); }
.hp-cta__btns { display: flex; gap: 14px; flex-shrink: 0; }

/* ── RESPONSIVE ── */
@media (max-width: 860px) {
  .hp-hero { grid-template-columns: 1fr; min-height: auto; padding: 60px 5% 40px; }
  .hp-hero__visual { display: none; }
  .hp-hero h1 { font-size: clamp(32px, 6vw, 48px); }
  .hp-services__grid { grid-template-columns: 1fr; }
  .hp-stats__grid { grid-template-columns: repeat(2, 1fr); }
  .hp-why__row,
  .hp-why__row--rev { grid-template-columns: 1fr; gap: 32px; }
  .hp-why__row--rev .hp-why__img    { order: 0; }
  .hp-why__row--rev .hp-why__content { order: 1; }
  .hp-why__img { height: 280px; }
  .hp-steps { grid-template-columns: repeat(2, 1fr); }
  .hp-step__connector { display: none; }
  .hp-testi__grid { grid-template-columns: 1fr; }
  .hp-cta { flex-direction: column; padding: 48px 32px; text-align: center; }
  .hp-cta h2 { font-size: 28px; max-width: 100%; }
}
@media (max-width: 560px) {
  .hp-steps { grid-template-columns: 1fr; }
  .hp-stats__grid { grid-template-columns: repeat(2, 1fr); }
  .hp-cta__btns { flex-direction: column; width: 100%; }
}
</style>

<script>
  // Run IntersectionObserver when the browser is idle — keeps it off
  // the critical path during initial paint.
  const registerFadeIns = () => {
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.12 });
    document.querySelectorAll('.fade-in').forEach(el => obs.observe(el));
  };

  if ('requestIdleCallback' in window) {
    requestIdleCallback(registerFadeIns);
  } else {
    // Fallback for Safari < 16
    setTimeout(registerFadeIns, 200);
  }
</script>
