<script>
document.addEventListener('DOMContentLoaded', () => {
  const section = document.querySelector('.hp-apps');
  if (!section) return;

  const slides = section.querySelectorAll('.hp-apps__slide');
  const imgs = section.querySelectorAll('.hp-apps__img');
  const progs = section.querySelectorAll('.hp-apps__prog');
  let current = 0;
  let ticking = false;

  function goTo(index) {
    if (index === current) return;
    const prev = current;
    current = index;

    // Text slides
    slides.forEach((s, i) => {
      s.classList.toggle('hp-apps__slide--active', i === current);
    });

    // Images: outgoing slides up, incoming slides in
    imgs.forEach((img, i) => {
      img.classList.remove('hp-apps__img--active', 'hp-apps__img--exit');
      if (i === current) {
        img.classList.add('hp-apps__img--active');
      } else if (i === prev && i > current) {
        img.classList.add('hp-apps__img--exit');
      }
    });

    // Progress dots
    progs.forEach((p, i) => {
      p.classList.toggle('hp-apps__prog--active', i === current);
    });
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        const rect = section.getBoundingClientRect();
        const total = section.offsetHeight - window.innerHeight;
        const scrolled = -rect.top;
        const pct = Math.max(0, Math.min(1, scrolled / total));
        const idx = Math.floor(pct * 3);
        goTo(Math.min(2, idx));
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });
});
</script>

