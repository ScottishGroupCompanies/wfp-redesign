---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Window Film Philadelphia | Leading Window Film Solutions';
const description = 'Window Film Philadelphia is honored to provide leading window film solutions for Philadelphia properties. Schedule your free consultation!';
---

<BaseLayout title={title} description={description} canonical="https://www.windowfilmphiladelphia.net/">

<!-- ══════════════════════════════════════════════════════
     HERO — 2-column: copy left, image right
     ══════════════════════════════════════════════════════ -->
<section class="hero">
  <div class="hero-content">
    <div class="hero-eyebrow">Serving Philadelphia Since 2008</div>
    <h1>Window Film Solutions <em>Done Right,</em> Every Time</h1>
    <p>Professional window film installation for homes, businesses, and commercial properties throughout Philadelphia and the surrounding metro area. Trusted by thousands of Pennsylvania and New Jersey clients.</p>
    <div class="hero-ctas">
      <a href="/contact/" class="btn-primary">Get a Free Quote</a>
      <a href="/process/" class="btn-ghost">Our Process</a>
    </div>
    <div class="hero-trust">
      <div class="trust-stat">
        <span class="num">15<span>+</span></span>
        <span class="lbl">Years of experience</span>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-stat">
        <span class="num">5k<span>+</span></span>
        <span class="lbl">Projects completed</span>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-stat">
        <span class="num">4.9<span>★</span></span>
        <span class="lbl">Average rating</span>
      </div>
    </div>
  </div>
  <div class="hero-visual">
    <div class="hero-img-main">
      <img
        src="/images/window-film-contractor-philadelphia.jpg"
        alt="Window film contractor Philadelphia"
        width="600"
        height="460"
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <div class="hero-badge">
      <div class="badge-icon">🏅</div>
      <div class="badge-text">
        <div class="b-title">#1 in Philadelphia</div>
        <div class="b-sub">Window Film Installer</div>
      </div>
    </div>
    <div class="hero-img-accent">Lifetime Warranty Included</div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════
     LOCATION SCROLL STRIP
     ══════════════════════════════════════════════════════ -->
<div class="logo-strip">
  <p class="logo-strip-label">Proudly serving the greater Philadelphia area</p>
  <div class="logo-strip-overflow">
    <div class="logo-scroll">
      <span class="logo-item">Philadelphia</span><span class="logo-sep">·</span>
      <span class="logo-item">Camden, NJ</span><span class="logo-sep">·</span>
      <span class="logo-item">Reading</span><span class="logo-sep">·</span>
      <span class="logo-item">Upper Darby</span><span class="logo-sep">·</span>
      <span class="logo-item">Cherry Hill</span><span class="logo-sep">·</span>
      <span class="logo-item">Wilmington</span><span class="logo-sep">·</span>
      <span class="logo-item">Allentown</span><span class="logo-sep">·</span>
      <span class="logo-item">Bucks County</span><span class="logo-sep">·</span>
      <!-- Duplicate for seamless loop -->
      <span class="logo-item">Philadelphia</span><span class="logo-sep">·</span>
      <span class="logo-item">Camden, NJ</span><span class="logo-sep">·</span>
      <span class="logo-item">Reading</span><span class="logo-sep">·</span>
      <span class="logo-item">Upper Darby</span><span class="logo-sep">·</span>
      <span class="logo-item">Cherry Hill</span><span class="logo-sep">·</span>
      <span class="logo-item">Wilmington</span><span class="logo-sep">·</span>
      <span class="logo-item">Allentown</span><span class="logo-sep">·</span>
      <span class="logo-item">Bucks County</span>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════
     SERVICES GRID
     ══════════════════════════════════════════════════════ -->
<section class="services">
  <div class="section-header">
    <p class="section-eyebrow">What We Do</p>
    <h2 class="section-title">Expert film solutions for <em>every surface</em></h2>
    <p class="section-sub">From homes to high-rises, storefronts to secured facilities — we handle every project with precision and care.</p>
  </div>
  <div class="services-grid">
    <div class="service-card fade-in">
      <div class="service-icon">🏠</div>
      <h3>Residential Film</h3>
      <p>Reduce heat, glare, and UV damage while adding privacy and style to your home. Energy savings from day one.</p>
      <a href="/benefits/" class="service-link">Learn more →</a>
    </div>
    <div class="service-card fade-in fade-in-delay-1">
      <div class="service-icon">🏢</div>
      <h3>Commercial Film</h3>
      <p>Protect your assets, reduce HVAC load, and create a professional appearance for offices and retail spaces.</p>
      <a href="/applications/" class="service-link">Learn more →</a>
    </div>
    <div class="service-card fade-in fade-in-delay-2">
      <div class="service-icon">🛡️</div>
      <h3>Security Film</h3>
      <p>Ballistic-resistant and blast-mitigation films that hold glass together on impact — protecting people and property.</p>
      <a href="/benefits/safety-and-security/" class="service-link">Learn more →</a>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════
     STATS BAND
     ══════════════════════════════════════════════════════ -->
<div class="stats">
  <div class="stats-grid">
    <div class="stat-item fade-in">
      <span class="stat-num">15<span class="stat-suffix">+</span></span>
      <span class="stat-label">Years in business</span>
    </div>
    <div class="stat-item fade-in fade-in-delay-1">
      <span class="stat-num">5k<span class="stat-suffix">+</span></span>
      <span class="stat-label">Projects completed</span>
    </div>
    <div class="stat-item fade-in fade-in-delay-2">
      <span class="stat-num">50<span class="stat-suffix">+</span></span>
      <span class="stat-label">Cities served</span>
    </div>
    <div class="stat-item fade-in fade-in-delay-3">
      <span class="stat-num">4.9<span class="stat-suffix">★</span></span>
      <span class="stat-label">Average Google rating</span>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════
     WHY US — alternating rows
     ══════════════════════════════════════════════════════ -->
<section class="why">
  <div class="section-header">
    <p class="section-eyebrow">Why Window Film Philadelphia</p>
    <h2 class="section-title">The difference you'll notice from day one</h2>
  </div>

  <div class="why-row fade-in">
    <div class="why-img">
      <img src="/images/window-film-contractor-philadelphia-1.jpg" alt="Premium window film installation Philadelphia" width="500" height="420" loading="lazy" />
      <span class="why-img-pill">Lifetime Warranty</span>
    </div>
    <div class="why-content">
      <div class="step-num">01</div>
      <h3>Premium films from the world's top manufacturers</h3>
      <p>We only install films from 3M, LLumar, Vista, Solar Gard, Madico, and more — brands with proven track records and manufacturer-backed warranties that last the lifetime of your film.</p>
      <ul class="why-points">
        <li>Blocks up to 99% of UV radiation</li>
        <li>Rejects up to 80% of solar heat</li>
        <li>Scratch-resistant hard coat on all films</li>
      </ul>
    </div>
  </div>

  <div class="why-row reverse fade-in">
    <div class="why-img">
      <img src="/images/window-film-contractor-philadelphia-2.jpg" alt="Expert window film installers Philadelphia" width="500" height="420" loading="lazy" />
      <span class="why-img-pill">Expert Installers</span>
    </div>
    <div class="why-content">
      <div class="step-num">02</div>
      <h3>Installers who treat your property like their own</h3>
      <p>Every member of our installation team is factory-trained and certified. We show up on time, work clean, and leave no trace except a flawless result — guaranteed every time.</p>
      <ul class="why-points">
        <li>Factory-certified installation team</li>
        <li>Residential & commercial specialists</li>
        <li>Free on-site consultations available</li>
      </ul>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════
     HOW IT WORKS — 4-step grid
     ══════════════════════════════════════════════════════ -->
<section class="how">
  <div class="section-header">
    <p class="section-eyebrow">The Process</p>
    <h2 class="section-title">From quote to done in <em>four simple steps</em></h2>
  </div>
  <div class="steps">
    <div class="step fade-in">
      <div class="step-number">Step 01</div>
      <div class="step-icon">💬</div>
      <h4>Free consultation</h4>
      <p>Tell us about your project online or by phone. We'll recommend the right film and provide an estimate.</p>
      <div class="step-connector"></div>
    </div>
    <div class="step fade-in fade-in-delay-1">
      <div class="step-number">Step 02</div>
      <div class="step-icon">📋</div>
      <h4>Custom proposal</h4>
      <p>Receive a detailed written quote with film options, pricing, and an expected energy savings projection.</p>
      <div class="step-connector"></div>
    </div>
    <div class="step fade-in fade-in-delay-2">
      <div class="step-number">Step 03</div>
      <div class="step-icon">🛠️</div>
      <h4>Professional install</h4>
      <p>Our certified crew arrives on schedule, installs cleanly, and ensures every panel is perfect before leaving.</p>
      <div class="step-connector"></div>
    </div>
    <div class="step fade-in fade-in-delay-3">
      <div class="step-number">Step 04</div>
      <div class="step-icon">✅</div>
      <h4>Lifetime support</h4>
      <p>Every job comes with a lifetime warranty. If anything goes wrong, we make it right — no questions asked.</p>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════
     TESTIMONIALS — 3-column cards
     ══════════════════════════════════════════════════════ -->
<section class="testimonials">
  <div class="section-header">
    <p class="section-eyebrow">Client Reviews</p>
    <h2 class="section-title">What Philadelphia customers are saying</h2>
  </div>
  <div class="testi-grid">
    <div class="testi-card fade-in">
      <div class="testi-stars">★★★★★</div>
      <p class="testi-quote">"The team was professional, fast, and the finished result looks incredible. Our living room is so much cooler now — already seeing the difference on our energy bill."</p>
      <div class="testi-author">
        <div class="testi-avatar">JR</div>
        <div>
          <div class="testi-name">Jennifer R.</div>
          <div class="testi-location">Residential · Philadelphia, PA</div>
        </div>
      </div>
    </div>
    <div class="testi-card fade-in fade-in-delay-1">
      <div class="testi-stars">★★★★★</div>
      <p class="testi-quote">"Had our entire 3rd-floor office done. The crew was on time, respectful of our workspace, and the film looks great. We'll use Window Film Philadelphia for every project going forward."</p>
      <div class="testi-author">
        <div class="testi-avatar">MT</div>
        <div>
          <div class="testi-name">Marcus T.</div>
          <div class="testi-location">Commercial · Center City, PA</div>
        </div>
      </div>
    </div>
    <div class="testi-card fade-in fade-in-delay-2">
      <div class="testi-stars">★★★★★</div>
      <p class="testi-quote">"The security film they installed on our storefront gives us serious peace of mind. Professional team, clean work, and completed exactly on schedule."</p>
      <div class="testi-author">
        <div class="testi-avatar">BK</div>
        <div>
          <div class="testi-name">Brian K.</div>
          <div class="testi-location">Commercial · South Philly, PA</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════
     CTA BANNER — dark rounded block
     ══════════════════════════════════════════════════════ -->
<div class="cta-banner fade-in">
  <h2>Ready to transform your <em>home or business?</em></h2>
  <div class="cta-banner-btns">
    <a href="/contact/" class="btn-white">Get a Free Quote</a>
    <a href="tel:+12673947980" class="btn-green">Call (267) 394-7980</a>
  </div>
</div>

</BaseLayout>

<style>
  /* ─── FONTS ─── */
  * { box-sizing: border-box; }

  /* ─── HERO ─── */
  .hero {
    min-height: 92vh;
    padding: 80px 5% 60px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    background: var(--white, #fff);
  }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--green-light, #eef4e4);
    color: #5a7a33;
    padding: 6px 14px;
    border-radius: var(--radius-pill, 100px);
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: 24px;
  }
  .hero-eyebrow::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--green, #81AB4C);
    border-radius: 50%;
  }
  .hero h1 {
    font-family: var(--font-serif, 'Playfair Display', serif);
    font-size: clamp(38px, 5vw, 62px);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -1px;
    color: var(--text-dark, #1a1a1a);
    margin-bottom: 24px;
  }
  .hero h1 em {
    font-style: italic;
    color: var(--green, #81AB4C);
  }
  .hero p {
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: 18px;
    color: var(--text-mid, #4a4a4a);
    line-height: 1.7;
    max-width: 480px;
    margin-bottom: 40px;
  }
  .hero-ctas {
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--green, #81AB4C);
    color: #fff;
    padding: 14px 28px;
    border-radius: var(--radius-pill, 100px);
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s;
    display: inline-block;
    border: 2px solid var(--green, #81AB4C);
  }
  .btn-primary:hover {
    background: #6e9640;
    border-color: #6e9640;
    transform: translateY(-2px);
    color: #fff;
  }
  .btn-ghost {
    background: transparent;
    color: var(--brand, #272E32);
    padding: 14px 28px;
    border-radius: var(--radius-pill, 100px);
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    border: 2px solid var(--brand, #272E32);
    transition: all 0.2s;
    display: inline-block;
  }
  .btn-ghost:hover {
    background: var(--brand, #272E32);
    color: #fff;
    transform: translateY(-2px);
  }
  .hero-trust {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--light-gray, #EFEFED);
    display: flex;
    gap: 32px;
    align-items: center;
  }
  .trust-divider {
    width: 1px;
    height: 40px;
    background: var(--light-gray, #EFEFED);
  }
  .trust-stat .num {
    font-family: var(--font-serif, 'Playfair Display', serif);
    font-size: 26px;
    font-weight: 600;
    color: var(--brand, #272E32);
    display: block;
  }
  .trust-stat .num span { color: var(--green, #81AB4C); }
  .trust-stat .lbl {
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: 13px;
    color: var(--text-light, #888);
  }
  .hero-visual {
    position: relative;
    height: 560px;
  }
  .hero-img-main {
    width: 100%;
    height: 460px;
    background: var(--brand, #272E32);
    border-radius: var(--radius-xl, 40px);
    overflow: hidden;
  }
  .hero-img-main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-badge {
    position: absolute;
    bottom: -20px;
    left: -20px;
    background: #fff;
    padding: 16px 20px;
    border-radius: var(--radius-lg, 24px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 200px;
  }
  .badge-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: var(--green-light, #eef4e4);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
  }
  .badge-text .b-title {
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: 15px;
    font-weight: 600;
    color: var(--text-dark, #1a1a1a);
  }
  .badge-text .b-sub {
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: 12px;
    color: var(--text-light, #888);
  }
  .hero-img-accent {
    position: absolute;
    top: 20px;
    right: -24px;
    width: 120px;
    height: 120px;
    background: var(--green-light, #eef4e4);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif, 'Playfair Display', serif);
    font-size: 13px;
    font-weight: 600;
    color: #5a7a33;
    text-align: center;
    line-height: 1.3;
    padding: 16px;
  }

  /* ─── LOGO STRIP ─── */
  .logo-strip {
    background: var(--off-white, #F7F6F3);
    padding: 28px 5%;
    overflow: hidden;
  }
  .logo-strip-label {
    text-align: center;
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--text-light, #888);
    margin-bottom: 20px;
  }
  .logo-strip-overflow { overflow: hidden; }
  .logo-scroll {
    display: flex;
    gap: 48px;
    align-items: center;
    animation: scroll-logos 28s linear infinite;
    width: max-content;
  }
  @keyframes scroll-logos {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .logo-item {
    font-family: var(--font-serif, 'Playfair Display', serif);
    font-size: 16px;
    font-weight: 600;
    color: var(--text-light, #888);
    white-space: nowrap;
    letter-spacing: 0.5px;
  }
  .logo-sep {
    font-family: var(--font-body, 'DM Sans', sans-serif);
    color: var(--light-gray, #EFEFED);
    font-size: 20px;
  }

  /* ─── SHARED SECTION STYLES ─── */
  section { padding: 100px 5%; }

  .section-header {
    text-align: center;
    margin-bottom: 52px;
  }
  .section-eyebrow {
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--green, #81AB4C);
    margin-bottom: 12px;
  }
  .section-title {
    font-family: var(--font-serif, 'Playfair Display', serif);
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.5px;
    color: var(--text-dark, #1a1a1a);
    margin: 0 auto 16px;
    max-width: 600px;
  }
  .section-title em {
    font-style: italic;
    color: var(--green, #81AB4C);
  }
  .section-sub {
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: 17px;
    color: var(--text-mid, #4a4a4a);
    line-height: 1.7;
    max-width: 540px;
    margin: 0 auto;
  }

  /* ─── SERVICES ─── */
  .services { background: #fff; }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .service-card {
    background: var(--off-white, #F7F6F3);
    border-radius: var(--radius-lg, 24px);
    padding: 36px 28px;
    transition: transform 0.25s, box-shadow 0.25s;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    text-decoration: none;
  }
  .service-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: var(--green, #81AB4C);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s;
  }
  .service-card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(0, 0, 0, 0.1); }
  .service-card:hover::after { transform: scaleX(1); }
  .service-icon {
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md, 16px);
    background: var(--brand, #272E32);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    margin-bottom: 24px;
  }
  .service-card h3 {
    font-family: var(--font-serif, 'Playfair Display', serif);
    font-size: 20px;
    font-weight: 600;
    color: var(--text-dark, #1a1a1a);
    margin-bottom: 12px;
  }
  .service-card p {
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: 15px;
    color: var(--text-mid, #4a4a4a);
    line-height: 1.65;
    margin: 0;
  }
  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 20px;
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: 14px;
    font-weight: 600;
    color: var(--green, #81AB4C);
    text-decoration: none;
    transition: gap 0.2s;
  }
  .service-link:hover { gap: 10px; }

  /* ─── STATS ─── */
  .stats {
    background: var(--brand, #272E32);
    padding: 80px 5%;
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }
  .stat-item {
    text-align: center;
    padding: 20px;
    border-right: 1px solid rgba(255, 255, 255, 0.12);
  }
  .stat-item:last-child { border-right: none; }
  .stat-num {
    font-family: var(--font-serif, 'Playfair Display', serif);
    font-size: 52px;
    font-weight: 600;
    color: #fff;
    display: block;
    line-height: 1;
  }
  .stat-suffix { color: var(--green, #81AB4C); }
