---
/* Hallmark · redesign · macrostructure: numbered-alternating-rows · tone: professional-editorial
 * template: benefits.astro · anchor hue: green (#81AB4C) */
import BaseLayout from '../../layouts/BaseLayout.astro';
import InnerPageHero from '../../components/InnerPageHero.astro';
import BrandLogos from '../../components/BrandLogos.astro';
import { Icon } from 'astro-icon/components';

const title = 'Energy Saving Window Film Philadelphia | Solar Films';
const description = 'Looking to cut energy costs? Window Film Philadelphia offers high-quality energy-saving window films in Philadelphia. Get a Quote Now!';

const faqItems = [
  { question: 'How much can energy saving film reduce my energy costs?', answer: 'Most property owners see a 20–30% reduction in cooling costs during summer months and 10–15% savings on heating in winter. Commercial buildings with large glass facades tend to see the highest impact.' },
  { question: 'Does window film work for both summer cooling and winter heating savings?', answer: 'Yes. Solar control films reject heat in summer, while Low-E films add an insulating layer that retains interior heat during winter. Many of our films are spectrally selective — rejecting infrared heat while allowing visible light through — delivering performance in both seasons.' },
  { question: 'What is the difference between Low-E film and solar control film?', answer: 'Solar control film primarily rejects solar heat in summer, reducing the cooling load on your HVAC system. Low-E film adds a reflective metallic layer that retains interior warmth in winter as well — making it ideal for year-round energy savings in climates like Philadelphia.' },
  { question: 'Will energy saving film change the appearance or natural light in my space?', answer: 'Modern energy saving films are engineered to be nearly invisible while still performing at a high level. Many spectrally selective films allow 50–70% of visible light through while rejecting up to 80% of solar heat.' },
  { question: 'How long does it take for energy saving window film to pay for itself?', answer: 'For most commercial properties, energy saving film has a payback period of 3–5 years through HVAC energy savings alone. Residential payback varies by home size and glazing area, typically within 5–7 years. After payback, the film continues delivering savings for 10–20+ years.' },
  { question: 'Does energy saving window film qualify for tax credits or utility rebates?', answer: 'Certain energy saving window films may qualify for utility company rebates and can contribute to LEED certification credits for commercial buildings. Our team can provide documentation and performance data to support any rebate or credit application.' },
];

const featuredSections = [
  {
    number: '01',
    heading: 'Energy Saving Window Film for Philadelphia Properties',
    body: 'Energy costs are a concern for any residential or commercial property owner. Window film offers a powerful way to address rising utility bills without the high cost and disruption of full window replacement. Window Film Philadelphia provides comprehensive energy-saving window film options from 3M, LLumar, Vista, Solar Gard, and other industry-leading brands — whether you need Low-E film for a Center City office or heat-blocking film for a Chestnut Hill home.',
    img: '/images/energy-saving-window-film-philadelphia.webp',
    alt: 'Energy saving window film Philadelphia',
    href: '/contact/',
    cta: 'Get a Free Quote',
  },
  {
    number: '02',
    heading: 'How Energy Saving Window Film Works',
    body: "In Philadelphia, where summer temperatures peak at 86°F and winters drive high heating demand, energy-saving window film is a crucial addition to any building. Film significantly rejects solar heat and insulates glass windows and doors — reducing the need for costly air conditioning in summer and heating in winter. By mitigating heat gain and blocking UV rays, it maintains consistent indoor temperatures and addresses uncomfortable hot and cold spots. It effectively turns single-pane windows into double-pane equivalents without renovation, and can assist in achieving LEED certification.",
    img: '/images/energy-saving-window-film-philly.webp',
    alt: 'How energy saving window film works Philadelphia',
    href: '/resources/window-film-fact-sheet/',
    cta: 'View Film Fact Sheet',
  },
  {
    number: '03',
    heading: 'Save Money & Improve Comfort Year-Round',
    body: 'Energy saving window film delivers measurable, immediate results from the day it\'s installed. Property owners see an average of 30% reduction in cooling costs during summer months and 10–15% savings on heating costs in winter. The film eliminates uncomfortable hot and cold spots, improves the productivity of building occupants, and extends the life of furnishings and flooring by blocking UV radiation — all with no operational downtime during installation.',
    img: '/images/energy-conserving-window-film-philadelphia.webp',
    alt: 'Energy conserving window film savings Philadelphia',
    href: '/contact/',
    cta: 'Schedule a Consultation',
  },
];

const benefitItems = [
  { icon: 'lucide:thermometer',   title: 'Solar Heat Rejection',    sub: 'Cuts solar heat gain by up to 80%' },
  { icon: 'lucide:sun',           title: 'UV Blocking',             sub: 'Blocks 99.9% of harmful UV rays' },
  { icon: 'lucide:trending-down', title: 'Lower Energy Bills',      sub: 'Reduce cooling costs up to 30%' },
  { icon: 'lucide:wind',          title: 'Year-Round Performance',  sub: 'Effective in summer heat and winter cold' },
  { icon: 'lucide:leaf',          title: 'LEED Eligible',           sub: 'Qualifies for green building credits' },
  { icon: 'lucide:layers',        title: 'No Replacement Needed',   sub: 'Applied to your existing glass' },
  { icon: 'lucide:shield-check',  title: 'Lifetime Warranty',       sub: 'Manufacturer-backed on all installs' },
  { icon: 'lucide:clock',         title: 'Fast ROI',                sub: 'Typical payback period of 3–5 years' },
];
---

<BaseLayout title={title} description={description} canonical="https://www.windowfilmphiladelphia.net/benefits/energy-savings/" faqItems={faqItems} serviceName="Energy Saving Window Film" serviceDesc="Professional energy saving window film installation in Philadelphia. Reduce HVAC costs 20–30% with solar control and Low-E films for homes and commercial buildings." serviceUrl="https://www.windowfilmphiladelphia.net/benefits/energy-savings/">

<InnerPageHero
  title="Energy Saving Window Film Philadelphia"
  bgImage="/images/energy-saving-window-film-philadelphia.webp"
  desc="Cut cooling costs and reduce solar heat gain year-round."
/>

<div class="ip-page-body">

<!-- ══════════════════════════════════════
     INTRO — 2-col: big heading left, text + CTAs right
     ══════════════════════════════════════ -->
<section class="bp-intro">
  <div class="bp-intro__inner">
    <div class="bp-intro__left">
      <span class="bp-eyebrow">Energy Performance</span>
      <h2 class="bp-intro__title">Lower Bills. Greater Comfort. One Simple Upgrade.</h2>
    </div>
    <div class="bp-intro__right">
      <p class="bp-intro__lead">Energy saving window film is one of the highest-ROI upgrades available for Philadelphia residential and commercial properties. By rejecting solar heat and insulating your existing glass, film reduces your reliance on HVAC systems — delivering measurable savings from day one without replacing a single pane of glass.</p>
      <div class="bp-intro__ctas">
        <a href="/contact/" class="bp-btn bp-btn--primary">Get a Free Quote</a>
        <a href="/benefits/" class="bp-btn bp-btn--ghost">All Benefits</a>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     FEATURED SECTIONS — 3 numbered alternating rows
     ══════════════════════════════════════ -->
<section class="bp-featured">
  <div class="bp-featured__hd">
    <span class="bp-eyebrow">How It Works</span>
    <h2 class="bp-featured__title">Everything you need to know about<br/>energy saving window film</h2>
  </div>

  {featuredSections.map((s, i) => (
    <div class={`bp-feat-row fade-in${i % 2 === 1 ? ' bp-feat-row--rev' : ''}`}>
      <div class="bp-feat-row__img">
        <img src={s.img} alt={s.alt} width="600" height="480" loading="lazy" />
        <span class="bp-feat-row__pill">{s.heading}</span>
      </div>
      <div class="bp-feat-row__content">
        <span class="bp-feat-row__num">{s.number}</span>
        <h3 class="bp-feat-row__heading">{s.heading}</h3>
        <p class="bp-feat-row__body">{s.body}</p>
        <a href={s.href} class="bp-feat-row__cta">
          {s.cta}
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/></svg>
        </a>
      </div>
    </div>
  ))}
</section>

<!-- ══════════════════════════════════════
     BENEFITS GRID — 4-col dark icon grid
     ══════════════════════════════════════ -->
<section class="bp-why">
  <div class="bp-why__hd">
    <span class="bp-eyebrow">Key Benefits</span>
    <h2 class="bp-why__title">Eight reasons energy saving film is worth it</h2>
  </div>
  <div class="bp-why__grid">
    {benefitItems.map((item) => (
      <div class="bp-why__item fade-in">
        <div class="bp-why__icon"><Icon name={item.icon} width="32" height="32" /></div>
        <div class="bp-why__divider"></div>
        <h4 class="bp-why__item-title">{item.title}</h4>
        <p class="bp-why__item-sub">{item.sub}</p>
      </div>
    ))}
  </div>
</section>

<!-- ══════════════════════════════════════
     FAQ ACCORDION
     ══════════════════════════════════════ -->
<section class="bp-faq">
  <div class="bp-faq__hd">
    <span class="bp-eyebrow">FAQ</span>
    <h2 class="bp-faq__title">Common questions about energy saving window film</h2>
  </div>
  <div class="bp-faq__item bp-faq__item--open">
    <div class="bp-faq__q">How much can energy saving film reduce my energy costs? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Most property owners see a 20–30% reduction in cooling costs during summer months and 10–15% savings on heating in winter. Commercial buildings with large glass facades tend to see the highest impact. Our team can provide a customized energy savings projection during your free consultation.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">Does window film work for both summer cooling and winter heating savings? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Yes. Solar control films reject heat in summer, while Low-E (low emissivity) films add an insulating layer that retains interior heat during winter. Many of our films are spectrally selective — meaning they reject infrared heat while allowing visible light through — delivering performance in both seasons.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">What is the difference between Low-E film and solar control film? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Solar control film primarily rejects solar heat in summer, reducing the cooling load on your HVAC system. Low-E (low emissivity) film adds a reflective metallic layer that retains interior warmth in winter as well — making it ideal for year-round energy savings in climates like Philadelphia's. Our team will recommend the right type for your specific goals.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">Will energy saving film change the appearance or natural light in my space? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Modern energy saving films are engineered to be nearly invisible while still performing at a high level. Many spectrally selective films allow 50–70% of visible light through while rejecting up to 80% of solar heat. We carry a range of visible light transmission (VLT) levels so you can choose a film that meets your performance goals without sacrificing natural light or your view.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">How long does it take for energy saving window film to pay for itself? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">For most commercial properties, energy saving film has a payback period of 3–5 years through HVAC energy savings alone. Residential payback varies by home size and glazing area, but most homeowners recoup their investment within 5–7 years. After payback, the film continues delivering savings for the life of the installation — typically 10–20+ years.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">Does energy saving window film qualify for tax credits or utility rebates? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Certain energy saving window films may qualify for utility company rebates and can contribute to LEED certification credits for commercial buildings. Federal and state energy efficiency incentives change frequently — our team can provide documentation and performance data to support any rebate or credit application during your project.</div>
  </div>
</section>

<!-- ══════════════════════════════════════
     BRAND LOGOS
     ══════════════════════════════════════ -->
<BrandLogos />

<!-- ══════════════════════════════════════
     CTA BANNER
     ══════════════════════════════════════ -->
<div class="bp-cta fade-in">
  <h2>Ready to start saving on your <em>energy bills?</em></h2>
  <div class="bp-cta__btns">
    <a href="/contact/" class="bp-btn bp-btn--white">Get a Free Quote</a>
    <a href="tel:+12673947980" class="bp-btn bp-btn--green">Call (267) 394-7980</a>
  </div>
</div>

</div><!-- end ip-page-body -->
</BaseLayout>

<style>
/* ── PAGE BODY WRAPPER ── */
.ip-page-body {
  position: relative;
  background: #ffffff;
  border-top-left-radius: 40px;
  border-top-right-radius: 40px;
  border-bottom-left-radius: 40px;
  border-bottom-right-radius: 40px;
  margin-top: -40px;
  z-index: 10;
  overflow: visible;
  padding-bottom: 80px;
}

/* ── EYEBROW ── */
.bp-eyebrow {
  display: inline-block;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--green, #81AB4C);
  margin-bottom: 16px;
}

/* ── BUTTONS ── */
.bp-btn {
  display: inline-block; padding: 14px 28px;
  border-radius: var(--radius-pill, 100px);
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; font-weight: 500;
  text-decoration: none; transition: all 0.2s;
  border: 2px solid transparent; white-space: nowrap;
}
.bp-btn--primary { background: var(--green, #81AB4C); color: #fff; border-color: var(--green, #81AB4C); }
.bp-btn--primary:hover { background: #6e9640; border-color: #6e9640; transform: translateY(-2px); color: #fff; }
.bp-btn--ghost { background: transparent; color: var(--brand, #272E32); border-color: var(--brand, #272E32); }
.bp-btn--ghost:hover { background: var(--brand, #272E32); color: #fff; transform: translateY(-2px); }
.bp-btn--white { background: #fff; color: var(--brand, #272E32); border-color: #fff; font-weight: 600; }
.bp-btn--white:hover { background: var(--off-white, #F7F6F3); transform: translateY(-2px); }
.bp-btn--green { background: var(--green, #81AB4C); color: #fff; border-color: var(--green, #81AB4C); }
.bp-btn--green:hover { background: #6e9640; transform: translateY(-2px); color: #fff; }

/* ── INTRO ── */
.bp-intro {
  padding: 80px 10%;
  border-top-left-radius: 40px;
  border-top-right-radius: 40px;
  overflow: hidden;
}
.bp-intro__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}
.bp-intro__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(36px, 4.5vw, 58px);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -1px;
  color: var(--text-dark, #1a1a1a);
  margin: 0;
}
.bp-intro__lead {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 17px;
  color: var(--text-mid, #4a4a4a);
  line-height: 1.75;
  margin-bottom: 32px;
}
.bp-intro__ctas { display: flex; gap: 14px; flex-wrap: wrap; }

/* ── FEATURED SECTIONS ── */
.bp-featured {
  padding: 100px 10%;
  background: var(--off-white, #F7F6F3);
}
.bp-featured__hd { margin-bottom: 72px; }
.bp-featured__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(32px, 4vw, 52px);
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: -0.5px;
  color: var(--text-dark, #1a1a1a);
  margin: 0;
}
.bp-feat-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  margin-bottom: 100px;
}
.bp-feat-row:last-child { margin-bottom: 0; }
.bp-feat-row--rev .bp-feat-row__img { order: 2; }
.bp-feat-row--rev .bp-feat-row__content { order: 1; }
.bp-feat-row__img {
  position: relative;
  height: 480px;
  border-radius: 32px;
  overflow: hidden;
}
.bp-feat-row__img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.bp-feat-row__pill {
  position: absolute; bottom: 24px; left: 24px;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(8px);
  padding: 10px 18px;
  border-radius: 100px;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px; font-weight: 600;
  color: var(--brand, #272E32);
  box-shadow: 0 4px 16px rgba(0,0,0,0.1);
}
.bp-feat-row__num {
  display: block;
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 72px; font-weight: 700;
  color: var(--green, #81AB4C);
  line-height: 1; opacity: 0.25;
  margin-bottom: -8px;
}
.bp-feat-row__heading {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(24px, 3vw, 36px);
  font-weight: 700;
  color: var(--text-dark, #1a1a1a);
  line-height: 1.2;
  margin-bottom: 20px;
  letter-spacing: -0.3px;
}
.bp-feat-row__body {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 16px;
  color: var(--text-mid, #4a4a4a);
  line-height: 1.8;
  margin-bottom: 28px;
}
.bp-feat-row__cta {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; font-weight: 600;
  color: var(--green, #81AB4C);
  text-decoration: none;
  transition: gap 0.2s;
}
.bp-feat-row__cta:hover { gap: 14px; }

/* ── BENEFITS GRID (dark) ── */
.bp-why {
  background: var(--brand, #272E32);
  padding: 100px 10%;
}
.bp-why__hd { margin-bottom: 64px; }
.bp-why__hd .bp-eyebrow { color: var(--green, #81AB4C); }
.bp-why__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(28px, 3.5vw, 48px);
  font-weight: 700;
  color: #ffffff;
  line-height: 1.15;
  letter-spacing: -0.5px;
  margin: 0;
  max-width: 600px;
}
.bp-why__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
}
.bp-why__item {
  padding: 32px 28px;
  border-right: 1px solid rgba(255,255,255,0.1);
  border-bottom: 1px solid rgba(255,255,255,0.1);
}
.bp-why__item:nth-child(4n) { border-right: none; }
.bp-why__item:nth-child(n+5) { border-bottom: none; }
.bp-why__icon {
  color: var(--green, #81AB4C);
  margin-bottom: 16px;
  display: flex; align-items: center; line-height: 1;
}
.bp-why__icon svg { display: block; }
.bp-why__divider {
  width: 32px; height: 2px;
  background: var(--green, #81AB4C);
  margin-bottom: 16px;
}
.bp-why__item-title {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; font-weight: 700;
  color: #ffffff;
  margin-bottom: 6px;
}
.bp-why__item-sub {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px;
  color: rgba(255,255,255,0.5);
  margin: 0; line-height: 1.5;
}

/* ── FAQ ── */
.bp-faq { padding: 100px 10%; background: #ffffff; }
.bp-faq__hd { margin-bottom: 48px; }
.bp-faq__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(28px, 3.5vw, 48px);
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: -0.5px;
  color: var(--text-dark, #1a1a1a);
  max-width: 560px; margin: 0;
}
.bp-faq__item {
  border-bottom: 1px solid var(--light-gray, #EFEFED);
  padding: 24px 0;
  cursor: pointer;
  max-width: 900px;
}
.bp-faq__item:first-of-type { border-top: 1px solid var(--light-gray, #EFEFED); }
.bp-faq__q {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 17px; font-weight: 600;
  color: var(--text-dark, #1a1a1a);
  display: flex; justify-content: space-between; align-items: center; gap: 12px;
}
.bp-faq__toggle { color: var(--green, #81AB4C); font-size: 22px; flex-shrink: 0; transition: transform 0.2s; }
.bp-faq__a {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; color: var(--text-mid, #4a4a4a); line-height: 1.75;
  margin-top: 14px; display: none;
}
.bp-faq__item--open .bp-faq__a { display: block; }
.bp-faq__item--open .bp-faq__toggle { transform: rotate(45deg); }

/* ── CTA BANNER ── */
.bp-cta {
  background: var(--brand, #272E32);
  border-radius: 40px;
  padding: 64px 60px;
  display: flex; align-items: center;
  justify-content: space-between;
  gap: 40px;
  margin: 0 5% 0;
}
.bp-cta h2 {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 32px; font-weight: 700;
  color: #fff; line-height: 1.2;
  max-width: 460px; margin: 0;
}
.bp-cta h2 em { font-style: italic; color: var(--green, #81AB4C); }
.bp-cta__btns { display: flex; gap: 14px; flex-shrink: 0; }

/* ── FADE IN ── */
.fade-in { opacity: 0; transform: translateY(24px); transition: opacity 0.65s ease, transform 0.65s ease; }
.fade-in.visible { opacity: 1; transform: translateY(0); }

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
  .bp-intro__inner { grid-template-columns: 1fr; gap: 40px; }
  .bp-feat-row { grid-template-columns: 1fr; gap: 40px; }
  .bp-feat-row--rev .bp-feat-row__img { order: 0; }
  .bp-feat-row--rev .bp-feat-row__content { order: 1; }
  .bp-why__grid { grid-template-columns: repeat(2, 1fr); }
  .bp-why__item:nth-child(4n) { border-right: 1px solid rgba(255,255,255,0.1); }
  .bp-why__item:nth-child(2n) { border-right: none; }
}
@media (max-width: 768px) {
  .bp-intro { padding: 60px 5%; }
  .bp-featured { padding: 60px 5%; }
  .bp-why { padding: 60px 5%; }
  .bp-faq { padding: 60px 5%; }
  .bp-feat-row__img { height: 300px; }
  .bp-why__grid { grid-template-columns: 1fr; }
  .bp-cta { flex-direction: column; padding: 40px 28px; text-align: center; }
  .bp-cta h2 { font-size: 26px; max-width: 100%; }
  .bp-cta__btns { flex-direction: column; width: 100%; }
}
@media (max-width: 480px) {
  .bp-intro__ctas { flex-direction: column; }
}
</style>

<script>
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-in').forEach(el => obs.observe(el));

  document.querySelectorAll('.bp-faq__item').forEach(item => {
    item.querySelector('.bp-faq__q')?.addEventListener('click', () => {
      const isOpen = item.classList.contains('bp-faq__item--open');
      document.querySelectorAll('.bp-faq__item').forEach(i => i.classList.remove('bp-faq__item--open'));
      if (!isOpen) item.classList.add('bp-faq__item--open');
    });
  });
</script>
