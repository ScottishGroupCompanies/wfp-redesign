---
/* Hallmark · redesign · macrostructure: numbered-alternating-rows · tone: professional-editorial
 * template: benefits.astro · anchor hue: green (#81AB4C) */
import BaseLayout from '../../layouts/BaseLayout.astro';
import InnerPageHero from '../../components/InnerPageHero.astro';
import BrandLogos from '../../components/BrandLogos.astro';
import { Icon } from 'astro-icon/components';

const title = 'Elevator Refinishing | Window Film Philadelphia | Leading Window Film';
const description = 'Window Film Philadelphia is honored to provide leading elevator refinishing window film solutions. Schedule your free consultation today!';

const featuredSections = [
  {
    number: '01',
    heading: 'Elevator Refinishing Film for Philadelphia Properties',
    body: 'Elevators are a significant investment for any commercial property, serving an essential role for buildings three levels and higher — and often providing one of the first impressions guests receive. Many elevators become susceptible to vandalism, graffiti, and daily wear and tear that is both unsightly and costly to repair. Window Film Philadelphia offers elevator refinishing services using proprietary surface film technology to restore and protect elevator interiors across the Philadelphia metro area.',
    img: '/images/elevator-refinishing-window-film-philadelphia.webp',
    alt: 'Elevator refinishing window film Philadelphia',
    href: '/contact/',
    cta: 'Get a Free Quote',
  },
  {
    number: '02',
    heading: 'How Elevator Refinishing Surface Film Works',
    body: 'Elevator refinishing utilizes specialty surface film to restore cosmetically damaged elevator interiors — addressing daily wear and tear, vandalism, and graffiti. The film is applied directly over existing surfaces to conceal existing damage while providing a durable protective layer against future threats. Available in multiple finishes to seamlessly match any elevator interior, the sacrificial layer is easily removed and replaced when damaged — eliminating the need for expensive repairs or decommissioning.',
    img: '/images/2021-10-elevator-refinishing-philadelphia.webp',
    alt: 'Elevator refinishing Philadelphia',
    href: '/contact/',
    cta: 'Schedule a Consultation',
  },
  {
    number: '03',
    heading: 'Philadelphia\'s Leading Elevator Refinishing Contractor',
    body: 'Window Film Philadelphia has helped countless commercial properties restore and protect their elevator interiors while saving thousands in repair costs and minimizing operational downtime. Our experienced team provides a complete service — from initial assessment and finish selection to professional installation and ongoing replacement as needed. If your elevator interior is showing signs of wear, graffiti, or vandalism, contact us today to learn how surface film can help.',
    img: '/images/elevator-repair-window-film-philadelphia.webp',
    alt: 'Elevator repair window film Philadelphia',
    href: '/contact/',
    cta: 'Contact Our Team',
  },
];

const benefitItems = [
  { icon: 'lucide:shield',        title: 'Sacrificial Layer',         sub: 'Replaceable film protects elevator interiors' },
  { icon: 'lucide:eye-off',       title: 'Tamper-Proof',              sub: 'Invisible and secure against public access' },
  { icon: 'lucide:eraser',        title: 'Conceals Damage',           sub: 'Hides existing wear, scratches, and vandalism' },
  { icon: 'lucide:zap',           title: 'Acid Etch Resistant',       sub: 'Thick material withstands aggressive damage' },
  { icon: 'lucide:layers',        title: 'Multiple Finishes',         sub: 'Seamlessly matches any elevator interior style' },
  { icon: 'lucide:refresh-cw',    title: 'Easy Replacement',          sub: 'Quickly removed and replaced when damaged' },
  { icon: 'lucide:trending-down', title: 'Saves Thousands',           sub: 'Eliminates costly elevator repair bills' },
  { icon: 'lucide:clock',         title: 'Minimal Downtime',          sub: 'Fast installation with minimal operational impact' },
];
---

<BaseLayout title={title} description={description} canonical="https://www.windowfilmphiladelphia.net/benefits/elevator-refinishing/" serviceName="Elevator Refinishing Window Film" serviceDesc="Elevator cab surface refinishing with DI-NOC and architectural film in Philadelphia — restore without replacement." serviceUrl="https://www.windowfilmphiladelphia.net/benefits/elevator-refinishing/">

<InnerPageHero
  title="Elevator Refinishing Film Philadelphia"
  bgImage="/images/elevator-refinishing-window-film-philadelphia.webp"
  desc="Restore and protect elevator interiors with specialty film."
/>

<div class="ip-page-body">

<section class="bp-intro">
  <div class="bp-intro__inner">
    <div class="bp-intro__left">
      <span class="bp-eyebrow">Surface Restoration</span>
      <h2 class="bp-intro__title">Keep Your Elevators Looking Their Best.</h2>
    </div>
    <div class="bp-intro__right">
      <p class="bp-intro__lead">Elevator refinishing surface film is the fastest, most cost-effective way to restore and protect elevator interiors in Philadelphia commercial properties. Instead of expensive replacement panels or decommissioning downtime, a professional film application conceals existing damage, defends against future vandalism, and can be replaced in hours — saving thousands with every service call.</p>
      <div class="bp-intro__ctas">
        <a href="/contact/" class="bp-btn bp-btn--primary">Get a Free Quote</a>
        <a href="/benefits/" class="bp-btn bp-btn--ghost">All Benefits</a>
      </div>
    </div>
  </div>
</section>

<section class="bp-featured">
  <div class="bp-featured__hd">
    <span class="bp-eyebrow">How It Works</span>
    <h2 class="bp-featured__title">Everything you need to know about<br/>elevator refinishing film</h2>
  </div>

  {featuredSections.map((s, i) => (
    <div class={`bp-feat-row fade-in${i % 2 === 1 ? ' bp-feat-row--rev' : ''}`}>
      <div class="bp-feat-row__img">
        <img src={s.img} alt={s.alt} width="600" height="480" loading="lazy" />
        <span class="bp-feat-row__pill">{s.heading}</span>
      </div>
      <div class="bp-feat-row__content">
        <span class="bp-feat-row__num">{s.number}</span>
        <h3 class="bp-feat-row__heading">{s.heading}</h3>
        <p class="bp-feat-row__body">{s.body}</p>
        <a href={s.href} class="bp-feat-row__cta">
          {s.cta}
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/></svg>
        </a>
      </div>
    </div>
  ))}
</section>

<section class="bp-why">
  <div class="bp-why__hd">
    <span class="bp-eyebrow">Key Benefits</span>
    <h2 class="bp-why__title">Eight reasons elevator refinishing film pays off</h2>
  </div>
  <div class="bp-why__grid">
    {benefitItems.map((item) => (
      <div class="bp-why__item fade-in">
        <div class="bp-why__icon"><Icon name={item.icon} width="32" height="32" /></div>
        <div class="bp-why__divider"></div>
        <h4 class="bp-why__item-title">{item.title}</h4>
        <p class="bp-why__item-sub">{item.sub}</p>
      </div>
    ))}
  </div>
</section>

<section class="bp-faq">
  <div class="bp-faq__hd">
    <span class="bp-eyebrow">FAQ</span>
    <h2 class="bp-faq__title">Common questions about elevator refinishing film</h2>
  </div>
  <div class="bp-faq__item bp-faq__item--open">
    <div class="bp-faq__q">What types of elevator damage can refinishing film conceal? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Elevator refinishing film can conceal a wide range of cosmetic damage including scratches, scuffs, graffiti markings, acid etching, sticker residue, and general surface wear. The film creates a fresh, clean surface appearance regardless of what lies beneath it — making it an ideal solution for heavily used elevator cabins in commercial, residential, and institutional buildings.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">How durable is elevator refinishing film against future damage? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Elevator surface film is engineered to be thick and durable, providing resistance against everyday abrasion, marker stains, scratching, and even acid etching attacks. Because it acts as a sacrificial layer, it absorbs damage that would otherwise reach the underlying surface. Once the film is damaged, it is replaced rather than repaired — ensuring your elevator always looks its best without costly surface restoration.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">How long does elevator refinishing installation take? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Installation time varies depending on the size of the elevator cabin and the extent of the surfaces being covered, but most elevator refinishing projects can be completed within a single day — often in just a few hours. We can schedule installation during off-peak hours or overnight to minimize disruption to your building's operations and elevator availability.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">How often does elevator refinishing film need to be replaced? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Replacement frequency depends on the level of use and vandalism exposure your elevator experiences. In high-traffic or high-vandalism environments, film may need to be replaced annually or even more frequently. In lower-traffic commercial buildings, the film may last several years before replacement is needed. The replacement process is fast and far more cost-effective than traditional surface repair or panel replacement.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">Is elevator refinishing film tamper-proof? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Yes. Elevator surface film is applied professionally and cannot be easily peeled or removed by elevator users. It is designed to be invisible and indistinguishable from the underlying surface material to the general public, making it a passive, tamper-resistant solution that deters vandalism without any visible indication that a protective layer has been applied.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">What surface finishes are available for elevator refinishing? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Elevator refinishing film is available in a wide range of finishes to match virtually any elevator interior, including stainless steel, brushed metal, wood grain, and custom finishes. Our team will assess your existing elevator interior and recommend the most appropriate finish for a seamless, professional result. Custom matching is also available for unique or branded elevator interiors.</div>
  </div>
</section>

<BrandLogos />

<div class="bp-cta fade-in">
  <h2>Ready to restore your elevator with <em>surface film?</em></h2>
  <div class="bp-cta__btns">
    <a href="/contact/" class="bp-btn bp-btn--white">Get a Free Quote</a>
    <a href="tel:+12673947980" class="bp-btn bp-btn--green">Call (267) 394-7980</a>
  </div>
</div>

</div><!-- end ip-page-body -->
</BaseLayout>

<style>
.ip-page-body { position: relative; background: #ffffff; border-top-left-radius: 40px; border-top-right-radius: 40px; border-bottom-left-radius: 40px; border-bottom-right-radius: 40px; margin-top: -40px; z-index: 10; overflow: visible; padding-bottom: 80px; }
.bp-eyebrow { display: inline-block; font-family: var(--font-body, 'DM Sans', sans-serif); font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--green, #81AB4C); margin-bottom: 16px; }
.bp-btn { display: inline-block; padding: 14px 28px; border-radius: var(--radius-pill, 100px); font-family: var(--font-body, 'DM Sans', sans-serif); font-size: 15px; font-weight: 500; text-decoration: none; transition: all 0.2s; border: 2px solid transparent; white-space: nowrap; }
.bp-btn--primary { background: var(--green, #81AB4C); color: #fff; border-color: var(--green, #81AB4C); }
.bp-btn--primary:hover { background: #6e9640; border-color: #6e9640; transform: translateY(-2px); color: #fff; }
.bp-btn--ghost { background: transparent; color: var(--brand, #272E32); border-color: var(--brand, #272E32); }
.bp-btn--ghost:hover { background: var(--brand, #272E32); color: #fff; transform: translateY(-2px); }
.bp-btn--white { background: #fff; color: var(--brand, #272E32); border-color: #fff; font-weight: 600; }
.bp-btn--white:hover { background: var(--off-white, #F7F6F3); transform: translateY(-2px); }
.bp-btn--green { background: var(--green, #81AB4C); color: #fff; border-color: var(--green, #81AB4C); }
.bp-btn--green:hover { background: #6e9640; transform: translateY(-2px); color: #fff; }
.bp-intro { padding: 80px 10%; border-top-left-radius: 40px; border-top-right-radius: 40px; overflow: hidden; }
.bp-intro__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
.bp-intro__title { font-family: var(--font-serif, 'Playfair Display', serif); font-size: clamp(36px, 4.5vw, 58px); font-weight: 700; line-height: 1.1; letter-spacing: -1px; color: var(--text-dark, #1a1a1a); margin: 0; }
.bp-intro__lead { font-family: var(--font-body, 'DM Sans', sans-serif); font-size: 17px; color: var(--text-mid, #4a4a4a); line-height: 1.75; margin-bottom: 32px; }
.bp-intro__ctas { display: flex; gap: 14px; flex-wrap: wrap; }
.bp-featured { padding: 100px 10%; background: var(--off-white, #F7F6F3); }
.bp-featured__hd { margin-bottom: 72px; }
.bp-featured__title { font-family: var(--font-serif, 'Playfair Display', serif); font-size: clamp(32px, 4vw, 52px); font-weight: 700; line-height: 1.15; letter-spacing: -0.5px; color: var(--text-dark, #1a1a1a); margin: 0; }
.bp-feat-row { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; margin-bottom: 100px; }
.bp-feat-row:last-child { margin-bottom: 0; }
.bp-feat-row--rev .bp-feat-row__img { order: 2; }
.bp-feat-row--rev .bp-feat-row__content { order: 1; }
.bp-feat-row__img { position: relative; height: 480px; border-radius: 32px; overflow: hidden; }
.bp-feat-row__img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.bp-feat-row__pill { position: absolute; bottom: 24px; left: 24px; background: rgba(255,255,255,0.92); backdrop-filter: blur(8px); padding: 10px 18px; border-radius: 100px; font-family: var(--font-body, 'DM Sans', sans-serif); font-size: 13px; font-weight: 600; color: var(--brand, #272E32); box-shadow: 0 4px 16px rgba(0,0,0,0.1); }
.bp-feat-row__num { display: block; font-family: var(--font-serif, 'Playfair Display', serif); font-size: 72px; font-weight: 700; color: var(--green, #81AB4C); line-height: 1; opacity: 0.25; margin-bottom: -8px; }
.bp-feat-row__heading { font-family: var(--font-serif, 'Playfair Display', serif); font-size: clamp(24px, 3vw, 36px); font-weight: 700; color: var(--text-dark, #1a1a1a); line-height: 1.2; margin-bottom: 20px; letter-spacing: -0.3px; }
.bp-feat-row__body { font-family: var(--font-body, 'DM Sans', sans-serif); font-size: 16px; color: var(--text-mid, #4a4a4a); line-height: 1.8; margin-bottom: 28px; }
.bp-feat-row__cta { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-body, 'DM Sans', sans-serif); font-size: 15px; font-weight: 600; color: var(--green, #81AB4C); text-decoration: none; transition: gap 0.2s; }
.bp-feat-row__cta:hover { gap: 14px; }
.bp-why { background: var(--brand, #272E32); padding: 100px 10%; }
.bp-why__hd { margin-bottom: 64px; }
.bp-why__hd .bp-eyebrow { color: var(--green, #81AB4C); }
.bp-why__title { font-family: var(--font-serif, 'Playfair Display', serif); font-size: clamp(28px, 3.5vw, 48px); font-weight: 700; color: #ffffff; line-height: 1.15; letter-spacing: -0.5px; margin: 0; max-width: 600px; }
.bp-why__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; }
.bp-why__item { padding: 32px 28px; border-right: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1); }
.bp-why__item:nth-child(4n) { border-right: none; }
.bp-why__item:nth-child(n+5) { border-bottom: none; }
.bp-why__icon { color: var(--green, #81AB4C); margin-bottom: 16px; display: flex; align-items: center; line-height: 1; }
.bp-why__icon svg { display: block; }
.bp-why__divider { width: 32px; height: 2px; background: var(--green, #81AB4C); margin-bottom: 16px; }
.bp-why__item-title { font-family: var(--font-body, 'DM Sans', sans-serif); font-size: 15px; font-weight: 700; color: #ffffff; margin-bottom: 6px; }
.bp-why__item-sub { font-family: var(--font-body, 'DM Sans', sans-serif); font-size: 13px; color: rgba(255,255,255,0.5); margin: 0; line-height: 1.5; }
.bp-faq { padding: 100px 10%; background: #ffffff; }
.bp-faq__hd { margin-bottom: 48px; }
.bp-faq__title { font-family: var(--font-serif, 'Playfair Display', serif); font-size: clamp(28px, 3.5vw, 48px); font-weight: 700; line-height: 1.15; letter-spacing: -0.5px; color: var(--text-dark, #1a1a1a); max-width: 560px; margin: 0; }
.bp-faq__item { border-bottom: 1px solid var(--light-gray, #EFEFED); padding: 24px 0; cursor: pointer; max-width: 900px; }
.bp-faq__item:first-of-type { border-top: 1px solid var(--light-gray, #EFEFED); }
.bp-faq__q { font-family: var(--font-body, 'DM Sans', sans-serif); font-size: 17px; font-weight: 600; color: var(--text-dark, #1a1a1a); display: flex; justify-content: space-between; align-items: center; gap: 12px; }
.bp-faq__toggle { color: var(--green, #81AB4C); font-size: 22px; flex-shrink: 0; transition: transform 0.2s; }
.bp-faq__a { font-family: var(--font-body, 'DM Sans', sans-serif); font-size: 15px; color: var(--text-mid, #4a4a4a); line-height: 1.75; margin-top: 14px; display: none; }
.bp-faq__item--open .bp-faq__a { display: block; }
.bp-faq__item--open .bp-faq__toggle { transform: rotate(45deg); }
.bp-cta { background: var(--brand, #272E32); border-radius: 40px; padding: 64px 60px; display: flex; align-items: center; justify-content: space-between; gap: 40px; margin: 0 5% 0; }
.bp-cta h2 { font-family: var(--font-serif, 'Playfair Display', serif); font-size: 32px; font-weight: 700; color: #fff; line-height: 1.2; max-width: 460px; margin: 0; }
.bp-cta h2 em { font-style: italic; color: var(--green, #81AB4C); }
.bp-cta__btns { display: flex; gap: 14px; flex-shrink: 0; }
.fade-in { opacity: 0; transform: translateY(24px); transition: opacity 0.65s ease, transform 0.65s ease; }
.fade-in.visible { opacity: 1; transform: translateY(0); }
@media (max-width: 1024px) {
  .bp-intro__inner { grid-template-columns: 1fr; gap: 40px; }
  .bp-feat-row { grid-template-columns: 1fr; gap: 40px; }
  .bp-feat-row--rev .bp-feat-row__img { order: 0; }
  .bp-feat-row--rev .bp-feat-row__content { order: 1; }
  .bp-why__grid { grid-template-columns: repeat(2, 1fr); }
  .bp-why__item:nth-child(4n) { border-right: 1px solid rgba(255,255,255,0.1); }
  .bp-why__item:nth-child(2n) { border-right: none; }
}
@media (max-width: 768px) {
  .bp-intro { padding: 60px 5%; }
  .bp-featured { padding: 60px 5%; }
  .bp-why { padding: 60px 5%; }
  .bp-faq { padding: 60px 5%; }
  .bp-feat-row__img { height: 300px; }
  .bp-why__grid { grid-template-columns: 1fr; }
  .bp-cta { flex-direction: column; padding: 40px 28px; text-align: center; }
  .bp-cta h2 { font-size: 26px; max-width: 100%; }
  .bp-cta__btns { flex-direction: column; width: 100%; }
}
@media (max-width: 480px) { .bp-intro__ctas { flex-direction: column; } }
</style>

<script>
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-in').forEach(el => obs.observe(el));
  document.querySelectorAll('.bp-faq__item').forEach(item => {
    item.querySelector('.bp-faq__q')?.addEventListener('click', () => {
      const isOpen = item.classList.contains('bp-faq__item--open');
      document.querySelectorAll('.bp-faq__item').forEach(i => i.classList.remove('bp-faq__item--open'));
      if (!isOpen) item.classList.add('bp-faq__item--open');
    });
  });
</script>
