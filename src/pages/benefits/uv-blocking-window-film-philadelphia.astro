<BaseLayout title={title} description={description} canonical='https://www.windowfilmphiladelphia.net/benefits/uv-blocking-window-film-philadelphia/'>
  <section class="page-hero" style="background-image: linear-gradient(rgba(40,40,40,0.62), rgba(40,40,40,0.80)), url('/images/window-film-philadelphia-uv-glare-reduction.jpg'); background-size: cover; background-position: center;">
    <div class="container">
      <h1>UV Blocking Window Film in Philadelphia</h1>
    </div>
