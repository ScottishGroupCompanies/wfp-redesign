---
/* Hallmark · redesign · macrostructure: numbered-alternating-rows · tone: professional-editorial
 * template: benefits.astro · anchor hue: green (#81AB4C) */
import BaseLayout from '../../layouts/BaseLayout.astro';
import InnerPageHero from '../../components/InnerPageHero.astro';
import BrandLogos from '../../components/BrandLogos.astro';
import { Icon } from 'astro-icon/components';

const title = 'UV Blocking Window Film Philadelphia | Window Film Philadelphia';
const description = 'Window Film Philadelphia is the trusted source for UV blocking window film in Philadelphia. Protect interiors and reduce fading. Get a quote today!';

const featuredSections = [
  {
    number: '01',
    heading: 'UV Blocking Window Film in Philadelphia',
    body: 'Window Film Philadelphia is the trusted source for UV blocking window film in Philadelphia, Pennsylvania. Our films block up to 99.9% of UVA and UVB rays — the equivalent of SPF 1,000 — protecting people, furniture, flooring, and artwork from invisible damage. With access to a wide selection from leading brands like 3M, Vista, LLumar, Solar Gard, and Huper Optik, clients enjoy outstanding results from a single installation. Whether you want to safeguard valuables in your commercial property or prevent hardwood floors in your home from fading, we will help you find the perfect UV blocking solution.',
    img: '/images/window-film-philadelphia-uv-glare-reduction.webp',
    alt: 'UV blocking window film Philadelphia',
    href: '/contact/',
    cta: 'Get a Free Quote',
  },
  {
    number: '02',
    heading: 'Why Philadelphia Properties Need UV Protection',
    body: "The sun's UV rays are one of the leading causes of interior fading and material breakdown. Furniture, carpets, hardwood flooring, and artwork are all vulnerable to sun damage over time. UV window film acts like an invisible shield, filtering out harmful rays while still allowing natural light into your space. For homeowners, this means protecting your investment and extending the life of your decor. For businesses, it means lower maintenance costs, a more comfortable environment for employees and customers, and reduced liability from UV-related occupant health risks.",
    img: '/images/window-film-philadelphia-uv-protection-solar-filter-1.webp',
    alt: 'UV protection window film Philadelphia',
    href: '/benefits/energy-savings/',
    cta: 'Explore Energy Savings',
  },
  {
    number: '03',
    heading: 'Energy Savings and Return on Investment',
    body: 'UV window films do more than protect interiors — they also improve energy efficiency. By reducing solar heat gain, film keeps indoor temperatures more consistent and reduces strain on cooling systems, often translating to significant savings on monthly energy bills. Most Philadelphia property owners see a full return on investment within two to five years through energy cost reductions alone. With rising utility rates, UV window film is one of the smartest long-term upgrades available for both residential and commercial properties.',
    img: '/images/window-film-philadelphia-uv-blocking-tint-1.webp',
    alt: 'UV blocking window film energy savings Philadelphia',
    href: '/contact/',
    cta: 'Schedule a Consultation',
  },
];

const benefitItems = [
  { icon: 'lucide:sun',            title: '99.9% UV Block',           sub: 'Equivalent to SPF 1,000 protection' },
  { icon: 'lucide:layers',         title: 'Fade Protection',          sub: 'Shields furniture, flooring & artwork' },
  { icon: 'lucide:thermometer',    title: 'Solar Heat Rejection',     sub: 'Reduces cooling load year-round' },
  { icon: 'lucide:eye',            title: 'Clear Views Maintained',   sub: 'Natural light without the damage' },
  { icon: 'lucide:shield-check',   title: 'Health Protection',        sub: 'Reduces UV-related skin & eye risk' },
  { icon: 'lucide:leaf',           title: 'LEED Eligible',            sub: 'Qualifies for green building credits' },
  { icon: 'lucide:trending-down',  title: 'Energy Savings',           sub: 'Lower cooling costs from day one' },
  { icon: 'lucide:clock',          title: 'Fast ROI',                 sub: 'Payback period of 2–5 years' },
];
---

<BaseLayout title={title} description={description} canonical="https://www.windowfilmphiladelphia.net/benefits/uv-blocking-window-film-philadelphia/" serviceName="UV Blocking Window Film" serviceDesc="UV blocking window film installation in Philadelphia. Block up to 99% of harmful UV rays to protect furnishings, art, and flooring." serviceUrl="https://www.windowfilmphiladelphia.net/benefits/uv-blocking-window-film-philadelphia/">

<InnerPageHero
  title="UV Blocking Window Film Philadelphia"
  bgImage="/images/window-film-philadelphia-uv-blocking-solar-shield-1.webp"
  desc="Block up to 99% of UV rays and protect interiors from fading."
/>

<div class="ip-page-body">

<!-- ══════════════════════════════════════
     INTRO — 2-col: big heading left, text + CTAs right
     ══════════════════════════════════════ -->
<section class="bp-intro">
  <div class="bp-intro__inner">
    <div class="bp-intro__left">
      <span class="bp-eyebrow">UV Protection</span>
      <h2 class="bp-intro__title">Block the Ray. Protect What's Inside.</h2>
    </div>
    <div class="bp-intro__right">
      <p class="bp-intro__lead">UV blocking window film is one of the most effective — and most overlooked — upgrades for Philadelphia properties. By filtering out up to 99.9% of harmful UV radiation, film protects interiors from fading and occupants from health risks, all while reducing solar heat gain and cutting energy costs. No replacement windows. No disruption. Just immediate, lasting protection.</p>
      <div class="bp-intro__ctas">
        <a href="/contact/" class="bp-btn bp-btn--primary">Get a Free Quote</a>
        <a href="/benefits/" class="bp-btn bp-btn--ghost">All Benefits</a>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     FEATURED SECTIONS — 3 numbered alternating rows
     ══════════════════════════════════════ -->
<section class="bp-featured">
  <div class="bp-featured__hd">
    <span class="bp-eyebrow">How It Works</span>
    <h2 class="bp-featured__title">Everything you need to know about<br/>UV blocking window film</h2>
  </div>

  {featuredSections.map((s, i) => (
    <div class={`bp-feat-row fade-in${i % 2 === 1 ? ' bp-feat-row--rev' : ''}`}>
      <div class="bp-feat-row__img">
        <img src={s.img} alt={s.alt} width="600" height="480" loading="lazy" />
        <span class="bp-feat-row__pill">{s.heading}</span>
      </div>
      <div class="bp-feat-row__content">
        <span class="bp-feat-row__num">{s.number}</span>
        <h3 class="bp-feat-row__heading">{s.heading}</h3>
        <p class="bp-feat-row__body">{s.body}</p>
        <a href={s.href} class="bp-feat-row__cta">
          {s.cta}
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/></svg>
        </a>
      </div>
    </div>
  ))}
</section>

<!-- ══════════════════════════════════════
     BENEFITS GRID — 4-col dark icon grid
     ══════════════════════════════════════ -->
<section class="bp-why">
  <div class="bp-why__hd">
    <span class="bp-eyebrow">Key Benefits</span>
    <h2 class="bp-why__title">Eight reasons UV blocking film is worth it</h2>
  </div>
  <div class="bp-why__grid">
    {benefitItems.map((item) => (
      <div class="bp-why__item fade-in">
        <div class="bp-why__icon"><Icon name={item.icon} width="32" height="32" /></div>
        <div class="bp-why__divider"></div>
        <h4 class="bp-why__item-title">{item.title}</h4>
        <p class="bp-why__item-sub">{item.sub}</p>
      </div>
    ))}
  </div>
</section>

<!-- ══════════════════════════════════════
     FAQ ACCORDION
     ══════════════════════════════════════ -->
<section class="bp-faq">
  <div class="bp-faq__hd">
    <span class="bp-eyebrow">FAQ</span>
    <h2 class="bp-faq__title">Common questions about UV blocking window film</h2>
  </div>
  <div class="bp-faq__item bp-faq__item--open">
    <div class="bp-faq__q">How much UV does window film actually block? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Most high-quality UV blocking window films block up to 99.9% of UVA and UVB radiation — roughly equivalent to SPF 1,000 sun protection. This applies even to clear or lightly tinted films, meaning you don't need a dark film to get maximum UV protection. Our team carries films from 3M, LLumar, Vista, and Solar Gard with best-in-class UV rejection ratings.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">Will UV blocking film stop my furniture and floors from fading? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">UV film dramatically reduces fading caused by UV radiation, which accounts for roughly 40–60% of all interior fading. While no film eliminates fading entirely — visible light and heat also contribute — UV blocking film significantly extends the life of furniture, hardwood floors, carpets, artwork, and merchandise. Most clients see a measurable difference in fading rates within the first year of installation.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">Does UV blocking film make my windows look dark or tinted? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Not necessarily. UV rejection is independent of visible light transmission — many of our films are nearly clear while still blocking 99.9% of UV rays. If you also want solar heat rejection and glare reduction, we carry spectrally selective films that accomplish all three goals while maintaining high visible light transmission. We'll recommend the right film for your goals and aesthetic preferences.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">Can UV window film reduce my energy bills? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Yes. Films that combine UV blocking with solar heat rejection reduce the amount of heat entering your building through glass, which lowers the demand on your HVAC system. Philadelphia property owners typically see cooling cost reductions of 20–30% during summer months. The result is a film that pays for itself through energy savings while also protecting your interiors — making it one of the highest-ROI window treatments available.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">Is UV blocking window film safe for double-pane insulated glass? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Most UV blocking films are safe for double-pane insulated glass units (IGUs), but proper film selection matters. Certain high-reflectivity films can increase thermal stress in double-pane windows. Our installation team assesses your window type before recommending a film, and we carry products specifically engineered for IGUs. We'll never recommend a film that could void your window manufacturer's warranty.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">How long does UV blocking window film last? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Premium UV blocking films from brands like 3M, LLumar, and Vista are designed to last 10–20+ years with proper installation and care. Most manufacturer warranties cover film performance, adhesion, and UV rejection levels for the life of the film. Our professional installation ensures proper application that maximizes film longevity and maintains manufacturer warranty coverage.</div>
  </div>
</section>

<!-- ══════════════════════════════════════
     BRAND LOGOS
     ══════════════════════════════════════ -->
<BrandLogos />

<!-- ══════════════════════════════════════
     CTA BANNER
     ══════════════════════════════════════ -->
<div class="bp-cta fade-in">
  <h2>Ready to protect your property with <em>UV blocking film?</em></h2>
  <div class="bp-cta__btns">
    <a href="/contact/" class="bp-btn bp-btn--white">Get a Free Quote</a>
    <a href="tel:+12673947980" class="bp-btn bp-btn--green">Call (267) 394-7980</a>
  </div>
</div>

</div><!-- end ip-page-body -->
</BaseLayout>

<style>
/* ── PAGE BODY WRAPPER ── */
.ip-page-body {
  position: relative;
  background: #ffffff;
  border-top-left-radius: 40px;
  border-top-right-radius: 40px;
  border-bottom-left-radius: 40px;
  border-bottom-right-radius: 40px;
  margin-top: -40px;
  z-index: 10;
  overflow: visible;
  padding-bottom: 80px;
}

/* ── EYEBROW ── */
.bp-eyebrow {
  display: inline-block;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--green, #81AB4C);
  margin-bottom: 16px;
}

/* ── BUTTONS ── */
.bp-btn {
  display: inline-block; padding: 14px 28px;
  border-radius: var(--radius-pill, 100px);
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; font-weight: 500;
  text-decoration: none; transition: all 0.2s;
  border: 2px solid transparent; white-space: nowrap;
}
.bp-btn--primary { background: var(--green, #81AB4C); color: #fff; border-color: var(--green, #81AB4C); }
.bp-btn--primary:hover { background: #6e9640; border-color: #6e9640; transform: translateY(-2px); color: #fff; }
.bp-btn--ghost { background: transparent; color: var(--brand, #272E32); border-color: var(--brand, #272E32); }
.bp-btn--ghost:hover { background: var(--brand, #272E32); color: #fff; transform: translateY(-2px); }
.bp-btn--white { background: #fff; color: var(--brand, #272E32); border-color: #fff; font-weight: 600; }
.bp-btn--white:hover { background: var(--off-white, #F7F6F3); transform: translateY(-2px); }
.bp-btn--green { background: var(--green, #81AB4C); color: #fff; border-color: var(--green, #81AB4C); }
.bp-btn--green:hover { background: #6e9640; transform: translateY(-2px); color: #fff; }

/* ── INTRO ── */
.bp-intro {
  padding: 80px 10%;
  border-top-left-radius: 40px;
  border-top-right-radius: 40px;
  overflow: hidden;
}
.bp-intro__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}
.bp-intro__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(36px, 4.5vw, 58px);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -1px;
  color: var(--text-dark, #1a1a1a);
  margin: 0;
}
.bp-intro__lead {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 17px;
  color: var(--text-mid, #4a4a4a);
  line-height: 1.75;
  margin-bottom: 32px;
}
.bp-intro__ctas { display: flex; gap: 14px; flex-wrap: wrap; }

/* ── FEATURED SECTIONS ── */
.bp-featured {
  padding: 100px 10%;
  background: var(--off-white, #F7F6F3);
}
.bp-featured__hd { margin-bottom: 72px; }
.bp-featured__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(32px, 4vw, 52px);
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: -0.5px;
  color: var(--text-dark, #1a1a1a);
  margin: 0;
}
.bp-feat-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
