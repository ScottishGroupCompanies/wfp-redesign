  max-width: 600px;
}
.bp-why__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
}
.bp-why__item {
  padding: 32px 28px;
  border-right: 1px solid rgba(255,255,255,0.1);
  border-bottom: 1px solid rgba(255,255,255,0.1);
}
.bp-why__item:nth-child(4n) { border-right: none; }
.bp-why__item:nth-child(n+5) { border-bottom: none; }
.bp-why__icon {
