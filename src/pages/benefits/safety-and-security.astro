  body={'Window Film Philadelphia is honored to provide leading services of safety and security window film for residential and commercial properties in Philadelphia. We’ve helped countless buildings defend against threats and would love the opportunity to help protect your property. Reach out today to learn how we can enhance your property’s security and peace of mind!'}
  imageSrc={'/images/safety-security-window-film-philadelphia.jpg'}
  imageAlt={'safety security window film philadelphia'}
  flip={true}
  altBg={true}
/>

  <section class="cta-strip">
