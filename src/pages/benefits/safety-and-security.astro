  imageAlt={'security window film philadelphia'}
  flip={true}
  altBg={true}
/>

  <BackAndForthSection
  heading={'Why Choose Security Window Film in Philadelphia'}
  body={'Safety and security window film for Philadelphia properties offers numerous benefits for homes and businesses, including: Mitigate broken glass hazards to minimize the risk of injury and death Easy cleanup for minimized operational downtime Upgrades standard glass to meet tempered glass safety standards Lasts the lifetime of your windows Invisible, passive, 24/7 security Deters intruders and provides additional response time Learn more by following this link: Resource for Security Window Film Philadelphia'}
  imageSrc={'/images/safety-window-film-philadelphia.jpg'}
  imageAlt={'safety window film philadelphia'}
  flip={false}
  altBg={false}
/>

