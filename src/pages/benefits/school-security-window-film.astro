---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InnerPageHero from '../../components/InnerPageHero.astro';
import BackAndForthSection from '../../components/BackAndForthSection.astro';
import BrandLogos from '../../components/BrandLogos.astro';
import CTAStrip from '../../components/CTAStrip.astro';

const title = 'School Security Window Film Philadelphia | Window Film Philadelphia';
const description = 'Window Film Philadelphia offers expert installation of security window film in Philadelphia schools, enhancing safety, reducing risks, and protecting students and staff.';
---

<BaseLayout title={title} description={description} canonical='https://www.windowfilmphiladelphia.net/benefits/school-security-window-film/'>

<InnerPageHero
  title="School Security Window Film"
  bgImage="/images/school-security-window-film-philadelphia-1.jpeg"
  desc="Protect students and staff with safety and security film."
/>

<div class="ip-page-body">
  <BackAndForthSection
    heading={"Security Window Film in Philadelphia for Safer Schools"}
    body={"As our society faces ongoing security concerns, it is crucial to prioritize the safety of our schools. Window Film Philadelphia offers state-of-the-art school security window film for Philadelphia educational facilities. Our security films are specifically engineered to fortify school windows and withstand significant force — providing valuable additional response time for safe evacuation during a threat."}
    imageSrc={'/images/school-security-window-film-philadelphia-1.jpeg'}
    imageAlt={'School security window film Philadelphia'}
    flip={false}
    altBg={false}
  />

  <BackAndForthSection
    heading={"Security Challenges for Schools in Philadelphia"}
    body={"Schools in Philadelphia face significant security challenges, primarily related to gun violence. Some schools have reported high levels of violent incidents, prompting officials to introduce new programs and policies to monitor and prevent threats. To address safety concerns, schools have implemented measures like security cameras, metal detectors, and police officers. Pennsylvania schools must also adhere to strict security protocols including mandated requirements for school safety and active shooter protocols."}
    imageSrc={'/images/philadelphia-security-system-school-scaled-1.jpg'}
    imageAlt={'Philadelphia school security system'}
    flip={true}
    altBg={true}
  />

  <BackAndForthSection
    heading={"Security Film Options for Schools"}
    body={"We offer a range of security film options to cater to the unique needs of Philadelphia schools:\nBasic Security Film — Economical option to strengthen glass; increases response time by 30 seconds to 1 minute.\nPremium Security Film — Advanced carbon fiber, cross-weave technology; increases response time by 30 seconds to 3 minutes.\nDual Premium Security Film — Interior and exterior application with anchoring system; recommended for dual-pane glazing; increases response time by 3 minutes or more.\nBomb Blast Resistant Film — Offered for single and dual-pane applications; increases flexibility and shatter resistance.\nBallistic Resistant Security Film — Three layers of security window film; designed to protect against crimes committed with 9mm handguns or below."}
    imageSrc={'/images/philadelphia-college-school-security-film-1.jpg'}
    imageAlt={'Philadelphia college school security film'}
    flip={false}
    altBg={false}
  />

  <BackAndForthSection
    heading={"Key Considerations for Schools in Philadelphia"}
    body={"Single or double-pane windows — recommend double layer of film for single-pane glass\nSide doors and points of entry — extend security to all potential access points\nInterior and exterior locking doors — both sets should be coated with security film\nFront desk protection — ensure the front desk area is included in your security plan"}
    imageSrc={'/images/security-film-philadelphia-schools-2.jpg'}
    imageAlt={'Security film Philadelphia schools'}
    flip={true}
    altBg={true}
  />

  <BackAndForthSection
    heading={"Enhance School Safety with Security Window Film in Philadelphia"}
    body={"Window Film Philadelphia is dedicated to providing top-notch security solutions to safeguard Philadelphia educational institutions. By enhancing response time and fortifying windows, our security film options serve as a vital layer of defense — giving students, teachers, and staff precious moments to evacuate safely. Contact Window Film Philadelphia today to discuss your school security needs and schedule a consultation."}
    imageSrc={'/images/security-film-schools-philadelphia.jpeg'}
    imageAlt={'Security film schools Philadelphia'}
    flip={false}
    altBg={false}
    ctaLabel={'Schedule a Consultation'}
    ctaHref={'/contact/'}
  />

  <BrandLogos />
  <CTAStrip />
</div>

</BaseLayout>

<style>
.benefit-list {
  padding-left: 1.5em;
  margin-top: 0.75rem;
}
.benefit-list li {
  margin-bottom: 0.5rem;
  color: var(--color-text-secondary);
  line-height: 1.6;
}
.ip-page-body {
  position: relative;
  background: #ffffff;
  border-top-left-radius: 40px;
  border-top-right-radius: 40px;
  border-bottom-left-radius: 40px;
  border-bottom-right-radius: 40px;
  margin-top: -40px;
  z-index: 10;
  overflow: visible;
  padding-bottom: 80px;
}
</style>