---
import BaseLayout from '../layouts/BaseLayout.astro';
import InnerPageHero from '../components/InnerPageHero.astro';
import BrandLogos from '../components/BrandLogos.astro';
import { Icon } from 'astro-icon/components';

const title = 'Window Film Applications | Philadelphia PA | All Properties';
const description = 'Window Film Philadelphia installs professional window film for offices, retail stores, hotels, schools, government buildings, churches, and more across the Philadelphia area.';

const faqItems = [
  { question: 'What types of properties do you service?', answer: 'We work on virtually any commercial or residential property — offices, retail shops, hotels, restaurants, schools, government buildings, arenas, airports, museums, libraries, and churches. If you have glass, we have a film solution for it.' },
  { question: 'How long does a commercial installation typically take?', answer: 'Most commercial projects are completed within one to three days depending on square footage and film type. We schedule installations to minimize disruption to your business operations — including after-hours and weekend availability for high-traffic locations.' },
  { question: 'Can window film be applied to existing glass without replacing it?', answer: 'Yes — that is one of the primary advantages of window film. It applies directly to your existing glass surface, delivering energy savings, security upgrades, and aesthetic changes at a fraction of the cost of glass replacement. No structural work or permits required in most cases.' },
  { question: 'Do you offer different film solutions depending on the property type?', answer: 'Absolutely. A school and a restaurant have very different needs. We carry over 200 film products from brands like 3M, LLumar, Vista, and Solar Gard — from daylight-redirecting classroom films to ballistic-resistant panels for secured facilities.' },
  { question: 'Do you work on residential properties as well as commercial?', answer: 'Yes. While we specialize in commercial and institutional installations, we work extensively on homes throughout the Philadelphia area — from rowhouses in Fishtown to suburban properties in the Main Line.' },
  { question: 'How do I know which film type is right for my property?', answer: 'The best starting point is identifying your primary goal — energy savings, security, privacy, aesthetics, or UV protection. Many of our films address multiple goals in one product. Our team will assess your property during a free on-site estimate and walk you through the options.' },
];

const applications = [
  {
    label: 'Office Buildings',
    desc: 'Reduce glare on screens, cut utility costs, and improve employee comfort with minimal disruption to operations.',
    img: '/images/2021-09-office-window-film-philadelphia.webp',
    alt: 'Office window film Philadelphia',
    href: '/applications/office/',
  },
  {
    label: 'Retail Stores & Malls',
    desc: 'Decorative branding film, UV protection for merchandise displays, and glare control to enhance the shopper experience.',
    img: '/images/2021-09-retail-window-film-philadelphia.webp',
    alt: 'Retail window film Philadelphia',
    href: '/applications/retail/',
  },
  {
    label: 'Hotels',
    desc: 'Privacy, glare reduction, UV protection, and energy savings — enhancing the guest experience across every floor.',
    img: '/images/2021-09-hotel-window-film-philadelphia.webp',
    alt: 'Hotel window film Philadelphia',
    href: '/applications/hotel-window-film/',
  },
  {
    label: 'Restaurants',
    desc: 'Set the right dining ambiance with privacy film, glare control, and decorative branding for storefronts and interiors.',
    img: '/images/2021-09-restaurant-window-film-philadelphia.webp',
    alt: 'Restaurant window film Philadelphia',
    href: '/applications/restaurants-window-film-philadelphia/',
  },
  {
    label: 'Schools & Universities',
    desc: 'Security film, daylight redirecting solutions, and glare reduction create safer, more productive learning environments.',
    img: '/images/2021-09-classroom-window-film-philadelphia.webp',
    alt: 'School window film Philadelphia',
    href: '/applications/schools-universities/',
  },
  {
    label: 'Arenas & Stadiums',
    desc: 'Energy savings, glare reduction, and exterior advertising film for large-scale venues with thousands of occupants.',
    img: '/images/2021-09-arena-window-film-philadelphia.webp',
    alt: 'Arena and stadium window film Philadelphia',
    href: '/applications/arenas-stadiums/',
  },
  {
    label: 'Secured Buildings',
    desc: 'Banks, police stations, and data centers reinforced with security film against forced entry, blast, and ballistic threats.',
    img: '/images/2021-09-secured-building-window-film-philadelphia.webp',
    alt: 'Secured building window film Philadelphia',
    href: '/applications/secured-buildings/',
  },
  {
    label: 'Airports & Transit',
    desc: 'Anti-graffiti film, security enhancements, and decorative advertising for high-traffic transit environments.',
    img: '/images/2021-09-mass-transit-window-film-philadelphia.webp',
    alt: 'Airport and mass transit window film Philadelphia',
    href: '/applications/mass-transit/',
  },
  {
    label: 'Government Buildings',
    desc: 'Energy-saving and security films that preserve architectural character while reducing utility costs and protecting public-facing glass.',
    img: '/images/2021-09-government-building-window-film-philadelphia.webp',
    alt: 'Government building window film Philadelphia',
    href: '/government-buildings/',
  },
  {
    label: 'Museums & Libraries',
    desc: 'UV-blocking films preserve rare collections while creating a comfortable, well-lit environment for visitors.',
    img: '/images/2021-09-museum-window-film-philadelphia.webp',
    alt: 'Museum and library window film Philadelphia',
    href: '/applications/museums-libraries/',
  },
  {
    label: 'Churches',
    desc: 'Stained glass effect decorative films, energy savings, and safety solutions for houses of worship of every denomination.',
    img: '/images/2021-09-church-window-film-philadelphia.webp',
    alt: 'Church window film Philadelphia',
    href: '/applications/churches/',
  },
];

const featuredApplications = [
  {
    number: '01',
    heading: 'Commercial Office Buildings',
    body: 'Office window film is one of the most impactful upgrades a Philadelphia property manager can make. Our solar control films reduce glare on monitors, eliminate hot and cold spots, and can cut cooling costs by up to 30% — all without replacing your existing glass. Ideal for high-rises, co-working spaces, and corporate campuses.',
    img: '/images/2021-09-office-window-film-philadelphia.webp',
    alt: 'Office building window film Philadelphia',
    href: '/applications/office/',
    cta: 'Explore Office Film',
  },
  {
    number: '02',
    heading: 'Schools, Universities & Secured Facilities',
    body: 'Educational and security-critical buildings require a unique combination of safety, privacy, and performance. Our certified security and ballistic-resistant films fortify classroom and entry glass against forced entry and accidents. Daylight redirecting film improves classroom visibility — creating better learning environments without renovation.',
    img: '/images/2021-09-classroom-window-film-philadelphia.webp',
    alt: 'School security window film Philadelphia',
    href: '/applications/schools-universities/',
    cta: 'Explore School & Security Film',
  },
  {
    number: '03',
    heading: 'Retail, Hospitality & Dining',
    body: 'First impressions matter. Decorative and branded window film transforms storefronts and interiors for retail shops, hotels, and restaurants throughout Philadelphia. Protect merchandise displays from UV fading, control glare for a better guest experience, and add custom logos or frosted privacy patterns — all in a single installation.',
    img: '/images/2021-09-retail-window-film-philadelphia.webp',
    alt: 'Retail and hospitality window film Philadelphia',
    href: '/applications/retail/',
    cta: 'Explore Retail & Hospitality Film',
  },
];

const whyItems = [
  { icon: 'lucide:award',       title: '15+ Years Experience',        sub: 'Serving Philadelphia since 2008' },
  { icon: 'lucide:badge-check', title: 'Factory-Certified Installers', sub: '3M, LLumar, Vista, Solar Gard' },
  { icon: 'lucide:file-check',  title: 'Lifetime Warranty',            sub: 'On all residential & commercial films' },
  { icon: 'lucide:calendar',    title: 'Free Consultations',           sub: 'On-site estimates, no obligation' },
  { icon: 'lucide:star',        title: '4.9 Google Rating',            sub: '5,000+ projects completed' },
  { icon: 'lucide:map-pin',     title: 'Philadelphia-Based',           sub: 'Local crews, same-week scheduling' },
  { icon: 'lucide:layers',      title: 'Premium Film Brands',          sub: '3M, LLumar, Vista, Solar Gard, Madico' },
  { icon: 'lucide:umbrella',    title: 'Fully Insured',                sub: 'Licensed & insured in PA and NJ' },
];
---

<BaseLayout title={title} description={description} canonical="https://www.windowfilmphiladelphia.net/applications/" faqItems={faqItems}>

<InnerPageHero
  title="Window Film Applications Philadelphia"
  bgImage="/images/2021-08-window-film-philadelphia-applications.webp"
  desc="Professional window film solutions for every Philadelphia property type."
/>

<div class="ip-page-body">

<!-- ══════════════════════════════════════
     INTRO — 2-col: big heading left, text + CTAs right
     ══════════════════════════════════════ -->
<section class="bp-intro">
  <div class="bp-intro__inner">
    <div class="bp-intro__left">
      <span class="bp-eyebrow">Where We Work</span>
      <h2 class="bp-intro__title">Window Film for Every Philadelphia Property</h2>
    </div>
    <div class="bp-intro__right">
      <p class="bp-intro__lead">From Center City high-rises to South Philadelphia churches, Window Film Philadelphia has the expertise and product range to serve any commercial or residential property. Explore how window film transforms different property types — and find the right solution for your building.</p>
      <div class="bp-intro__ctas">
        <a href="/contact/" class="bp-btn bp-btn--primary">Get a Free Quote</a>
        <a href="/benefits/" class="bp-btn bp-btn--ghost">View Film Benefits</a>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     STATS — 2-col: hero image + 2×2 card grid
     ══════════════════════════════════════ -->
<section class="bp-stats">
  <div class="bp-stats__inner">

    <div class="bp-stats__hero-img">
      <img src="/images/wfp-bp-stats-large.webp" alt="Commercial window film installation Philadelphia" loading="lazy" />
    </div>

    <div class="bp-stats__grid">

      <div class="bp-stat-card">
        <div class="bp-stat-card__top">
          <div class="bp-stat-card__label">Years of Experience</div>
          <div class="bp-stat-card__rule"></div>
        </div>
        <div class="bp-stat-card__bottom">
          <div class="bp-stat-card__num">15<span class="bp-stat-card__accent">+</span></div>
          <div class="bp-stat-card__sub">Serving Philadelphia since 2008</div>
        </div>
      </div>

      <div class="bp-stat-card">
        <div class="bp-stat-card__top">
          <div class="bp-stat-card__label">Projects Completed</div>
          <div class="bp-stat-card__rule"></div>
        </div>
        <div class="bp-stat-card__bottom">
          <div class="bp-stat-card__num">5k<span class="bp-stat-card__accent">+</span></div>
          <div class="bp-stat-card__sub">Residential &amp; commercial installs</div>
        </div>
      </div>

      <div class="bp-stat-card">
        <div class="bp-stat-card__top">
          <div class="bp-stat-card__label">Google Rating</div>
          <div class="bp-stat-card__rule"></div>
        </div>
        <div class="bp-stat-card__bottom">
          <div class="bp-stat-card__num">4.9<span class="bp-stat-card__accent">★</span></div>
          <div class="bp-stat-card__sub">Average customer rating</div>
        </div>
      </div>

      <div class="bp-stat-card bp-stat-card--img">
        <img src="/images/wfp-bp-stats-card.webp" alt="Window film professionals Philadelphia" loading="lazy" />
      </div>

    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     FEATURED APPLICATIONS — numbered alternating rows
     ══════════════════════════════════════ -->
<section class="bp-featured">
  <div class="bp-featured__hd">
    <span class="bp-eyebrow">Top Applications</span>
    <h2 class="bp-featured__title">Built for the demands of<br/>Philadelphia's property landscape</h2>
  </div>

  {featuredApplications.map((a, i) => (
    <div class={`bp-feat-row fade-in${i % 2 === 1 ? ' bp-feat-row--rev' : ''}`}>
      <div class="bp-feat-row__img">
        <img src={a.img} alt={a.alt} width="600" height="480" loading="lazy" />
        <span class="bp-feat-row__pill">{a.heading}</span>
      </div>
      <div class="bp-feat-row__content">
        <span class="bp-feat-row__num">{a.number}</span>
        <h3 class="bp-feat-row__heading">{a.heading}</h3>
        <p class="bp-feat-row__body">{a.body}</p>
        <a href={a.href} class="bp-feat-row__cta">
          {a.cta}
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/></svg>
        </a>
      </div>
    </div>
  ))}
</section>

<!-- ══════════════════════════════════════
     ALL APPLICATIONS GRID — image cards
     ══════════════════════════════════════ -->
<section class="bp-all">
  <div class="bp-all__hd">
    <span class="bp-eyebrow">All Property Types</span>
    <h2 class="bp-all__title">Every type of property we serve in Philadelphia</h2>
  </div>
  <div class="bp-all__grid">
    {applications.map((a, i) => (
      <a href={a.href} class="bp-all__card fade-in" style={`transition-delay: ${(i % 4) * 80}ms`}>
        <div class="bp-all__card-img">
          <img src={a.img} alt={a.alt} loading="lazy" />
        </div>
        <div class="bp-all__card-body">
          <h3 class="bp-all__card-title">{a.label}</h3>
          <div class="bp-all__card-rule"></div>
          <p class="bp-all__card-desc">{a.desc}</p>
        </div>
      </a>
    ))}
  </div>
</section>

<!-- ══════════════════════════════════════
     WHY US — 4-col icon grid
     ══════════════════════════════════════ -->
<section class="bp-why">
  <div class="bp-why__hd">
    <span class="bp-eyebrow">Why Window Film Philadelphia</span>
    <h2 class="bp-why__title">Genuine partner in every aspect of your project</h2>
  </div>
  <div class="bp-why__grid">
    {whyItems.map((item) => (
      <div class="bp-why__item fade-in">
        <div class="bp-why__icon"><Icon name={item.icon} width="32" height="32" /></div>
        <div class="bp-why__divider"></div>
        <h4 class="bp-why__item-title">{item.title}</h4>
        <p class="bp-why__item-sub">{item.sub}</p>
      </div>
    ))}
  </div>
</section>

<!-- ══════════════════════════════════════
     FAQ ACCORDION
     ══════════════════════════════════════ -->
<section class="bp-faq">
  <div class="bp-faq__hd">
    <span class="bp-eyebrow">FAQ</span>
    <h2 class="bp-faq__title">Common questions about window film applications</h2>
  </div>
  <div class="bp-faq__item bp-faq__item--open">
    <div class="bp-faq__q">What types of properties do you service? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">We work on virtually any commercial or residential property — offices, retail shops, hotels, restaurants, schools, government buildings, arenas, airports, museums, libraries, and churches. If you have glass, we have a film solution for it. Contact us for a free on-site consultation.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">How long does a commercial installation typically take? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Most commercial projects are completed within one to three days depending on square footage and film type. We schedule installations to minimize disruption to your business operations — including after-hours and weekend availability for high-traffic locations.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">Can window film be applied to existing glass without replacing it? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Yes — that's one of the primary advantages of window film. It applies directly to your existing glass surface, delivering energy savings, security upgrades, and aesthetic changes at a fraction of the cost of glass replacement. No structural work or permits required in most cases.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">Do you offer different film solutions depending on the property type? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Absolutely. A school and a restaurant have very different needs. We carry over 200 film products from brands like 3M, LLumar, Vista, and Solar Gard — from daylight-redirecting classroom films to ballistic-resistant panels for secured facilities. Our team will recommend the right film during your free consultation.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">Do you work on residential properties as well as commercial? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Yes. While we specialize in commercial and institutional installations, we work extensively on homes throughout the Philadelphia area — from rowhouses in Fishtown to suburban properties in the Main Line. Our residential clients benefit from the same premium films and certified installation teams as our commercial accounts.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">How do I know which film type is right for my property? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">The best starting point is identifying your primary goal — energy savings, security, privacy, aesthetics, or UV protection. Many of our films address multiple goals in one product. Our team will assess your property during a free on-site estimate and walk you through the options that match your needs and budget.</div>
  </div>
</section>

<!-- ══════════════════════════════════════
     BRAND LOGOS
     ══════════════════════════════════════ -->
<BrandLogos />

<!-- ══════════════════════════════════════
     CTA BANNER
     ══════════════════════════════════════ -->
<div class="bp-cta fade-in">
  <h2>Ready to transform your <em>Philadelphia property?</em></h2>
  <div class="bp-cta__btns">
    <a href="/contact/" class="bp-btn bp-btn--white">Get a Free Quote</a>
    <a href="tel:+12673947980" class="bp-btn bp-btn--green">Call (267) 394-7980</a>
  </div>
</div>

</div><!-- end ip-page-body -->

</BaseLayout>

<style>
/* ── PAGE BODY WRAPPER ── */
.ip-page-body {
  position: relative;
  background: #ffffff;
  border-top-left-radius: 40px;
  border-top-right-radius: 40px;
  border-bottom-left-radius: 40px;
  border-bottom-right-radius: 40px;
  margin-top: -40px;
  z-index: 10;
  overflow: visible;
  padding-bottom: 80px;
}

/* ── EYEBROW ── */
.bp-eyebrow {
  display: inline-block;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--green, #81AB4C);
  margin-bottom: 16px;
}

/* ── BUTTONS ── */
.bp-btn {
  display: inline-block; padding: 14px 28px;
  border-radius: var(--radius-pill, 100px);
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; font-weight: 500;
  text-decoration: none; transition: all 0.2s;
  border: 2px solid transparent; white-space: nowrap;
}
.bp-btn--primary { background: var(--green, #81AB4C); color: #fff; border-color: var(--green, #81AB4C); }
.bp-btn--primary:hover { background: #6e9640; border-color: #6e9640; transform: translateY(-2px); color: #fff; }
.bp-btn--ghost { background: transparent; color: var(--brand, #272E32); border-color: var(--brand, #272E32); }
.bp-btn--ghost:hover { background: var(--brand, #272E32); color: #fff; transform: translateY(-2px); }
.bp-btn--white { background: #fff; color: var(--brand, #272E32); border-color: #fff; font-weight: 600; }
.bp-btn--white:hover { background: var(--off-white, #F7F6F3); transform: translateY(-2px); }
.bp-btn--green { background: var(--green, #81AB4C); color: #fff; border-color: var(--green, #81AB4C); }
.bp-btn--green:hover { background: #6e9640; transform: translateY(-2px); color: #fff; }

/* ── INTRO ── */
.bp-intro {
  padding: 80px 10%;
  border-top-left-radius: 40px;
  border-top-right-radius: 40px;
  overflow: hidden;
}
.bp-intro__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}
.bp-intro__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(36px, 4.5vw, 58px);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -1px;
  color: var(--text-dark, #1a1a1a);
  margin: 0;
}
.bp-intro__lead {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 17px;
  color: var(--text-mid, #4a4a4a);
  line-height: 1.75;
  margin-bottom: 32px;
}
.bp-intro__ctas { display: flex; gap: 14px; flex-wrap: wrap; }

/* ── STATS ── */
.bp-stats {
  background: #ffffff;
  padding: 80px 10%;
}
.bp-stats__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  align-items: stretch;
}
.bp-stats__hero-img {
  border-radius: 32px;
  overflow: hidden;
  min-height: 500px;
}
.bp-stats__hero-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.bp-stats__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  gap: 16px;
  height: 100%;
}
.bp-stat-card {
  background: var(--off-white, #F7F6F3);
  border-radius: 24px;
  padding: 28px 28px 32px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.bp-stat-card--img {
  padding: 0;
  overflow: hidden;
}
.bp-stat-card--img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.bp-stat-card__label {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text-light, #888);
  margin-bottom: 10px;
}
.bp-stat-card__rule {
  width: 100%;
  height: 1px;
  background: var(--light-gray, #EFEFED);
}
.bp-stat-card__num {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(44px, 4vw, 64px);
  font-weight: 700;
  color: var(--text-dark, #1a1a1a);
  line-height: 1;
  margin-bottom: 10px;
}
.bp-stat-card__accent {
  color: var(--green, #81AB4C);
}
.bp-stat-card__sub {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px;
  color: var(--text-light, #888);
  line-height: 1.4;
}

/* ── FEATURED APPLICATIONS ── */
.bp-featured {
  padding: 100px 10%;
  background: var(--off-white, #F7F6F3);
}
.bp-featured__hd {
  margin-bottom: 72px;
}
.bp-featured__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(32px, 4vw, 52px);
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: -0.5px;
  color: var(--text-dark, #1a1a1a);
  margin: 0;
}
.bp-feat-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  margin-bottom: 100px;
}
.bp-feat-row:last-child { margin-bottom: 0; }
.bp-feat-row--rev .bp-feat-row__img { order: 2; }
.bp-feat-row--rev .bp-feat-row__content { order: 1; }
.bp-feat-row__img {
  position: relative;
  height: 480px;
  border-radius: 32px;
  overflow: hidden;
}
.bp-feat-row__img img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}
.bp-feat-row__pill {
  position: absolute; bottom: 24px; left: 24px;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(8px);
  padding: 10px 18px;
  border-radius: 100px;
  font-family: var(--font-body, 'DM Sans', sans-serif);
