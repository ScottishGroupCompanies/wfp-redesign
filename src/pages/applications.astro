---
import BaseLayout from '../layouts/BaseLayout.astro';
import BackAndForthSection from '../components/BackAndForthSection.astro';

const title = 'Applications | Window Film Philadelphia | Leading Window Film Solutions';
const description = 'Window Film Philadelphia offers leading window film solutions available for many applications in any industry. Get your free quote today!';
---

<BaseLayout title={title} description={description} canonical='https://www.windowfilmphiladelphia.net/applications/'>
  <section class="page-hero" style="background-image: linear-gradient(rgba(0,30,90,0.72), rgba(0,30,90,0.88)), url('/images/2021-09-office-window-film-philadelphia.jpg'); background-size: cover; background-position: center;">
    <div class="container">
      <h1>A Revolutionary Approach to Architecture</h1>
    </div>
  </section>

  <BackAndForthSection
  heading={'A Revolutionary Approach to Architecture'}
  body={'Window Film offers an innovative solution that any residential or commercial property throughout the Philadelphia area can take advantage of. With leading money-saving solutions that address a wide array of property dysfunction, property owners can achieve their goals and transform their spaces with this effective, affordable investment.'}
  imageSrc={'/images/2021-09-office-window-film-philadelphia.jpg'}
  imageAlt={'office window film philadelphia'}
  flip={false}
  altBg={false}
/>

  <BackAndForthSection
  heading={'Office Buildings'}
  body={'From high-rise office buildings in Kensington to co-working spaces in North Philadelphia, window film provides exclusive benefits that can help improve your work space. Address workplace comfort, improve productivity, save money, and more with these exclusive office-designed window film solutions.'}
  imageSrc={'/images/2021-09-retail-window-film-philadelphia.jpg'}
  imageAlt={'retail window film philadelphia'}
  flip={true}
  altBg={true}
/>

  <BackAndForthSection
  heading={'Retail Stores & Malls'}
  body={'Brick and mortar retail storefronts have to prioritize the guest experience in order to capitalize on their commercial real estate investment. From decorative window film for custom brand visibility to UV protection for optimal storefront displays, window film has extensive benefits that any retail location can benefit from.'}
  imageSrc={'/images/2021-09-hotel-window-film-philadelphia.jpg'}
  imageAlt={'hotel window film philadelphia'}
  flip={false}
  altBg={false}
/>

  <BackAndForthSection
  heading={'Hotel & Hospitality'}
  body={'Keep your guests ultra-comfortable throughout your hotel or hospitality establishment in order to keep them coming back. Window film offers numerous benefits for hotel properties, ranging from privacy solutions to improved guest experience. Make the most out of your building with our money-saving investments.'}
  imageSrc={'/images/2021-09-restaurant-window-film-philadelphia.jpg'}
  imageAlt={'restaurant window film philadelphia'}
  flip={true}
  altBg={true}
/>

  <BackAndForthSection
  heading={'Restaurants'}
  body={'Philadelphia is known for having an incredible restaurant scene that’s noteworthy for locals and travelers alike. While food is king, making sure the dining experience is up to par is also crucial for setting the ambiance. Window film can provide incredible advantages for restaurants located in South Philadelphia to cafes in Old City.'}
  imageSrc={'/images/2021-09-classroom-window-film-philadelphia.jpg'}
  imageAlt={'classroom window film philadelphia'}
  flip={false}
  altBg={false}
/>

  <BackAndForthSection
  heading={'Schools & Universities'}
  body={'Schools and universities can utilize our leading, money-saving solutions for optimizing security, improving productivity, and enhancing the learning environment. From daylight redirecting window film to safety and security options, we can help you transform your school in order to create the best teaching and learning experience.'}
  imageSrc={'/images/2021-09-arena-window-film-philadelphia.jpg'}
  imageAlt={'arena window film philadelphia'}
  flip={true}
  altBg={true}
/>

  <BackAndForthSection
  heading={'Arenas, Venues & Stadiums'}
  body={'In order to keep sports stadiums, venues, and arenas comfortable for the tens of thousands of occupants it can hold, it can cost a fortune. Window film helps these properties save money while keeping everyone safe and comfortable. Create the perfect events space with these leading solutions.'}
  imageSrc={'/images/2021-09-secured-building-window-film-philadelphia.jpg'}
  imageAlt={'secured building window film philadelphia'}
  flip={false}
  altBg={false}
/>

  <BackAndForthSection
  heading={'Secured Buildings'}
  body={'Secured properties including banks, police stations, military bases, and data centers can all utilize window film to address safety, improve privacy, and more. Enjoy exclusive benefits for securing your building and ensuring all your needs are met.'}
  imageSrc={'/images/2021-09-mass-transit-window-film-philadelphia.jpg'}
  imageAlt={'mass transit window film philadelphia'}
  flip={true}
  altBg={true}
/>

  <section class="cta-strip">
    <div class="container">
      <h2>Get Your Free Quote Today</h2>
      <p>Philadelphia&#39;s leading window film contractor. Contact us for a free consultation and estimate.</p>
      <a href="/contact/" class="btn btn--accent">Contact Us</a>
    </div>
  </section>
</BaseLayout>
