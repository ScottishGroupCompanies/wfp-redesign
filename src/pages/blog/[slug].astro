---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BrandLogos from '../../components/BrandLogos.astro';
import InnerPageHero from '../../components/InnerPageHero.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const { title, description, pubDate, author, image, imageAlt, tags } = post.data;

// Recent posts for sidebar (exclude current)
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = allPosts
  .filter((p) => p.slug !== post.slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const canonical = `https://www.windowfilmphiladelphia.net/blog/${post.slug}/`;

const categories = [
  { label: 'Energy Savings',         href: '/benefits/energy-savings/' },
  { label: 'UV Blocking',            href: '/benefits/uv-blocking-window-film-philadelphia/' },
  { label: 'Glare Reduction',        href: '/benefits/glare-reduction/' },
  { label: 'Safety & Security',      href: '/benefits/safety-and-security/' },
  { label: 'Privacy Film',           href: '/benefits/privacy-window-film-philadelphia/' },
  { label: 'Anti-Graffiti',          href: '/benefits/anti-graffiti/' },
  { label: 'Decorative Film',        href: '/benefits/decorative-promotional/' },
  { label: 'School Security',        href: '/benefits/school-security-window-film/' },
  { label: 'Bird Strike Prevention', href: '/benefits/bird-strike-prevention/' },
  { label: 'Blast Mitigation',       href: '/benefits/blast-mitigation/' },
  { label: 'Ballistic Resistance',   href: '/benefits/ballistic-resistance/' },
  { label: 'Exterior Film',          href: '/benefits/exterior-window-film/' },
  { label: 'Building Wraps',         href: '/benefits/exterior-building-wraps/' },
  { label: 'Elevator Refinishing',   href: '/benefits/elevator-refinishing/' },
  { label: 'Mirror Refinishing',     href: '/benefits/mirror-refinishing/' },
  { label: 'Surface Updates',        href: '/benefits/updating-surfaces/' },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>

<InnerPageHero
  title={title}
  bgImage={image || '/images/wfp-premium-films-v2.jpg'}
  desc={formatDate(pubDate)}
/>

<div class="ip-page-body">

  <!-- ══════════════════════════════════════
       META BAR — full width
       ══════════════════════════════════════ -->
  <div class="post-meta-bar">
    <a href="/blog/" class="post-back">&#8592; Back to Blog</a>
    <div class="post-meta-right">
      <div class="post-meta-info">
        <span class="post-author">By {author}</span>
        <span class="post-sep">&#183;</span>
        <span class="post-date">{formatDate(pubDate)}</span>
      </div>
      {tags && tags.length > 0 && (
        <div class="post-tags">
          {tags.map((tag) => (
            <span class="post-tag">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </div>

  <!-- ══════════════════════════════════════
       2-COL LAYOUT: article + sidebar
       ══════════════════════════════════════ -->
  <div class="post-layout">

    <!-- ── MAIN ARTICLE ── -->
    <main class="post-main">

      {image && (
        <div class="post-featured-img">
          <img src={image} alt={imageAlt || title} width="860" height="500" loading="eager" />
        </div>
      )}

      <article class="post-prose">
        <Content />
      </article>

    </main>

    <!-- ── SIDEBAR ── -->
    <aside class="post-sidebar">

      <!-- CTA image card -->
      <div class="ip-sidebar-cta-card">
        <div class="ip-sidebar-cta-card__bg" style="background-image: url('/images/2021-09-hotel-window-film-philadelphia.webp')">
          <div class="ip-sidebar-cta-card__overlay"></div>
          <div class="ip-sidebar-cta-card__content">
            <p class="ip-sidebar-cta-card__label">Any Questions? Let's talk</p>
            <a href="tel:+12673947980" class="ip-sidebar-cta-card__phone">(267) 394-7980</a>
            <a href="/contact/" class="ip-sidebar-cta-card__btn">Get a Free Quote &rarr;</a>
          </div>
        </div>
      </div>

      <!-- Browse by Topic (benefit categories) -->
      <div class="ip-sidebar-cats">
        <h4 class="ip-sidebar-cats__title">Browse by Topic</h4>
        <ul class="ip-sidebar-cats__list">
          {categories.map((cat) => (
            <li>
              <a href={cat.href} class="ip-sidebar-cat-link">{cat.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Recent Posts -->
      {recentPosts.length > 0 && (
        <div class="ip-sidebar-recent">
          <h4 class="ip-sidebar-recent__title">Recent Posts</h4>
          <ul class="ip-sidebar-recent__list">
            {recentPosts.map((rp) => (
              <li class="ip-sidebar-recent__item">
                {rp.data.image && (
                  <a href={`/blog/${rp.slug}/`} class="ip-sidebar-recent__thumb">
                    <img src={rp.data.image} alt={rp.data.imageAlt || rp.data.title} loading="lazy" />
                  </a>
                )}
                <div class="ip-sidebar-recent__body">
                  <span class="ip-sidebar-recent__date">{formatDate(rp.data.pubDate)}</span>
                  <a href={`/blog/${rp.slug}/`} class="ip-sidebar-recent__link">{rp.data.title}</a>
                </div>
              </li>
            ))}
          </ul>
        </div>
      )}

    </aside>
  </div><!-- end post-layout -->

  <!-- ══════════════════════════════════════
       BRAND LOGOS + CTA
       ══════════════════════════════════════ -->
  <BrandLogos />

  <div class="ip-cta">
    <h2>Ready to transform your <em>windows?</em></h2>
    <div class="ip-cta__btns">
      <a href="/contact/" class="ip-btn ip-btn--white">Get a Free Quote</a>
      <a href="tel:+12673947980" class="ip-btn ip-btn--green">Call (267) 394-7980</a>
    </div>
  </div>

</div><!-- end ip-page-body -->

</BaseLayout>

<style>
/* ── PAGE BODY WRAPPER ── */
.ip-page-body {
  position: relative;
  background: #ffffff;
  border-top-left-radius: 40px;
  border-top-right-radius: 40px;
  border-bottom-left-radius: 40px;
  border-bottom-right-radius: 40px;
  margin-top: -40px;
  z-index: 10;
  overflow: visible;
  padding-bottom: 80px;
}

/* ── META BAR ── */
.post-meta-bar {
  padding: 36px 5% 28px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
  border-bottom: 1px solid var(--light-gray, #EFEFED);
}
.post-back {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 14px; font-weight: 600;
  color: var(--green, #81AB4C);
  text-decoration: none;
}
.post-back:hover { text-decoration: underline; }
.post-meta-right {
  display: flex; align-items: center; gap: 14px; flex-wrap: wrap;
}
.post-meta-info {
  display: flex; align-items: center; gap: 8px;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 14px; color: var(--text-light, #888);
}
.post-author { font-weight: 600; color: var(--text-mid, #4a4a4a); }
.post-sep { color: var(--light-gray, #ccc); }
.post-tags { display: flex; gap: 6px; flex-wrap: wrap; }
.post-tag {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 11px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 1px;
  color: var(--green, #81AB4C);
  background: var(--green-light, #eef4e4);
  padding: 4px 10px;
  border-radius: var(--radius-pill, 100px);
}

/* ── 2-COL LAYOUT ── */
.post-layout {
  padding: 0 5%;
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: 60px;
  align-items: start;
}
.post-main { padding: 56px 0; }
.post-sidebar {
  padding: 56px 0;
  position: sticky;
  top: 100px;
  align-self: start;
}

/* ── FEATURED IMAGE ── */
.post-featured-img {
  width: 100%;
  border-radius: var(--radius-xl, 40px);
  overflow: hidden;
  margin-bottom: 48px;
  aspect-ratio: 16 / 9;
}
.post-featured-img img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}

/* ── PROSE CONTENT ── */
.post-prose { font-family: var(--font-body, 'DM Sans', sans-serif); }

.post-prose :global(h2) {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(22px, 2.5vw, 32px);
  font-weight: 700; letter-spacing: -0.3px; line-height: 1.2;
  color: var(--text-dark, #1a1a1a); margin: 44px 0 14px;
}
.post-prose :global(h2:first-child) { margin-top: 0; }
.post-prose :global(h3) {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(18px, 2vw, 26px);
  font-weight: 700; line-height: 1.25;
  color: var(--text-dark, #1a1a1a); margin: 32px 0 10px;
}
.post-prose :global(p) {
  font-size: 17px; line-height: 1.85;
  color: var(--text-mid, #4a4a4a); margin-bottom: 20px;
}
.post-prose :global(a) {
  color: var(--green, #81AB4C);
  text-decoration: underline; text-underline-offset: 3px; transition: color 0.2s;
}
.post-prose :global(a:hover) { color: #6e9640; }
.post-prose :global(ul), .post-prose :global(ol) {
  padding-left: 0; margin-bottom: 20px; list-style: none;
}
.post-prose :global(ul li) {
  display: flex; align-items: flex-start; gap: 10px;
  font-size: 16px; color: var(--text-mid, #4a4a4a);
  line-height: 1.7; padding: 4px 0;
}
.post-prose :global(ul li::before) {
  content: ''; display: inline-block;
  width: 7px; height: 7px; border-radius: 50%;
  background: var(--green, #81AB4C); margin-top: 9px; flex-shrink: 0;
}
.post-prose :global(blockquote) {
  border-left: 4px solid var(--green, #81AB4C);
  background: var(--green-light, #eef4e4);
  border-radius: 0 var(--radius-md, 16px) var(--radius-md, 16px) 0;
  padding: 20px 24px; margin: 28px 0;
}
.post-prose :global(blockquote p) { font-size: 16px; color: #3a5a1f; margin: 0; }
.post-prose :global(hr) {
  border: none; border-top: 1px solid var(--light-gray, #EFEFED); margin: 36px 0;
}
.post-prose :global(strong) { font-weight: 700; color: var(--text-dark, #1a1a1a); }
.post-prose :global(em) { font-style: italic; }

/* ── SIDEBAR CTA CARD ── */
.ip-sidebar-cta-card {
  border-radius: 20px; overflow: hidden; margin-bottom: 20px;
}
.ip-sidebar-cta-card__bg {
  position: relative; background-size: cover; background-position: center;
  padding: 40px 28px; min-height: 260px;
  display: flex; align-items: flex-end;
}
.ip-sidebar-cta-card__overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.72) 100%);
  border-radius: 20px;
}
.ip-sidebar-cta-card__content {
  position: relative; z-index: 2;
  display: flex; flex-direction: column; gap: 8px;
}
.ip-sidebar-cta-card__label {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px; color: rgba(255,255,255,0.75); margin: 0;
}
.ip-sidebar-cta-card__phone {
  font-family: var(--font-serif);
  font-size: 24px; font-weight: 700; color: #fff;
  text-decoration: none; line-height: 1.1;
}
.ip-sidebar-cta-card__btn {
  display: inline-block; margin-top: 8px;
  background: var(--green, #81AB4C); color: #fff;
  padding: 10px 20px; border-radius: 100px;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px; font-weight: 600; text-decoration: none; width: fit-content;
}

/* ── SIDEBAR CATEGORIES ── */
.ip-sidebar-cats {
  background: transparent;
  border: 1px solid var(--light-gray, #EFEFED);
  border-radius: 20px; padding: 24px; margin-bottom: 20px;
}
.ip-sidebar-cats__title {
  font-family: var(--font-serif);
  font-size: clamp(17px, 2vw, 20px);
  font-weight: 700; color: #111; margin-bottom: 12px;
}
.ip-sidebar-cats__list { list-style: none; padding: 0; margin: 0; }
.ip-sidebar-cats__list li { border-bottom: 1px solid var(--light-gray, #EFEFED); }
.ip-sidebar-cats__list li:last-child { border-bottom: none; }
.ip-sidebar-cat-link {
  display: flex; justify-content: space-between; align-items: center;
  padding: 9px 12px; border-radius: 8px;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 14px; font-weight: 500;
  color: var(--text-dark, #1a1a1a);
  text-decoration: none; transition: all 0.2s;
}
.ip-sidebar-cat-link::after {
  content: '→'; font-size: 12px; color: var(--text-light, #888); transition: color 0.2s;
}
.ip-sidebar-cat-link:hover {
  background: var(--green, #81AB4C); color: #fff;
}
.ip-sidebar-cat-link:hover::after { color: rgba(255,255,255,0.75); }

/* ── SIDEBAR RECENT POSTS ── */
.ip-sidebar-recent {
  background: var(--off-white, #F7F6F3);
  border-radius: 20px; padding: 24px;
}
.ip-sidebar-recent__title {
  font-family: var(--font-serif);
  font-size: clamp(17px, 2vw, 20px);
  font-weight: 700; color: #111; margin-bottom: 16px;
}
.ip-sidebar-recent__list { list-style: none; padding: 0; margin: 0; }
.ip-sidebar-recent__item {
  display: flex; gap: 14px; align-items: flex-start;
  padding: 12px 0; border-bottom: 1px solid var(--light-gray, #EFEFED);
}
.ip-sidebar-recent__item:last-child { border-bottom: none; padding-bottom: 0; }
.ip-sidebar-recent__thumb {
  width: 64px; height: 64px; border-radius: 10px;
  overflow: hidden; flex-shrink: 0; display: block;
}
.ip-sidebar-recent__thumb img {
  width: 100%; height: 100%; object-fit: cover; display: block;
}
.ip-sidebar-recent__body {
  display: flex; flex-direction: column; gap: 4px; min-width: 0;
}
.ip-sidebar-recent__date {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 11px; color: var(--text-light, #888); font-weight: 500;
}
.ip-sidebar-recent__link {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px; font-weight: 600; color: var(--text-dark, #1a1a1a);
  text-decoration: none; line-height: 1.4;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  transition: color 0.2s;
}
.ip-sidebar-recent__link:hover { color: var(--green, #81AB4C); }

/* ── Buttons ── */
.ip-btn {
  display: inline-block; padding: 14px 28px;
  border-radius: var(--radius-pill, 100px);
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; font-weight: 500;
  text-decoration: none; transition: all 0.2s;
  border: 2px solid transparent; white-space: nowrap;
}
.ip-btn--white {
  background: #fff; color: var(--brand, #272E32);
  border-color: #fff; font-weight: 600;
}
.ip-btn--white:hover {
  background: var(--off-white, #F7F6F3); transform: translateY(-2px);
  color: var(--brand, #272E32);
}
.ip-btn--green {
  background: var(--green, #81AB4C); color: #fff; border-color: var(--green, #81AB4C);
}
.ip-btn--green:hover { background: #6e9640; transform: translateY(-2px); color: #fff; }

/* ── CTA BANNER ── */
.ip-cta {
  background: var(--brand, #272E32); border-radius: var(--radius-xl, 40px);
  padding: 64px 60px; display: flex; align-items: center;
  justify-content: space-between; gap: 40px; margin: 0 5%;
}
.ip-cta h2 {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 32px; font-weight: 600; color: #fff;
  line-height: 1.2; max-width: 460px; margin: 0;
}
.ip-cta h2 em { font-style: italic; color: var(--green, #81AB4C); }
.ip-cta__btns { display: flex; gap: 14px; flex-shrink: 0; }

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
  .post-layout { grid-template-columns: 1fr; }
  .post-sidebar { position: static; padding-top: 0; }
}
@media (max-width: 768px) {
  .post-meta-bar { flex-direction: column; align-items: flex-start; gap: 10px; }
  .post-meta-right { flex-direction: column; align-items: flex-start; }
  .post-featured-img { border-radius: var(--radius-lg, 24px); }
  .ip-cta { flex-direction: column; padding: 40px 28px; text-align: center; }
  .ip-cta h2 { font-size: 26px; max-width: 100%; }
  .ip-cta__btns { flex-direction: column; width: 100%; }
}
</style>
