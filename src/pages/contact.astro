---
import BaseLayout from '../layouts/BaseLayout.astro';
import InnerPageHero from '../components/InnerPageHero.astro';
import BrandLogos from '../components/BrandLogos.astro';

const title = 'Contact Window Film Philadelphia | Free Estimate';
const description = 'Contact Window Film Philadelphia to schedule your free on-site consultation and estimate. Serving Philadelphia, Camden, Reading, and the surrounding metro area.';
---

<BaseLayout title={title} description={description} canonical="https://www.windowfilmphiladelphia.net/contact/">

<InnerPageHero
  title="Contact Window Film Philadelphia"
  bgImage="/images/window-film-contractor-philadelphia.webp"
  desc="Request a free consultation and estimate for your property."
/>

<div class="ip-page-body">

<!-- ══════════════════════════════════════
     CONTACT CARDS — 3-col
     ══════════════════════════════════════ -->
<section class="ct-cards">
  <div class="ct-cards__grid">

    <div class="ct-card">
      <div class="ct-card__icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
          <rect width="20" height="16" x="2" y="4" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </div>
      <p class="ct-card__label">Support Email</p>
      <p class="ct-card__value">contact@windowfilmphiladelphia.net</p>
      <a href="mailto:contact@windowfilmphiladelphia.net" class="ct-card__btn">Email Us</a>
    </div>

    <div class="ct-card">
      <div class="ct-card__icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.18 6.18l.93-.93a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
      </div>
      <p class="ct-card__label">Phone Number</p>
      <p class="ct-card__value">(267) 394-7980</p>
      <a href="tel:+12673947980" class="ct-card__btn">Call Us</a>
    </div>

    <div class="ct-card">
      <div class="ct-card__icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
      </div>
      <p class="ct-card__label">Location</p>
      <p class="ct-card__value">Philadelphia, PA &amp; surrounding counties</p>
      <a href="https://maps.google.com/?q=Philadelphia,PA" target="_blank" rel="noopener" class="ct-card__btn">Visit Us</a>
    </div>

  </div>
</section>

<!-- ══════════════════════════════════════
     FORM + MAP — 2-col
     ══════════════════════════════════════ -->
<section class="ct-main">
  <div class="ct-main__inner">

    <div class="ct-form-wrap">
      <h2 class="ct-form__heading">Leave a message</h2>

      <form
        class="ct-form"
        action="https://formsubmit.co/contact@windowfilmphiladelphia.net"
        method="POST"
      >
        <input type="hidden" name="_next" value="https://www.windowfilmphiladelphia.net/thank-you/" />
        <input type="hidden" name="_subject" value="New Contact Form Submission — Window Film Philadelphia" />
        <input type="hidden" name="_captcha" value="false" />

        <div class="ct-form__row">
          <div class="ct-form__field">
            <input type="text" name="first_name" placeholder="First Name*" required class="ct-form__input" />
          </div>
          <div class="ct-form__field">
            <input type="text" name="last_name" placeholder="Last Name*" required class="ct-form__input" />
          </div>
        </div>

        <div class="ct-form__field">
          <input type="email" name="email" placeholder="Email*" required class="ct-form__input" />
        </div>

        <div class="ct-form__field">
          <input type="tel" name="phone" placeholder="Phone Number" class="ct-form__input" />
        </div>

        <div class="ct-form__field">
          <textarea name="message" placeholder="Message..." rows="6" required class="ct-form__input ct-form__textarea"></textarea>
        </div>

        <button type="submit" class="ct-form__submit" id="ct-submit-btn">
          <span>Submit</span>
          <span class="ct-form__submit-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M7 17 17 7M7 7h10v10"/></svg>
          </span>
        </button>
      </form>

      <!-- PROMPT CARD -->
      <div class="ai-prompt-card" id="ai-prompt-card">
        <div class="ai-prompt-card__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <p class="ai-prompt-card__text">Before we send your message — would you like to tell us a bit more about your window film project? It takes about a minute and helps us prepare a more accurate estimate.</p>
        <div class="ai-prompt-card__actions">
          <button class="ai-prompt-card__yes" id="ai-yes-btn">Yes, tell us more</button>
          <button class="ai-prompt-card__no" id="ai-no-btn">No thanks, just submit</button>
        </div>
      </div>

      <!-- CHAT WIDGET -->
      <div class="ai-chat" id="ai-chat">
        <div class="ai-chat__header">
          <span class="ai-chat__header-dot" aria-hidden="true"></span>
          <span class="ai-chat__header-label">Window Film Project Inquiry</span>
        </div>
        <div class="ai-chat__messages" id="ai-chat-messages"></div>
        <div class="ai-chat__quick-replies" id="ai-quick-replies"></div>
        <div class="ai-chat__input-row" id="ai-input-row">
          <input type="text" class="ai-chat__input" id="ai-chat-input" placeholder="Type your answer…" />
          <button class="ai-chat__send" id="ai-chat-send" aria-label="Send">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 2 11 13M22 2 15 22 11 13 2 9l20-7z"/></svg>
          </button>
        </div>
      </div>

      <!-- SUCCESS MESSAGE -->
      <div class="ai-success" id="ai-success">
        <div class="ai-success__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
        </div>
        <h3 class="ai-success__title">Message sent!</h3>
        <p class="ai-success__text">Thanks for reaching out. We'll review your project details and get back to you shortly.</p>
      </div>

    </div>

    <div class="ct-map-wrap">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d196281.2729651692!2d-75.28140900000001!3d39.9525839!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c6b7d8d4b54beb%3A0x89cb5f4e72af6b4f!2sPhiladelphia%2C%20PA!5e0!3m2!1sen!2sus!4v1716000000000!5m2!1sen!2sus"
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Window Film Philadelphia service area map"
      ></iframe>
    </div>

  </div>
</section>

<!-- ══════════════════════════════════════
     BRAND LOGOS
     ══════════════════════════════════════ -->
<BrandLogos />

</div><!-- end ip-page-body -->

</BaseLayout>

<script define:vars={{ geminiKey: import.meta.env.PUBLIC_GEMINI_KEY }}>
(function () {
  const GEMINI_KEY = geminiKey || '';
  const FORMSUBMIT_URL = 'https://formsubmit.co/ajax/contact@windowfilmphiladelphia.net';

  const SYSTEM_PROMPT = `You are a friendly intake assistant for Window Film Philadelphia, a professional window film contractor serving residential and commercial properties in the Philadelphia metro area. Ask one question at a time in this exact order: (1) Is this a residential or commercial project? (2) What type of film are you looking for? Give these exact options: Sun Control, Privacy, or Security. (3) Can you list each window and its approximate square footage? (4) Are any of these windows more than 8 feet off the ground? (5) Do any of the windows have existing window film on them already? (6) What city or neighborhood is the project in? (7) Any urgency or timeline? After all 7 questions are answered, thank them warmly and output a JSON object wrapped in <SUMMARY> tags like: <SUMMARY>{"project_type":"...","film_type":"...","windows":"...","high_windows":"...","existing_film":"...","location":"...","timeline":"..."}</SUMMARY>`;

  const SCRIPTED_QUESTIONS = [
    { text: 'Is this a residential or commercial project?', replies: ['Residential', 'Commercial'] },
    { text: 'What type of film are you looking for?', replies: ['Sun Control', 'Privacy', 'Security'] },
    { text: 'Can you list each window and its approximate square footage? For example: \'Living room – 40 sq ft, 2 bedroom windows – 15 sq ft each\'. A rough estimate is totally fine!', replies: [] },
    { text: 'Are any of these windows more than 8 feet off the ground?', replies: ['Yes', 'No', 'Not sure'] },
    { text: 'Do any of the windows have existing window film on them already?', replies: ['Yes', 'No', 'Not sure'] },
    { text: 'What city or neighborhood is the project in?', replies: ['Philadelphia', 'South Philly', 'Center City', 'NE Philly', 'Camden, NJ', 'Montgomery County', 'Other'] },
    { text: 'Last one — any urgency or timeline we should know about?', replies: ['ASAP', 'Within a month', '1–3 months', 'Just exploring'] },
  ];

  const QUESTION_LABELS = [
    'Project Type',
    'Film Type',
    'Window Details',
    'High Windows (8ft+)',
    'Existing Film',
    'Location',
    'Timeline',
  ];

  const form        = document.querySelector('.ct-form');
  const submitBtn   = document.getElementById('ct-submit-btn');
  const promptCard  = document.getElementById('ai-prompt-card');
  const yesBtn      = document.getElementById('ai-yes-btn');
  const noBtn       = document.getElementById('ai-no-btn');
  const chatWidget  = document.getElementById('ai-chat');
  const messagesEl  = document.getElementById('ai-chat-messages');
  const quickReplies= document.getElementById('ai-quick-replies');
  const inputRow    = document.getElementById('ai-input-row');
  const chatInput   = document.getElementById('ai-chat-input');
  const sendBtn     = document.getElementById('ai-chat-send');
  const successEl   = document.getElementById('ai-success');

  let conversationHistory = [];  // [{role, parts:[{text}]}]
  let scriptedStep = 0;
  let useScripted = !GEMINI_KEY;
  let chatTranscript = [];
  let pendingSubmit = false;

  function show(el, displayType) { el.style.display = displayType || 'flex'; }
  function hide(el) { el.style.display = 'none'; }

  // --- intercept form submit ---
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    show(promptCard);
    promptCard.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });

  noBtn.addEventListener('click', function () {
    hide(promptCard);
    doSubmit('');
  });

  yesBtn.addEventListener('click', function () {
    hide(promptCard);
    show(chatWidget);
    chatWidget.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    startChat();
  });

  sendBtn.addEventListener('click', handleUserInput);
  chatInput.addEventListener('keydown', function (e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); handleUserInput(); }
  });

  function startChat() {
    if (useScripted) {
      addMessage('bot', SCRIPTED_QUESTIONS[0].text);
      showQuickReplies(SCRIPTED_QUESTIONS[0].replies);
      scriptedStep = 0;
    } else {
      callGemini(null);
    }
  }

  function handleUserInput(textOverride) {
    const text = typeof textOverride === 'string' ? textOverride : chatInput.value.trim();
    if (!text) return;
    chatInput.value = '';
    addMessage('user', text);

    // label the answer using the current question index
    if (useScripted) {
      const label = QUESTION_LABELS[scriptedStep] || 'Response';
      chatTranscript.push(label + ': ' + text);
    } else {
      const modelTurns = conversationHistory.filter(m => m.role === 'model').length;
      const label = QUESTION_LABELS[modelTurns] || 'Response';
      chatTranscript.push(label + ': ' + text);
    }

    clearQuickReplies();
    hideInput();

    if (useScripted) {
      handleScriptedFlow(text);
    } else {
      callGemini(text);
    }
  }

  function handleScriptedFlow(userText) {
    scriptedStep++;
    if (scriptedStep >= SCRIPTED_QUESTIONS.length) {
      finishChat();
    } else {
      setTimeout(function () {
        const q = SCRIPTED_QUESTIONS[scriptedStep];
        addMessage('bot', q.text);
        showQuickReplies(q.replies);
        if (q.replies.length === 0) showInput();
      }, 400);
    }
  }

  async function callGemini(userText) {
    if (userText !== null) {
      conversationHistory.push({ role: 'user', parts: [{ text: userText }] });
    }

    try {
      const body = {
        system_instruction: { parts: [{ text: SYSTEM_PROMPT }] },
        contents: conversationHistory
      };
      const res = await fetch(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${GEMINI_KEY}`,
        { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) }
      );
      if (!res.ok) throw new Error('API error ' + res.status);
      const data = await res.json();
      const replyText = data.candidates?.[0]?.content?.parts?.[0]?.text || '';
      conversationHistory.push({ role: 'model', parts: [{ text: replyText }] });

      if (replyText.includes('<SUMMARY>')) {
        // strip tags and finish
        const clean = replyText.replace(/<SUMMARY>[\s\S]*<\/SUMMARY>/, '').trim();
        if (clean) addMessage('bot', clean);
        finishChat();
      } else {
        addMessage('bot', replyText);
        // determine quick replies from current scripted step mapping
        const qr = getGeminiQuickReplies(conversationHistory.length);
        showQuickReplies(qr);
        if (qr.length === 0) showInput();
      }
    } catch (err) {
      // fallback to scripted
      useScripted = true;
      scriptedStep = Math.max(0, Math.floor(conversationHistory.filter(m => m.role === 'user').length));
      const q = SCRIPTED_QUESTIONS[Math.min(scriptedStep, SCRIPTED_QUESTIONS.length - 1)];
      addMessage('bot', q.text);
      showQuickReplies(q.replies);
      if (q.replies.length === 0) showInput();
    }
  }

  function getGeminiQuickReplies(historyLen) {
    // model responses are at even indices (0-based counting of model turns)
    const modelTurns = conversationHistory.filter(m => m.role === 'model').length;
    const map = [
      ['Residential', 'Commercial'],
      ['Sun Control', 'Privacy', 'Security'],
      [],
      ['Yes', 'No', 'Not sure'],
      ['Yes', 'No', 'Not sure'],
      ['Philadelphia', 'South Philly', 'Center City', 'NE Philly', 'Camden, NJ', 'Montgomery County', 'Other'],
      ['ASAP', 'Within a month', '1–3 months', 'Just exploring'],
    ];
    return map[modelTurns - 1] || [];
  }

  function finishChat() {
    addMessage('bot', 'Thanks! Sending your message now…');
    setTimeout(function () {
      doSubmit(chatTranscript.join('\n'));
    }, 800);
  }

  async function doSubmit(transcript) {
    const firstName = form.querySelector('[name=first_name]').value.trim();
    const lastName  = form.querySelector('[name=last_name]').value.trim();
    const email     = form.querySelector('[name=email]').value.trim();
    const phone     = form.querySelector('[name=phone]').value.trim();
    const baseMsg   = form.querySelector('[name=message]').value.trim();

    const fullMsg = transcript
      ? baseMsg + '\n\n--- Project Details ---\n' + transcript
      : baseMsg;

    // Extract Q1 answer (project type) from transcript for Zoho CRM fields
    const ptEntry = chatTranscript.find(function (t) { return t.startsWith('Project Type: '); });
    const projectType = ptEntry ? ptEntry.replace('Project Type: ', '').trim() : '';

    // ── Zoho CRM WebToLeadForm ──────────────────────────────────────────
    const zohoBody = new URLSearchParams();
    zohoBody.set('xnQsjsdp',    'ec6cc450bd8a4db85070a7eb2f5290d2369347a626942c7cab35f26ed68008ef');
    zohoBody.set('xmIwtLD',     '68d331a3973d119320ef53640350c14a0acaa88becba63a670ea3ba583279be07fa0bfe4674a670ea9a45b066703de40');
    zohoBody.set('actionType',  'TGVhZHM=');
    zohoBody.set('returnURL',   'https://windowfilmphiladelphia.net/thank-you/');
    zohoBody.set('zc_gad',      '');
    zohoBody.set('aG9uZXlwb3Q', '');
    zohoBody.set('First Name',  firstName);
    zohoBody.set('Last Name',   lastName);
    zohoBody.set('Email',       email);
    zohoBody.set('Phone',       phone);
    zohoBody.set('Company',     '');
    zohoBody.set('Summary_of_Call', fullMsg);
    zohoBody.set('Lead Status', 'New');
    zohoBody.set('LEADCF5',     'Web Form');
    zohoBody.set('LEADCF4',     'Website');
    zohoBody.set('LEADCF7',     'www.windowfilmphiladelphia.net');
    zohoBody.set('LEADCF8',     projectType || '-None-');

    const zohoFetch = fetch('https://crm.zoho.com/crm/WebToLeadForm', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: zohoBody.toString(),
    });

    // ── Formsubmit.co backup email ──────────────────────────────────────
    const fsFetch = fetch(FORMSUBMIT_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({
        name:     firstName + ' ' + lastName,
        email:    email,
        phone:    phone,
        message:  fullMsg,
        _subject: 'New Contact Form Submission — Window Film Philadelphia',
      }),
    });

    // Run both in parallel; show success if either succeeds
    const [zohoResult, fsResult] = await Promise.allSettled([zohoFetch, fsFetch]);

    const zohoOk = zohoResult.status === 'fulfilled' && zohoResult.value.ok;
    const fsOk   = fsResult.status === 'fulfilled';

    console.log('[zoho]',       zohoOk ? 'ok' : 'failed', zohoResult.reason || '');
    console.log('[formsubmit]', fsOk   ? 'ok' : 'failed', fsResult.reason   || '');

    if (!zohoOk && !fsOk) {
      console.error('[submission] both endpoints failed');
    }

    // Always show success to user
    hide(form);
    hide(chatWidget);
    hide(promptCard);
    show(successEl);
    successEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  // --- UI helpers ---
  function addMessage(role, text) {
    const wrap = document.createElement('div');
    wrap.className = 'ai-msg ai-msg--' + role;
    const bubble = document.createElement('div');
    bubble.className = 'ai-msg__bubble';
    bubble.textContent = text;
    wrap.appendChild(bubble);
    messagesEl.appendChild(wrap);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function showQuickReplies(replies) {
    quickReplies.innerHTML = '';
    if (!replies || replies.length === 0) { showInput(); return; }
    hideInput();
    replies.forEach(function (r) {
      const btn = document.createElement('button');
      btn.className = 'ai-qr-btn';
      btn.textContent = r;
      btn.addEventListener('click', function () { handleUserInput(r); });
      quickReplies.appendChild(btn);
    });
  }

  function clearQuickReplies() { quickReplies.innerHTML = ''; }
  function showInput()  { show(inputRow); chatInput.focus(); }
  function hideInput()  { hide(inputRow); }
})();
</script>

<style>
/* ── PAGE BODY WRAPPER ── */
.ip-page-body {
  position: relative;
  background: #ffffff;
  border-top-left-radius: 40px;
  border-top-right-radius: 40px;
  border-bottom-left-radius: 40px;
  border-bottom-right-radius: 40px;
  margin-top: -40px;
  z-index: 10;
  overflow: visible;
  padding-bottom: 80px;
}

/* ── CONTACT CARDS ── */
.ct-cards {
  padding: 80px 10% 64px;
  border-top-left-radius: 40px;
  border-top-right-radius: 40px;
}
.ct-cards__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.ct-card {
  border: 1px solid var(--light-gray, #EFEFED);
  border-radius: 24px;
  padding: 36px 32px 32px;
  display: flex;
  flex-direction: column;
  gap: 0;
  background: #fff;
  transition: box-shadow 0.2s, border-color 0.2s;
}
.ct-card:hover {
  border-color: #d0d0ce;
  box-shadow: 0 8px 32px rgba(0,0,0,0.07);
}
.ct-card__icon {
  color: var(--green, #81AB4C);
  margin-bottom: 20px;
  line-height: 1;
}
.ct-card__label {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text-light, #888);
  margin: 0 0 6px;
}
.ct-card__value {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 16px;
  font-weight: 600;
  color: var(--text-dark, #1a1a1a);
  line-height: 1.45;
  margin: 0 0 28px;
  flex: 1;
}
.ct-card__btn {
  display: block;
  text-align: center;
  background: var(--green, #81AB4C);
  color: #fff;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 14px;
  font-weight: 600;
  padding: 13px 24px;
  border-radius: 100px;
  text-decoration: none;
  transition: background 0.2s, transform 0.2s;
}
.ct-card__btn:hover {
  background: #6e9640;
  transform: translateY(-2px);
  color: #fff;
}

/* ── FORM + MAP ── */
.ct-main {
  padding: 0 10% 80px;
}
.ct-main__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: stretch;
}

/* Form */
.ct-form-wrap {
  display: flex;
  flex-direction: column;
}
.ct-form__heading {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(32px, 4vw, 52px);
  font-weight: 700;
  color: var(--text-dark, #1a1a1a);
  line-height: 1.1;
  letter-spacing: -1px;
  margin: 0 0 36px;
}
.ct-form {
  display: flex;
  flex-direction: column;
  gap: 14px;
  flex: 1;
}
.ct-form__row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}
.ct-form__field {
  display: flex;
  flex-direction: column;
}
.ct-form__input {
  background: var(--off-white, #F7F6F3);
  border: 1px solid transparent;
  border-radius: 12px;
  padding: 16px 20px;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px;
  color: var(--text-dark, #1a1a1a);
  outline: none;
  transition: border-color 0.2s, background 0.2s;
  width: 100%;
  box-sizing: border-box;
  resize: none;
}
.ct-form__input::placeholder {
  color: var(--text-light, #888);
}
.ct-form__input:focus {
  border-color: var(--green, #81AB4C);
  background: #fff;
}
.ct-form__textarea {
  min-height: 140px;
  resize: vertical;
}
.ct-form__submit {
  display: inline-flex;
  align-items: center;
  gap: 14px;
  background: none;
  border: none;
  padding: 0;
  cursor: pointer;
  margin-top: 6px;
  width: fit-content;
}
.ct-form__submit span:first-child {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 16px;
  font-weight: 600;
  color: var(--text-dark, #1a1a1a);
  transition: color 0.2s;
}
.ct-form__submit-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  background: var(--brand, #272E32);
  color: #fff;
  border-radius: 50%;
  flex-shrink: 0;
  transition: background 0.2s, transform 0.2s;
}
.ct-form__submit:hover span:first-child { color: var(--green, #81AB4C); }
.ct-form__submit:hover .ct-form__submit-icon {
  background: var(--green, #81AB4C);
  transform: rotate(45deg);
}

/* Map */
.ct-map-wrap {
  border-radius: 24px;
  overflow: hidden;
  min-height: 520px;
  background: var(--off-white, #F7F6F3);
}
.ct-map-wrap iframe {
  display: block;
  width: 100%;
  height: 100%;
  min-height: 520px;
  border: none;
}

/* ── AI ELEMENTS: hidden by default ── */
#ai-prompt-card,
#ai-chat,
#ai-success,
#ai-input-row {
  display: none;
}

/* ── AI PROMPT CARD ── */
.ai-prompt-card {
  margin-top: 28px;
  background: var(--off-white, #F7F6F3);
  border: 1px solid var(--light-gray, #EFEFED);
  border-radius: 24px;
  padding: 32px 28px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.ai-prompt-card__icon {
  color: var(--green, #81AB4C);
  line-height: 1;
}
.ai-prompt-card__text {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px;
  line-height: 1.6;
  color: var(--text-mid, #4a4a4a);
  margin: 0;
}
.ai-prompt-card__actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-top: 4px;
}
.ai-prompt-card__yes,
.ai-prompt-card__no {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 14px;
  font-weight: 600;
  border-radius: 100px;
  padding: 12px 24px;
  cursor: pointer;
  transition: background 0.2s, color 0.2s, border-color 0.2s, transform 0.15s;
  border: none;
}
.ai-prompt-card__yes {
  background: var(--green, #81AB4C);
  color: #fff;
}
.ai-prompt-card__yes:hover {
  background: #6e9640;
  transform: translateY(-1px);
}
.ai-prompt-card__no {
  background: #fff;
  color: var(--text-mid, #4a4a4a);
  border: 1px solid #e0e0e0;
}
.ai-prompt-card__no:hover {
  border-color: var(--green, #81AB4C);
  color: var(--green, #81AB4C);
}

/* ── AI CHAT WIDGET ── */
.ai-chat {
  margin-top: 28px;
  border: 1px solid var(--light-gray, #EFEFED);
  border-radius: 24px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
.ai-chat__header {
  background: var(--brand, #272E32);
  color: #fff;
  padding: 14px 20px;
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.5px;
}
.ai-chat__header-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--green, #81AB4C);
  flex-shrink: 0;
}
.ai-chat__messages {
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  min-height: 220px;
  max-height: 360px;
  overflow-y: auto;
  background: #fff;
}
/* .ai-msg, .ai-msg__bubble, .ai-qr-btn — moved to <style is:global> below
   because these elements are created dynamically in JS and won't receive
   Astro's scoped attribute */
.ai-chat__quick-replies {
  padding: 4px 16px 14px;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  background: #fff;
}
.ai-chat__input-row {
  padding: 12px 16px;
  border-top: 1px solid var(--light-gray, #EFEFED);
  display: flex;
  gap: 10px;
  align-items: center;
  background: #fff;
}
.ai-chat__input {
  flex: 1;
  background: var(--off-white, #F7F6F3);
  border: 1px solid transparent;
  border-radius: 100px;
  padding: 11px 18px;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 14px;
  color: var(--text-dark, #1a1a1a);
  outline: none;
  transition: border-color 0.2s;
}
.ai-chat__input:focus {
  border-color: var(--green, #81AB4C);
  background: #fff;
}
.ai-chat__send {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: var(--brand, #272E32);
  color: #fff;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.2s;
}
.ai-chat__send:hover { background: var(--green, #81AB4C); }

/* ── SUCCESS ── */
.ai-success {
  margin-top: 28px;
  background: #f0f7e8;
  border: 1px solid #c5dfa0;
  border-radius: 24px;
  padding: 40px 32px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 12px;
}
.ai-success__icon {
  color: var(--green, #81AB4C);
  line-height: 1;
}
.ai-success__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 28px;
  font-weight: 700;
  color: var(--text-dark, #1a1a1a);
  margin: 0;
}
.ai-success__text {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px;
  color: var(--text-mid, #4a4a4a);
  margin: 0;
  line-height: 1.6;
}

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
  .ct-main__inner {
    grid-template-columns: 1fr;
    gap: 48px;
  }
  .ct-map-wrap { min-height: 400px; }
  .ct-map-wrap iframe { min-height: 400px; }
}
@media (max-width: 768px) {
  .ct-cards { padding: 60px 5% 48px; }
  .ct-cards__grid { grid-template-columns: 1fr; }
  .ct-main { padding: 0 5% 60px; }
  .ct-form__row { grid-template-columns: 1fr; }
  .ct-map-wrap { min-height: 320px; }
  .ct-map-wrap iframe { min-height: 320px; }
}
</style>

