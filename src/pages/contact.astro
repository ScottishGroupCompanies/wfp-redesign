}
.ai-msg--bot { justify-content: flex-start; }
.ai-msg--user { justify-content: flex-end; }
.ai-msg__bubble {
  max-width: 78%;
  padding: 12px 16px;
  border-radius: 18px;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 14px;
  line-height: 1.55;
}
.ai-msg--bot .ai-msg__bubble {
  background: var(--off-white, #F7F6F3);
  color: var(--text-dark, #1a1a1a);
  border-bottom-left-radius: 4px;
}
.ai-msg--user .ai-msg__bubble {
  background: var(--green, #81AB4C);
  color: #fff;
  border-bottom-right-radius: 4px;
}
.ai-qr-btn {
  -webkit-appearance: none;
  appearance: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  background: var(--green, #81AB4C);
  border: none;
  outline: none;
  border-radius: 100px;
  padding: 9px 20px;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px;
  font-weight: 600;
  color: #fff;
  cursor: pointer;
  line-height: 1;
  white-space: nowrap;
  transition: background 0.15s, transform 0.15s, box-shadow 0.15s;
  text-decoration: none;
}
.ai-qr-btn:hover {
  background: #6e9640;
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(129, 171, 76, 0.3);
}
</style>
