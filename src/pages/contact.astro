---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Contact | Window Film Philadelphia | Leading Window Film Solutions';
const description = 'Window Film Philadelphia is honored to provide comprehensive window film services for Philadelphia. Schedule your free consultation today!';
---

<BaseLayout title={title} description={description} canonical='https://www.windowfilmphiladelphia.net/contact/'>
  <section class="page-hero" style="background-image: linear-gradient(rgba(0,30,90,0.72), rgba(0,30,90,0.88)), url('/images/window-film-contractor-philadelphia.jpg'); background-size: cover; background-position: center;">
    <div class="container">
      <h1>Contact Window Film Philadelphia</h1>
      <p>Request a free consultation and estimate for your property.</p>
    </div>
  </section>

  <section class="contact-section">
    <div class="container">
      <div class="contact-layout">

        <div class="contact-info">
          <h2>Get In Touch</h2>
          <p>Philadelphia's leading commercial and residential window film contractor. Reach out today to discuss your project and schedule a free on-site consultation.</p>

          <ul class="contact-details">
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.568 17.568 0 0 0 4.168 6.608 17.569 17.569 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.678.678 0 0 0-.58-.122l-2.19.547a1.745 1.745 0 0 1-1.657-.459L5.482 8.062a1.745 1.745 0 0 1-.46-1.657l.548-2.19a.678.678 0 0 0-.122-.58L3.654 1.328z"/>
              </svg>
              <a href="tel:+12159995290">215-999-5290</a>
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4Zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1H2Zm13 2.383-4.708 2.825L15 11.105V5.383Zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741ZM1 11.105l4.708-2.897L1 5.383v5.722Z"/>
              </svg>
              <a href="mailto:info@windowfilmphiladelphia.net">info@windowfilmphiladelphia.net</a>
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10zm0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/>
              </svg>
              <span>Philadelphia, PA and surrounding counties</span>
            </li>
          </ul>
        </div>

        <div class="contact-form">
          <script type="text/javascript" src="https://form.jotform.com/jsform/231236977587168"></script>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
.contact-section {
  padding: var(--section-pad-y) 0;
  background: var(--color-bg-light);
}

.contact-layout {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 4rem;
  align-items: start;
}

.contact-info h2 {
  margin-bottom: 1rem;
}

.contact-info p {
  margin-bottom: 1.5rem;
  line-height: 1.7;
}

.contact-details {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.contact-details li {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  color: var(--color-text-secondary);
  font-size: 0.95rem;
  margin-bottom: 0;
}

.contact-details li svg {
  color: var(--color-brand-blue);
  flex-shrink: 0;
}

.contact-details a {
  color: var(--color-brand-blue);
  font-weight: 600;
}

.contact-details a:hover {
  color: var(--color-brand-blue-light);
}

.contact-form {
  background: var(--color-bg-white);
  border-radius: 8px;
  padding: 2rem;
  box-shadow: 0 2px 16px rgba(0,0,0,0.07);
  min-height: 400px;
}

@media (max-width: 800px) {
  .contact-layout {
    grid-template-columns: 1fr;
    gap: 2rem;
  }
}
</style>
