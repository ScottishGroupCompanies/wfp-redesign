---
import BaseLayout from '../layouts/BaseLayout.astro';
import BackAndForthSection from '../components/BackAndForthSection.astro';

const title = 'Contact | Window Film Philadelphia | Leading Window Film Solutions';
const description = 'Window Film Philadelphia is honored to provide comprehensive window film services for Philadelphia. Schedule your free consultation today!';
---

<BaseLayout title={title} description={description} canonical='https://www.windowfilmphiladelphia.net/contact/'>
  <section class="page-hero" style="background-image: linear-gradient(rgba(0,30,90,0.72), rgba(0,30,90,0.88)), url('/images/2021-08-window-film-philadelphia-benefits.jpg'); background-size: cover; background-position: center;">
    <div class="container">
      <h1>Contact</h1>
    </div>
  </section>

  <section class="section-pad">
  <div class="container">
    <h2>Contact</h2>
    <p>Email Us – contact@windowfilmphiladelphia.net Call Us – (267) 394-7980</p>
  </div>
</section>

  <section class="cta-strip">
    <div class="container">
      <h2>Get Your Free Quote Today</h2>
      <p>Philadelphia&#39;s leading window film contractor. Contact us for a free consultation and estimate.</p>
      <a href="/contact/" class="btn btn--accent">Contact Us</a>
    </div>
  </section>
</BaseLayout>
