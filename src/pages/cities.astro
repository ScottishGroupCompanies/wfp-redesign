---
import BaseLayout from '../layouts/BaseLayout.astro';
import BackAndForthSection from '../components/BackAndForthSection.astro';

const title = 'Cities | Window Film Philadelphia | Leading Window Film Solutions';
const description = 'Window Film Philadelphia is honored to serve clients throughout the Philadelphia metropolitan area. Schedule your free consultation!';
import CTAStrip from './../components/CTAStrip.astro';
---

<BaseLayout title={title} description={description} canonical='https://www.windowfilmphiladelphia.net/cities/'>
  <section class="page-hero" style="background-image: linear-gradient(rgba(40,40,40,0.62), rgba(40,40,40,0.80)), url('/images/window-film-philadelphia.png'); background-size: cover; background-position: center;">
    <div class="container">
      <h1>Cities We Serve</h1>
    </div>
  </section>

  <BackAndForthSection
  heading={'Cities We Serve'}
  body={'Window Film Philadelphia is honored to serve cities throughout the Philadelphia metropolitan area. Our team proudly serves the states of Pennsylvania and New Jersey and is happy to help residential and commercial property owners with their upcoming projects.'}
  imageSrc={'/images/window-film-philadelphia.png'}
  imageAlt={'window film philadelphia'}
  flip={false}
  altBg={false}
/>

  <BackAndForthSection
  heading={'Work With Philadelphia’s Trusted Window Film Contractor'}
  body={'Window Film Philadelphia proudly serves numerous cities and areas throughout the Philadelphia metropolitan area as well as the states of Pennsylvania and New Jersey. If you don’t see your city listed above, please contact us! We’re happy to help you with your upcoming residential or commercial project!'}
  imageSrc={'/images/window-tinting-contractor-philadelphia.jpg'}
  imageAlt={'window tinting contractor philadelphia'}
  flip={true}
  altBg={true}
/>

  <CTAStrip />
</BaseLayout>
