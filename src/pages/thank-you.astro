---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Thank You | Window Film Philadelphia';
const description = 'Thank you for contacting Window Film Philadelphia. We will be in touch shortly.';
---

<BaseLayout title={title} description={description} canonical='https://www.windowfilmphiladelphia.net/thank-you/'>

  <section class="thank-you">
    <div class="container">
      <div class="thank-you__inner">
        <div class="thank-you__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" fill="currentColor" viewBox="0 0 16 16">
            <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
          </svg>
        </div>
        <h1>Thank You!</h1>
        <p>Thank you for contacting Window Film Philadelphia. We have received your inquiry and a member of our team will follow up with you shortly. We look forward to helping you with your window film project.</p>
        <p class="thank-you__sub">In the meantime, feel free to explore our services and resources.</p>
        <a href="/" class="btn btn--primary">Back to Home</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.thank-you {
  padding: 6rem var(--section-pad-x);
  background: var(--color-bg-light);
  min-height: 60vh;
  display: flex;
  align-items: center;
}

.thank-you__inner {
  max-width: 580px;
  margin: 0 auto;
  text-align: center;
}

.thank-you__icon {
  color: var(--color-brand);
  margin-bottom: 1.5rem;
}

.thank-you__inner h1 {
  margin-bottom: 1.25rem;
}

.thank-you__inner p {
  font-size: 1.05rem;
  line-height: 1.7;
  margin-bottom: 1rem;
}

.thank-you__sub {
  color: var(--color-text-muted);
  font-size: 0.95rem !important;
  margin-bottom: 2rem !important;
}

.thank-you__inner .btn {
  margin: 0 auto;
}
</style>
