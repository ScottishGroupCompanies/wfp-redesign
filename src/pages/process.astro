---
import BaseLayout from '../layouts/BaseLayout.astro';
import BackAndForthSection from '../components/BackAndForthSection.astro';
import BrandLogos from '../components/BrandLogos.astro';
import CTAStrip from '../components/CTAStrip.astro';

const title = 'Process | Window Film Philadelphia | Leading Window Film Solutions';
const description = 'Learn about Window Film Philadelphia\'s professional installation process — from consultation and preparation to precision installation. Schedule your free consultation today.';
---

<BaseLayout title={title} description={description} canonical='https://www.windowfilmphiladelphia.net/process/'>

  <section class="page-hero" style="background-image: linear-gradient(rgba(40,40,40,0.62), rgba(40,40,40,0.80)), url('/images/2021-10-window-film-process-philadelphia.jpg'); background-size: cover; background-position: center;">
    <div class="container">
      <h1>Expert Window Film Installation in Philadelphia</h1>
      <p>Our team specializes in window film installation in Philadelphia, providing residential and commercial properties with professional, precise service using cutting-edge technology for optimal adhesion and performance.</p>
    </div>
  </section>

  <BackAndForthSection
    heading={'Step One: Window Film Consultation'}
    body={'We provide either same-day installations or scheduled consultations for our clients. During the consultation, our window film contractors show you available options, discuss your project goals, take measurements, and determine whether same-day installation is possible or a follow-up appointment is needed.'}
    imageSrc={'/images/2021-10-window-film-process-philadelphia.jpg'}
    imageAlt={'Window film consultation Philadelphia'}
    flip={false}
    altBg={false}
  />

  <BackAndForthSection
    heading={'Step Two: Window Film Preparation'}
    body={'In order to ensure proper adhesion of your window film, our contractors prepare your windows by thoroughly cleaning the glass using razor blades and squeegee tools. This process removes all dirt, debris, and residue from the interior or exterior glass surface — ensuring proper adhesion and cure time.'}
    imageSrc={'/images/2021-10-window-film-preparation-philadelphia.jpg'}
    imageAlt={'Window film preparation Philadelphia'}
    flip={true}
    altBg={true}
  />

  <BackAndForthSection
    heading={'Step Three: Window Film Installation'}
    body={'Film is custom-cut per window dimension to minimize waste and ensure a perfect fit. C-Bond adhesion technology is available for faster cure times and stronger bond strength. Important care note: DO NOT CLEAN YOUR WINDOW FILM FOR 30 DAYS after installation to allow the adhesive to fully cure.'}
    imageSrc={'/images/2021-10-window-film-installation-philadelphia.jpg'}
    imageAlt={'Window film installation Philadelphia'}
    flip={false}
    altBg={false}
  />

  <BackAndForthSection
    heading={"Work With Philadelphia's Trusted Window Film Installation Experts"}
    body={"Window Film Philadelphia's installation team brings precision, professionalism, and expert product knowledge to every project. Whether you're upgrading a single office window or outfitting an entire building, we deliver solutions with a great ROI and award-winning customer service. Contact us today to schedule your project."}
    imageSrc={'/images/2021-10-llumar-window-film-contractor-philadelphia.jpg'}
    imageAlt={'Window film installation experts Philadelphia'}
    flip={true}
    altBg={true}
    ctaLabel={'Schedule a Consultation'}
    ctaHref={'/contact/'}
  />

  <BrandLogos />
  <CTAStrip />

</BaseLayout>
