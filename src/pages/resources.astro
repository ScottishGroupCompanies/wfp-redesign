---
import BaseLayout from '../layouts/BaseLayout.astro';
import BackAndForthSection from '../components/BackAndForthSection.astro';

const title = 'Resources | Window Film Philadelphia | Leading Window Film Solutions';
const description = 'Window Film Philadelphia is honored to provide leading window film resources for Philadelphia properties. Schedule your free consultation!';
import BrandLogos from '../components/BrandLogos.astro';
import CTAStrip from './../components/CTAStrip.astro';
---

<BaseLayout title={title} description={description} canonical='https://www.windowfilmphiladelphia.net/resources/'>
  <section class="page-hero" style="background-image: linear-gradient(rgba(40,40,40,0.62), rgba(40,40,40,0.80)), url('/images/window-tinting-contractor-philadelphia.jpg'); background-size: cover; background-position: center;">
    <div class="container">
      <h1>Window Film Resources for Philadelphia</h1>
    </div>
  </section>

  <BackAndForthSection
  heading={'Window Film Resources for Philadelphia'}
  body={'Window Film Philadelphia provides a comprehensive selection of window film resources so that residential and commercial property owners can find the right investment for their upcoming project.'}
  imageSrc={'/images/window-tinting-contractor-philadelphia.jpg'}
  imageAlt={'window tinting contractor philadelphia'}
  flip={false}
  altBg={false}
/>

  <BackAndForthSection
  heading={'Work With Philadelphia’s Trusted Window Film Contractor'}
  body={'Window Film Philadelphia is committed to sharing the latest resources and is happy to help you with your upcoming project! Contact us today to schedule your free consultation today!'}
  imageSrc={'/images/window-tinting-resources-philadelphia.png'}
  imageAlt={'window tinting resources philadelphia'}
  flip={true}
  altBg={true}
/>

  <BrandLogos />
  <CTAStrip />
</BaseLayout>
