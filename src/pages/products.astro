---
import BaseLayout from '../layouts/BaseLayout.astro';
import InnerPageHero from '../components/InnerPageHero.astro';
import BrandLogos from '../components/BrandLogos.astro';

const title = 'Products | Window Film Philadelphia | Leading Window Film Solutions';
const description = 'Window Film Philadelphia carries all leading window film brands — 3M, LLumar, Vista, Solar Gard, Madico, Solyx, Huper Optik, C-Bond, HDClear, Hanita Coatings, Casper, Bird Divert, and NanoTint.';

const products = [
  {
    label: '3M™ Window Film',
    desc: 'The world\'s most recognized window film brand. Solar control, safety, decorative, and architectural films backed by 3M\'s science and a comprehensive manufacturer warranty.',
    img: '/images/2021-09-3m-window-film-philadelphia.jpg',
    alt: '3M window film Philadelphia',
    href: '/products/3m-window-film/',
  },
  {
    label: 'LLumar',
    desc: 'Premium solar control and security films trusted by installers worldwide. Exceptional heat rejection across a wide range of tints, styles, and performance levels.',
    img: '/images/2021-09-llumar-window-film-philadelphia.jpg',
    alt: 'LLumar window film Philadelphia',
    href: '/products/llumar/',
  },
  {
    label: 'Vista Window Film',
    desc: 'Eastman\'s high-performance solar line featuring spectrally selective technology — maximum heat rejection with minimal loss of natural light or view clarity.',
    img: '/images/2021-09-vista-window-film-philadelphia.jpg',
    alt: 'Vista window film Philadelphia',
    href: '/products/vista-window-film/',
  },
  {
    label: 'Solar Gard',
    desc: 'Saint-Gobain\'s professional-grade solar control, safety, and decorative films. Renowned for outstanding durability, UV rejection, and architectural-grade performance.',
    img: '/images/2021-09-solar-gard-window-film-philadelphia.jpg',
    alt: 'Solar Gard window film Philadelphia',
    href: '/products/solar-gard-window-film/',
  },
  {
    label: 'Madico',
    desc: 'Over 100 years of film science. Solar, safety, decorative, and specialty films for commercial and residential applications from one of the industry\'s most trusted names.',
    img: '/images/2021-09-madico-window-film-philadelphia.jpg',
    alt: 'Madico window film Philadelphia',
    href: '/products/madico-window-film/',
  },
  {
    label: 'Huper Optik',
    desc: 'German-engineered ceramic window films with industry-leading heat rejection and full signal transparency. No metal means no interference with GPS, WiFi, or cell signals.',
    img: '/images/2021-09-huper-optik-window-film-philadelphia.jpg',
    alt: 'Huper Optik window film Philadelphia',
    href: '/products/huper-optik/',
  },
  {
    label: 'Casper Cloaking Film',
    desc: 'Innovative LCD-privacy technology that renders screens opaque from outside conference rooms while remaining fully visible to those inside — protecting sensitive data without blinds.',
    img: '/images/2021-09-casper-window-film-philadelphia.jpg',
    alt: 'Casper cloaking window film Philadelphia',
    href: '/products/casper-cloaking-film/',
  },
  {
    label: 'C-Bond Systems',
    desc: 'Patented nanotechnology primer that penetrates and strengthens glass at the molecular level — improving film adhesion for a more durable, longer-lasting installation.',
    img: '/images/c-bond-primer-window-film-philadelphia.jpg',
    alt: 'C-Bond window film systems Philadelphia',
    href: '/products/c-bond-window-film/',
  },
  {
    label: 'HDClear',
    desc: 'Custom-printed decorative window film for privacy, branding, and interior design. Full-color, high-definition printing in any pattern, logo, or graphic — cut to any size.',
    img: '/images/2021-09-hdclear-window-film-philadelphia.jpg',
    alt: 'HDClear decorative window film Philadelphia',
    href: '/products/hdclear-window-film/',
  },
  {
    label: 'Hanita Coatings',
    desc: 'Israeli-engineered safety, solar, and security films known for advanced multi-layer construction and exceptional optical clarity across both residential and commercial applications.',
    img: '/images/2021-09-hanita-coatings-window-film-philadelphia.jpg',
    alt: 'Hanita Coatings window film Philadelphia',
    href: '/products/hanita-coatings-window-film/',
  },
  {
    label: 'Solyx',
    desc: 'Specialty decorative films for architects and interior designers. Hundreds of patterns, textures, and translucencies for privacy, light diffusion, and custom space design.',
    img: '/images/2021-09-solyx-window-film-philadelphia.jpg',
    alt: 'Solyx decorative window film Philadelphia',
    href: '/products/solyx-window-film/',
  },
  {
    label: 'NanoTint',
    desc: 'Liquid window film technology that applies as a coating — ideal for irregular, curved, or textured glass surfaces where traditional film cannot adhere.',
    img: '/images/drywired-liquid-nanotint-philadelphia-1.jpg',
    alt: 'NanoTint liquid window film Philadelphia',
    href: '/products/nanotint-window-film/',
  },
  {
    label: 'Bird Divert',
    desc: 'UV-patterned film that makes glass visible to birds, preventing fatal collisions with structures — virtually invisible to the human eye and fully transparent from inside.',
    img: '/images/bird-divert-film-philadelphia.jpg',
    alt: 'Bird Divert window film Philadelphia',
    href: '/products/bird-divert/',
  },
];
---

<BaseLayout title={title} description={description} canonical="https://www.windowfilmphiladelphia.net/products/">

<InnerPageHero
  title="Window Film Products"
  bgImage="/images/2021-10-window-film-brands-philadelphia.jpg"
  desc="Premium window film brands for every residential and commercial application."
/>

<div class="ip-page-body">

<!-- ══════════════════════════════════════
     INTRO
     ══════════════════════════════════════ -->
<section class="pr-intro">
  <div class="pr-intro__inner">
    <div class="pr-intro__left">
      <span class="pr-eyebrow">Our Brand Partners</span>
      <h1 class="pr-intro__title">The industry's best window film brands, all in one place</h1>
    </div>
    <div class="pr-intro__right">
      <p class="pr-intro__lead">Window Film Philadelphia partners with every leading manufacturer to offer the most comprehensive product selection in the region. From energy-saving solar films and ballistic-resistant security systems to custom decorative printing and specialty coatings — we carry the right film for every project. Select a brand below to explore its product line.</p>
      <div class="pr-intro__ctas">
        <a href="/contact/" class="pr-btn pr-btn--primary">Get a Free Quote</a>
        <a href="/benefits/" class="pr-btn pr-btn--ghost">View Film Benefits</a>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     PRODUCTS CARD GRID — 3 columns
     ══════════════════════════════════════ -->
<section class="pr-all">
  <div class="pr-all__grid">
    {products.map((p, i) => (
      <a href={p.href} class="pr-all__card fade-in" style={`transition-delay: ${(i % 3) * 80}ms`}>
        <div class="pr-all__card-img">
          <img src={p.img} alt={p.alt} loading="lazy" />
        </div>
        <div class="pr-all__card-body">
          <h3 class="pr-all__card-title">{p.label}</h3>
          <div class="pr-all__card-rule"></div>
          <p class="pr-all__card-desc">{p.desc}</p>
        </div>
      </a>
    ))}
  </div>
</section>

<!-- ══════════════════════════════════════
     BRAND LOGOS
     ══════════════════════════════════════ -->
<BrandLogos />

<!-- ══════════════════════════════════════
     CTA BANNER
     ══════════════════════════════════════ -->
<div class="pr-cta fade-in">
  <h2>Not sure which film is right for your <em>project?</em></h2>
  <div class="pr-cta__btns">
    <a href="/contact/" class="pr-btn pr-btn--white">Get a Free Quote</a>
    <a href="tel:+12673947980" class="pr-btn pr-btn--green">Call (267) 394-7980</a>
  </div>
</div>

</div><!-- end ip-page-body -->

</BaseLayout>

<style>
/* ── PAGE BODY WRAPPER ── */
.ip-page-body {
  position: relative;
  background: #ffffff;
  border-top-left-radius: 40px;
  border-top-right-radius: 40px;
  border-bottom-left-radius: 40px;
  border-bottom-right-radius: 40px;
  margin-top: -40px;
  z-index: 10;
  overflow: visible;
  padding-bottom: 80px;
}

/* ── EYEBROW ── */
.pr-eyebrow {
  display: inline-block;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--green, #81AB4C);
  margin-bottom: 16px;
}

/* ── BUTTONS ── */
.pr-btn {
  display: inline-block; padding: 14px 28px;
  border-radius: var(--radius-pill, 100px);
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; font-weight: 500;
  text-decoration: none; transition: all 0.2s;
  border: 2px solid transparent; white-space: nowrap;
}
.pr-btn--primary { background: var(--green, #81AB4C); color: #fff; border-color: var(--green, #81AB4C); }
.pr-btn--primary:hover { background: #6e9640; border-color: #6e9640; transform: translateY(-2px); color: #fff; }
.pr-btn--ghost { background: transparent; color: var(--brand, #272E32); border-color: var(--brand, #272E32); }
.pr-btn--ghost:hover { background: var(--brand, #272E32); color: #fff; transform: translateY(-2px); }
.pr-btn--white { background: #fff; color: var(--brand, #272E32); border-color: #fff; font-weight: 600; }
.pr-btn--white:hover { background: var(--off-white, #F7F6F3); transform: translateY(-2px); }
.pr-btn--green { background: var(--green, #81AB4C); color: #fff; border-color: var(--green, #81AB4C); }
.pr-btn--green:hover { background: #6e9640; transform: translateY(-2px); color: #fff; }

/* ── INTRO ── */
.pr-intro {
  padding: 80px 10%;
  border-top-left-radius: 40px;
  border-top-right-radius: 40px;
  overflow: hidden;
}
.pr-intro__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}
.pr-intro__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(36px, 4.5vw, 58px);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -1px;
  color: var(--text-dark, #1a1a1a);
  margin: 0;
}
.pr-intro__lead {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 17px;
  color: var(--text-mid, #4a4a4a);
  line-height: 1.75;
  margin-bottom: 32px;
}
.pr-intro__ctas { display: flex; gap: 14px; flex-wrap: wrap; }

/* ── PRODUCTS GRID ── */
.pr-all {
  padding: 0 10% 100px;
  background: #ffffff;
}
.pr-all__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.pr-all__card {
  background: transparent;
  border-radius: 24px;
  overflow: visible;
  text-decoration: none;
  display: block;
  position: relative;
  border: 1px solid #DDDCDA;
  transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
}
.pr-all__card:hover {
  border-color: var(--green, #81AB4C);
  transform: translateY(-4px);
  box-shadow: 0 16px 40px rgba(0,0,0,0.09);
}
.pr-all__card-img {
  margin: 12px;
  border-radius: 14px;
  overflow: hidden;
  height: 240px;
}
.pr-all__card-img img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  transition: transform 0.4s ease;
}
.pr-all__card:hover .pr-all__card-img img {
  transform: scale(1.05);
}
.pr-all__card-body {
  padding: 8px 20px 28px;
}
.pr-all__card-title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(19px, 1.6vw, 23px);
  font-weight: 700;
  color: var(--text-dark, #1a1a1a);
  line-height: 1.25;
  margin-bottom: 12px;
}
.pr-all__card-rule {
  width: 100%; height: 1px;
  background: var(--light-gray, #EFEFED);
  margin-bottom: 14px;
}
.pr-all__card-desc {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 14px;
  color: var(--text-mid, #4a4a4a);
  line-height: 1.7;
  margin: 0;
}

/* ── CTA BANNER ── */
.pr-cta {
  background: var(--brand, #272E32);
  border-radius: 40px;
  padding: 64px 60px;
  display: flex; align-items: center;
  justify-content: space-between;
  gap: 40px;
  margin: 0 5% 0;
}
.pr-cta h2 {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 32px; font-weight: 700;
  color: #fff; line-height: 1.2;
  max-width: 460px; margin: 0;
}
.pr-cta h2 em { font-style: italic; color: var(--green, #81AB4C); }
.pr-cta__btns { display: flex; gap: 14px; flex-shrink: 0; }

/* ── FADE IN ── */
.fade-in { opacity: 0; transform: translateY(24px); transition: opacity 0.65s ease, transform 0.65s ease; }
.fade-in.visible { opacity: 1; transform: translateY(0); }

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
  .pr-intro__inner { grid-template-columns: 1fr; gap: 40px; }
  .pr-all__grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 768px) {
  .pr-intro { padding: 60px 5%; }
  .pr-all { padding: 0 5% 60px; }
  .pr-all__card-img { height: 200px; }
  .pr-cta { flex-direction: column; padding: 40px 28px; text-align: center; }
  .pr-cta h2 { font-size: 26px; max-width: 100%; }
  .pr-cta__btns { flex-direction: column; width: 100%; }
}
@media (max-width: 480px) {
  .pr-all__grid { grid-template-columns: 1fr; }
  .pr-intro__ctas { flex-direction: column; }
}
</style>

<script>
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-in').forEach(el => obs.observe(el));
</script>
