---
import BaseLayout from '../layouts/BaseLayout.astro';
import BackAndForthSection from '../components/BackAndForthSection.astro';

const title = 'Products | Window Film Philadelphia | Leading Window Film Solutions';
const description = 'Window Film Philadelphia is honored to partner with leading window film manufacturers to provide comprehensive solutions. Contact us today!';
---

<BaseLayout title={title} description={description} canonical='https://www.windowfilmphiladelphia.net/products/'>
  <section class="page-hero" style="background-image: linear-gradient(rgba(40,40,40,0.62), rgba(40,40,40,0.80)), url('/images/window-tinting-reading-pennsylvania.jpg'); background-size: cover; background-position: center;">
    <div class="container">
      <h1>Leading Window Film Products forPhiladelphia Homes and Businesses</h1>
    </div>
  </section>

  <BackAndForthSection
  heading={'Leading Window Film Products forPhiladelphia Homes and Businesses'}
  body={'Window Film Philadelphia is honored to partner with all the leading window film manufacturers in order to provide the most comprehensive scope of premium window film solutions for our residential and commercial clients. We only carry the best products available to help you achieve all of your property goals and help address building concerns. Our team is happy to help you navigate all of our window film products available for your upcoming project!'}
  imageSrc={'/images/window-tinting-reading-pennsylvania.jpg'}
  imageAlt={'window tinting reading pennsylvania'}
  flip={false}
  altBg={false}
/>

  <BackAndForthSection
  heading={'Comprehensive Window Film Products for Your Philadelphia Property'}
  body={'Window Film Philadelphia is the number one source for all the leading window film products and brands. Find the right investment for your residential or commercial property: 3M Madico Vista Drywired C-Bond hdClear Hanita Coatings Solyx Solar Gard Casper LLumar Huper Optik If you’re interested in a window film product that isn’t listed here, please contact us! Our team is always available to help you find the perfect investment for your upcoming project!'}
  imageSrc={'/images/2021-10-window-film-brands-philadelphia.jpg'}
  imageAlt={'window film brands philadelphia'}
  flip={true}
  altBg={true}
/>

  <section class="section-pad">
  <div class="container">
    <h2>Work With Philadelphia’s Preferred Window Film Contractor</h2>
    <p>The Window Film Philadelphia team is always available to help you compare different window film products and brands for your upcoming project. From LEED certification to custom HD decorative printing, we can help you achieve your property goals through our comprehensive selection of window film.</p>
  </div>
</section>

  <section class="cta-strip">
    <div class="container">
      <h2>Get Your Free Quote Today</h2>
      <p>Philadelphia&#39;s leading window film contractor. Contact us for a free consultation and estimate.</p>
      <a href="/contact/" class="btn btn--accent">Contact Us</a>
    </div>
  </section>
</BaseLayout>
