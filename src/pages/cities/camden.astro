---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackAndForthSection from '../../components/BackAndForthSection.astro';
import BrandLogos from '../../components/BrandLogos.astro';
import CTAStrip from '../../components/CTAStrip.astro';
import InnerPageHero from '../../components/InnerPageHero.astro';

const title = 'Window Film Camden NJ | Window Film Contractor Camden';
const description = 'Window Film Philadelphia is the #1 source for window film in Camden, NJ. Get 3M, energy saving, LLumar, security, or privacy film for your home or business. Free quotes!';
---

<BaseLayout title={title} description={description} canonical="https://www.windowfilmphiladelphia.net/cities/camden/">

<InnerPageHero
  title="Window Film Solutions<br />Camden, NJ"
  bgImage="/images/wfp-camden-hero-bg.jpg"
  desc="Serving Camden and South Jersey homeowners and businesses since 2008."
/>

<div class="ip-page-body">
<!-- ══════════════════════════════════════
     PAGE HERO — 2-col: copy left, quote form right
     ══════════════════════════════════════ -->
<div class="ip-hero">
  <div class="ip-hero__content fade-in">
    <div class="ip-hero__eyebrow">
      <span class="eyebrow-marquee"><span>Camden, New Jersey</span></span>
    </div>
    <h1>Window Film in <em>Camden, NJ</em></h1>
  </div>
  <div class="ip-hero__body fade-in">
    <p class="ip-hero__lead">Window Film Philadelphia has served Camden homeowners, businesses, and commercial properties since 2008. Expert installation, premium films from 3M, LLumar, and Vista, and a lifetime warranty on every project.</p>
    <div class="ip-hero__ctas">
      <a href="/contact/" class="ip-btn ip-btn--primary">Get a Free Quote</a>
      <a href="tel:+12673947980" class="ip-btn ip-btn--ghost">Call (267) 394-7980</a>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
     HERO IMAGE — full-width rounded
     ══════════════════════════════════════ -->
<div class="ip-hero-img-wrap">
  <div class="ip-hero-img fade-in">
    <img src="/images/wfp-camden-window-film-service.jpg" alt="Window film installation Camden NJ" width="1200" height="380" loading="lazy" />
    <span class="ip-hero-img__caption">📍 Serving all Camden neighborhoods &amp; surrounding areas</span>
  </div>
</div>

<!-- ══════════════════════════════════════
     MAIN CONTENT + SIDEBAR
     ══════════════════════════════════════ -->
<div class="ip-content-wrap">
  <div class="ip-main prose">
    <h2>Camden's Trusted Window Film Experts</h2>
    <p>At Window Film Philadelphia, we've been serving Camden and the surrounding South Jersey communities since 2008. Whether you're looking to reduce the summer heat in your home, improve energy efficiency in your office, protect your storefront from graffiti, or add decorative privacy film to a conference room — our certified installers deliver flawless results every time.</p>
    <p>Camden's urban environment comes with unique challenges: high crime rates, intense summer humidity, and commercial properties that need maximum protection. Our window films address every one of these concerns, providing security reinforcement, heat rejection, and UV blocking in a single installation.</p>

    <div class="ip-callout">
      <p><strong>Camden Security Advantage:</strong> With a crime rate of 43.71 per 1,000 residents, Camden businesses and homeowners benefit greatly from security window film that holds glass together on impact, deters smash-and-grab theft, and protects occupants during severe weather events.</p>
    </div>

    <h2>Window Film Options for Camden Properties</h2>
    <p>We offer a curated selection of premium films from 3M, LLumar, Vista, and Solar Gard — matched to Camden's specific urban climate and your project goals.</p>

    <div class="ip-film-grid">
      <div class="ip-film-card ip-film-card--featured">
        <svg class="ip-film-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <h3>Solar Control Film</h3>
        <p>Maximum heat rejection and UV blocking. Ideal for Camden homes and offices facing south or west.</p>
        <div class="ip-film-price">From $6.50/sq ft installed</div>
      </div>
      <div class="ip-film-card">
        <svg class="ip-film-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <h3>Safety & Security Film</h3>
        <p>Holds glass together on impact. Popular for commercial storefronts and ground-floor offices.</p>
        <div class="ip-film-price">From $7.00/sq ft installed</div>
      </div>
      <div class="ip-film-card">
        <svg class="ip-film-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        <h3>Decorative & Privacy Film</h3>
        <p>Frosted, patterned, or custom-cut designs for bathrooms, conference rooms, and storefronts.</p>
        <div class="ip-film-price">From $5.50/sq ft installed</div>
      </div>
      <div class="ip-film-card">
        <svg class="ip-film-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
        <h3>Anti-Graffiti Film</h3>
        <p>Sacrificial film layer protects glass from etching, paint, and graffiti. Easily replaced at low cost.</p>
        <div class="ip-film-price">From $4.00/sq ft installed</div>
      </div>
    </div>

    <h2>Why Camden Properties Choose Window Film Philadelphia</h2>
    <ul>
      <li>15+ years serving Philadelphia and South Jersey</li>
      <li>Factory-certified installers from 3M, LLumar, and Vista</li>
      <li>Lifetime manufacturer warranty on all residential and commercial films</li>
      <li>Same-week appointments available across Camden County</li>
      <li>Free in-home and on-site consultations</li>
      <li>Philadelphia's most reviewed window film contractor</li>
    </ul>

    <h2>Our Camden Installation Process</h2>
    <p>Call or submit a quote request and receive a detailed estimate within 24 hours. Our Camden-area crew arrives on schedule, preps the surface, installs the film, and leaves your space spotless. Most residential jobs are completed in a single day.</p>
  </div>

  <div class="ip-sidebar">
    <div class="ip-sidebar-cta-card fade-in">
      <div class="ip-sidebar-cta-card__bg" style="background-image: url('/images/2021-09-hotel-window-film-philadelphia.jpg')">
        <div class="ip-sidebar-cta-card__overlay"></div>
        <div class="ip-sidebar-cta-card__content">
          <p class="ip-sidebar-cta-card__label">Any Questions? Let's talk</p>
          <a href="tel:+12673947980" class="ip-sidebar-cta-card__phone">(267) 394-7980</a>
          <a href="/contact/" class="ip-sidebar-cta-card__btn">Get a Free Quote →</a>
        </div>
      </div>
    </div>

    <div class="ip-sidebar-cities fade-in fade-in-delay-1">
      <h4 class="ip-sidebar-cities__title">Cities We Serve</h4>
      <ul class="ip-sidebar-cities__list">
        <li><a href="/cities/philadelphia/" class="ip-sidebar-city-link">Philadelphia <span>PA</span></a></li>
        <li><a href="/cities/camden/" class="ip-sidebar-city-link ip-sidebar-city-link--active">Camden <span>NJ</span></a></li>
        <li><a href="/cities/reading/" class="ip-sidebar-city-link">Reading <span>PA</span></a></li>
        <li><a href="/cities/upper-darby-township/" class="ip-sidebar-city-link">Upper Darby <span>PA</span></a></li>
      </ul>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
     LOCAL AREA — map + neighborhood copy
     ══════════════════════════════════════ -->
<div class="ip-local fade-in">
  <div class="ip-local__grid">
    <div class="ip-local__map">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d49041.3!2d-75.12!3d39.94!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c6c6dde38f4d11%3A0x79f9dafe3a2fdf54!2sCamden%2C%20NJ!5e0!3m2!1sen!2sus!4v1714000000000"
        width="100%" height="100%"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Camden NJ service area map"
      ></iframe>
    </div>
    <div class="ip-local__content">
      <p class="section-eyebrow">Local Expertise</p>
      <h2>We know Camden inside and out</h2>
      <p>From Cramer Hill rowhouses to the Camden waterfront commercial corridor to suburban Cherry Hill offices — our crews work in every Camden neighborhood, every week. We understand South Jersey's humid summers, urban security concerns, and the specific building styles across the metro area.</p>
      <div class="ip-tags">
        <span class="ip-tag">Camden</span>
        <span class="ip-tag">Cherry Hill</span>
        <span class="ip-tag">Haddonfield</span>
        <span class="ip-tag">Collingswood</span>
        <span class="ip-tag">Pennsauken</span>
        <span class="ip-tag">Merchantville</span>
        <span class="ip-tag">Maple Shade</span>
        <span class="ip-tag">Voorhees</span>
        <span class="ip-tag">+ more</span>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
     FAQ ACCORDION
     ══════════════════════════════════════ -->
<div class="ip-faq">
  <div class="ip-faq__hd">
    <p class="section-eyebrow">FAQ</p>
    <h2 class="section-title" style="margin:0 auto;">Common questions about Camden window film</h2>
  </div>
  <div class="ip-faq__item ip-faq__item--open">
    <div class="ip-faq__q">Is window film legal in New Jersey? <span class="ip-faq__toggle">+</span></div>
    <div class="ip-faq__a">Yes. New Jersey law permits residential and commercial window film without restriction. For automotive applications, NJ requires front side windows at 35% VLT or higher. We ensure all installs are fully compliant.</div>
  </div>
  <div class="ip-faq__item">
    <div class="ip-faq__q">How long does installation take? <span class="ip-faq__toggle">+</span></div>
    <div class="ip-faq__a">Most residential jobs take 4–8 hours. Commercial projects are scoped per job. Anti-graffiti and decorative films can often be completed in a single afternoon.</div>
  </div>
  <div class="ip-faq__item">
    <div class="ip-faq__q">What warranty comes with my installation? <span class="ip-faq__toggle">+</span></div>
    <div class="ip-faq__a">All residential and commercial installations include a lifetime manufacturer warranty against peeling, bubbling, and fading. The warranty transfers with the property.</div>
  </div>
  <div class="ip-faq__item">
    <div class="ip-faq__q">How much does window film cost in Camden? <span class="ip-faq__toggle">+</span></div>
    <div class="ip-faq__a">Solar control film starts around $5–$8 per sq ft installed. Security film starts at $7/sq ft. Anti-graffiti starts at $4/sq ft. Request a free quote for an exact estimate.</div>
  </div>
  <div class="ip-faq__item">
    <div class="ip-faq__q">Do you offer free consultations in Camden? <span class="ip-faq__toggle">+</span></div>
    <div class="ip-faq__a">Yes — all consultations are free. We'll come to your home or business, assess your needs, and provide a detailed written estimate at no charge and no obligation.</div>
  </div>
  <div class="ip-faq__item">
    <div class="ip-faq__q">How soon can you schedule in Camden? <span class="ip-faq__toggle">+</span></div>
    <div class="ip-faq__a">We typically have same-week availability in the Camden area. During peak summer months we recommend booking 1–2 weeks in advance.</div>
  </div>
</div>

<!-- ══════════════════════════════════════
     CTA BANNER
     ══════════════════════════════════════ -->
<BrandLogos />

<div class="ip-cta fade-in">
  <h2>Ready to get started in <em>Camden?</em></h2>
  <div class="ip-cta__btns">
    <a href="/contact/" class="ip-btn ip-btn--white">Get a Free Quote</a>
    <a href="tel:+12673947980" class="ip-btn ip-btn--green">Call (267) 394-7980</a>
  </div>
</div>

</div><!-- end ip-page-body -->

</BaseLayout>

<style>
/* ── PAGE BODY WRAPPER ── */
.ip-page-body {
  position: relative;
  background: #ffffff;
  border-top-left-radius: 40px;
  border-top-right-radius: 40px;
  border-bottom-left-radius: 40px;
  border-bottom-right-radius: 40px;
  margin-top: -40px;
  z-index: 10;
  overflow: visible;
  padding-bottom: 80px;
}
/* ── BREADCRUMB ── */
.ip-breadcrumb {
  padding: 16px 5%;
  background: var(--off-white, #F7F6F3);
  border-bottom: 1px solid var(--light-gray, #EFEFED);
  font-family: var(--font-body, 'DM Sans', sans-serif);
}
.ip-breadcrumb span { font-size: 13px; color: var(--text-light, #888); }
.ip-breadcrumb a { color: var(--green, #81AB4C); text-decoration: none; font-size: 13px; }
.ip-breadcrumb a:hover { text-decoration: underline; }

/* ── PAGE HERO ── */
.ip-hero {
  padding: 80px 10%;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 50px;
  align-items: center;
  background: #fff;
  border-top-left-radius: 40px;
  border-top-right-radius: 40px;
  overflow: hidden;
}
.ip-hero__content { padding-bottom: 0; }
.ip-hero__body { padding-bottom: 0; }

.ip-hero__eyebrow {
  display: inline-flex; align-items: center;
  background: transparent;
  border: 1.5px solid var(--green, #81AB4C);
  color: var(--green, #81AB4C);
  padding: 5px 14px; border-radius: var(--radius-pill, 100px);
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 12px; font-weight: 600; letter-spacing: 0.5px;
  text-transform: uppercase; margin-bottom: 20px; overflow: hidden;
}
.eyebrow-marquee {
  display: block; overflow: hidden; white-space: nowrap;
}
.eyebrow-marquee span {
  display: inline-block;
  animation: marquee-scroll 8s linear infinite;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 12px; font-weight: 600; letter-spacing: 0.5px;
  text-transform: uppercase;
}
@keyframes marquee-scroll {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

.ip-hero h1 {
  font-family: var(--font-serif);
  font-size: clamp(40px, 5vw, 64px); font-weight: 600;
  line-height: 1.1; letter-spacing: -0.8px;
  color: var(--text-dark, #1a1a1a); margin-bottom: 20px;
}
.ip-hero h1 em { font-style: italic; color: var(--green, #81AB4C); }

.ip-hero__lead {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 17px; color: var(--text-mid, #4a4a4a);
  line-height: 1.75; max-width: 560px; margin-bottom: 32px;
}

.ip-hero__ctas { display: flex; gap: 14px; align-items: center; flex-wrap: wrap; margin-bottom: 32px; }

/* Buttons */
.ip-btn {
  display: inline-block; padding: 14px 28px;
  border-radius: var(--radius-pill, 100px);
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; font-weight: 500;
  text-decoration: none; transition: all 0.2s;
  border: 2px solid transparent; white-space: nowrap;
}
.ip-btn--primary { background: var(--green, #81AB4C); color: #fff; border-color: var(--green, #81AB4C); }
.ip-btn--primary:hover { background: #6e9640; border-color: #6e9640; transform: translateY(-2px); color: #fff; }
.ip-btn--ghost { background: transparent; color: var(--brand, #272E32); border-color: var(--brand, #272E32); }
.ip-btn--ghost:hover { background: var(--brand, #272E32); color: #fff; transform: translateY(-2px); }
.ip-btn--white { background: #fff; color: var(--brand, #272E32); border-color: #fff; font-weight: 600; }
.ip-btn--white:hover { background: var(--off-white, #F7F6F3); transform: translateY(-2px); color: var(--brand, #272E32); }
.ip-btn--green { background: var(--green, #81AB4C); color: #fff; border-color: var(--green, #81AB4C); }
.ip-btn--green:hover { background: #6e9640; transform: translateY(-2px); color: #fff; }

.ip-trust-row { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
.ip-trust-badge {
  display: flex; align-items: center; gap: 8px;
  background: var(--off-white, #F7F6F3);
  padding: 10px 16px; border-radius: var(--radius-pill, 100px);
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px; font-weight: 500; color: var(--text-mid, #4a4a4a);
}
.ip-trust-badge span { color: var(--green, #81AB4C); font-weight: 700; }

/* Quote card */
.ip-quote-sidebar { position: sticky; top: 84px; }
.ip-quote-card {
  background: var(--brand, #272E32);
  border-radius: var(--radius-lg, 24px);
  padding: 32px 28px; color: #fff;
}
.ip-quote-card h3 {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 22px; font-weight: 600; color: #fff; margin-bottom: 6px;
}
.ip-quote-card > p {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 14px; color: rgba(255,255,255,0.65); margin-bottom: 24px;
}
.ip-form-group { margin-bottom: 14px; }
.ip-form-group input,
.ip-form-group select {
  width: 100%; padding: 12px 16px;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: var(--radius-md, 16px);
  color: #fff; font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 14px; outline: none; transition: border-color 0.2s;
}
.ip-form-group input::placeholder { color: rgba(255,255,255,0.45); }
.ip-form-group input:focus,
.ip-form-group select:focus { border-color: var(--green, #81AB4C); }
.ip-form-group select { color: rgba(255,255,255,0.7); }
.ip-form-group select option { background: var(--brand, #272E32); color: #fff; }
.ip-btn-form {
  width: 100%; background: var(--green, #81AB4C); color: #fff;
  padding: 14px; border-radius: var(--radius-pill, 100px);
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; font-weight: 600; border: none; cursor: pointer;
  transition: background 0.2s; margin-top: 8px;
}
.ip-btn-form:hover { background: #6e9640; }
.ip-form-note {
  text-align: center; font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 12px; color: rgba(255,255,255,0.45); margin-top: 12px; margin-bottom: 0;
}

/* ── HERO IMAGE ── */
.ip-hero-img-wrap { padding: 32px 5% 0; }
.ip-hero-img {
  width: 100%; height: 380px;
  border-radius: var(--radius-xl, 40px); overflow: hidden; position: relative;
}
.ip-hero-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.ip-hero-img__caption {
  position: absolute; bottom: 20px; left: 20px;
  background: rgba(255,255,255,0.92); backdrop-filter: blur(8px);
  padding: 10px 18px; border-radius: var(--radius-pill, 100px);
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px; font-weight: 600; color: var(--brand, #272E32);
}

/* ── CONTENT + SIDEBAR ── */
.ip-content-wrap {
  padding: 0 5%;
  display: grid; grid-template-columns: 1fr 420px;
  gap: 60px; align-items: start;
}
.ip-main { padding: 64px 0; }
.ip-sidebar { padding: 64px 0; }

/* Prose */
.prose h2 {
  font-family: var(--font-serif);
  font-size: clamp(28px, 3.5vw, 42px);
  font-weight: 700;
  letter-spacing: -0.5px;
  line-height: 1.15;
  color: var(--text-dark, #1a1a1a); margin: 48px 0 20px;
}
.prose h2:first-child { margin-top: 0; }
.prose p {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 16px; color: var(--text-mid, #4a4a4a); line-height: 1.8; margin-bottom: 18px;
}
.prose ul { list-style: none; padding: 0; margin-bottom: 18px; }
.prose ul li {
  display: flex; align-items: flex-start; gap: 10px;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; color: var(--text-mid, #4a4a4a); padding: 5px 0; line-height: 1.6;
}
.prose ul li::before { content: '✓'; color: var(--green, #81AB4C); font-weight: 700; font-size: 13px; margin-top: 3px; flex-shrink: 0; }

/* Callout */
.ip-callout {
  background: var(--green-light, #eef4e4);
  border-left: 4px solid var(--green, #81AB4C);
  border-radius: 0 var(--radius-md, 16px) var(--radius-md, 16px) 0;
  padding: 20px 24px; margin: 32px 0;
}
.ip-callout p { font-family: var(--font-body, 'DM Sans', sans-serif); font-size: 15px; color: #3a5a1f; margin: 0; line-height: 1.7; }

/* Film grid */
.ip-film-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin: 24px 0 32px; }
.ip-film-card {
  background: var(--off-white, #F7F6F3);
  border-radius: var(--radius-lg, 24px); padding: 24px 20px;
  border: 2px solid transparent; transition: border-color 0.2s, transform 0.2s;
}
.ip-film-card:hover { border-color: var(--green, #81AB4C); transform: translateY(-2px); }
.ip-film-card--featured { border-color: var(--green, #81AB4C); background: var(--green-light, #eef4e4); }
.ip-film-badge {
  display: inline-block; background: var(--green, #81AB4C); color: #fff;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 11px; font-weight: 600;
  padding: 3px 10px; border-radius: var(--radius-pill, 100px); margin-bottom: 12px;
}
.ip-film-card h3 {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 16px; font-weight: 600; color: var(--text-dark, #1a1a1a); margin-bottom: 6px;
