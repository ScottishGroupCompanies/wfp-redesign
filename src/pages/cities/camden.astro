<style>
  /* ─── BREADCRUMB ─── */
  .breadcrumb {
    padding: 16px 5%;
    background: var(--off-white, #F7F6F3);
    border-bottom: 1px solid var(--light-gray, #EFEFED);
  }
  .breadcrumb span {
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: 13px;
    color: var(--text-light, #888);
  }
  .breadcrumb a {
    color: var(--green, #81AB4C);
    text-decoration: none;
    font-size: 13px;
    font-family: var(--font-body, 'DM Sans', sans-serif);
  }
  .breadcrumb a:hover { text-decoration: underline; }

  /* ─── PAGE HERO ─── */
  .page-hero {
    padding: 64px 5% 0;
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 60px;
    align-items: start;
    background: #fff;
  }
  .page-hero-content { padding-bottom: 64px; }
  .page-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--green-light, #eef4e4);
    color: #5a7a33;
    padding: 6px 14px;
    border-radius: var(--radius-pill, 100px);
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .page-eyebrow::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--green, #81AB4C);
    border-radius: 50%;
  }
  .page-hero h1 {
    font-family: var(--font-serif, 'Playfair Display', serif);
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.8px;
    color: var(--text-dark, #1a1a1a);
    margin-bottom: 20px;
  }
  .page-hero h1 em { font-style: italic; color: var(--green, #81AB4C); }
  .page-hero-lead {
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: 17px;
    color: var(--text-mid, #4a4a4a);
    line-height: 1.75;
    max-width: 560px;
    margin-bottom: 32px;
  }
  .hero-ctas {
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }
  .btn-primary {
    background: var(--green, #81AB4C);
    color: #fff;
    padding: 14px 28px;
    border-radius: var(--radius-pill, 100px);
    font-family: var(--font-body, 'DM Sans', sans-serif);
