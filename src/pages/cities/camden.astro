<BaseLayout title={title} description={description} canonical="https://www.windowfilmphiladelphia.net/cities/camden/">

<!-- ══════════════════════════════════════════════════════
     BREADCRUMB
     ══════════════════════════════════════════════════════ -->
<div class="breadcrumb">
  <a href="/">Home</a>
  <span> › </span>
  <a href="/cities/">Locations</a>
  <span> › </span>
  <span>Camden Window Film</span>
</div>

<!-- ══════════════════════════════════════════════════════
     PAGE HERO — 2-col: copy left, quote form right
     ══════════════════════════════════════════════════════ -->
<div class="page-hero">
  <div class="page-hero-content">
    <div class="page-eyebrow">Camden, New Jersey</div>
    <h1>Window Film in <em>Camden, NJ</em></h1>
    <p class="page-hero-lead">Window Film Philadelphia has served Camden homeowners, businesses, and commercial properties since 2008. Expert installation, premium films from 3M, LLumar, and Vista, and a lifetime warranty on every project.</p>
    <div class="hero-ctas">
      <a href="/contact/" class="btn-primary">Get a Free Quote</a>
      <a href="tel:+12673947980" class="btn-ghost">Call (267) 394-7980</a>
    </div>
    <div class="trust-row">
      <div class="trust-badge"><span>★ 4.9</span> 5,000+ projects completed</div>
      <div class="trust-badge"><span>✓</span> Lifetime warranty</div>
      <div class="trust-badge"><span>✓</span> Free consultations</div>
    </div>
  </div>
  <div class="quote-sidebar">
    <div class="quote-card">
      <h3>Get a Free Quote</h3>
      <p>Camden estimates in under 24 hours</p>
      <form method="POST" action="/thank-you/" class="quote-form">
        <div class="form-group"><input type="text" name="name" placeholder="Your name" required /></div>
        <div class="form-group"><input type="tel" name="phone" placeholder="Phone number" required /></div>
        <div class="form-group"><input type="email" name="email" placeholder="Email address" required /></div>
        <div class="form-group">
          <select name="service">
            <option value="" disabled selected>Service type</option>
            <option>Residential Window Film</option>
            <option>Commercial Window Film</option>
            <option>Security Film</option>
            <option>Decorative Film</option>
            <option>Anti-Graffiti Film</option>
            <option>Exterior Building Wrap</option>
          </select>
        </div>
        <button type="submit" class="btn-form">Request My Free Quote →</button>
        <p class="form-note">No commitment. Response within 24 hours.</p>
      </form>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════
