<script>
  // IntersectionObserver deferred to idle — off the critical paint path.
  const registerFadeIns = () => {
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-in').forEach(el => obs.observe(el));
  };

  if ('requestIdleCallback' in window) {
    requestIdleCallback(registerFadeIns);
  } else {
    setTimeout(registerFadeIns, 200);
  }

  // FAQ accordion — synchronous, must respond to clicks immediately.
  document.querySelectorAll('.ip-faq__item').forEach(item => {
    item.querySelector('.ip-faq__q')?.addEventListener('click', () => {
      const isOpen = item.classList.contains('ip-faq__item--open');
      document.querySelectorAll('.ip-faq__item').forEach(i => i.classList.remove('ip-faq__item--open'));
      if (!isOpen) item.classList.add('ip-faq__item--open');
    });
  });

  // Testimonial carousel
  const slides = document.querySelectorAll('.ip-testi-slide');
  const dots = document.querySelectorAll('.ip-testi-dot');
  let current = 0;

  function goTo(n, dir) {
    slides[current].classList.remove('ip-testi-slide--active');
    dots[current].classList.remove('ip-testi-dot--active');
    current = (n + slides.length) % slides.length;
    slides[current].classList.add('ip-testi-slide--active');
    dots[current].classList.add('ip-testi-dot--active');
  }

  document.querySelector('.ip-testi-btn--prev')?.addEventListener('click', () => goTo(current - 1));
  document.querySelector('.ip-testi-btn--next')?.addEventListener('click', () => goTo(current + 1));
  dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
</script>
