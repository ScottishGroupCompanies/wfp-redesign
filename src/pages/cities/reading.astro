  heading={'Glare Reduction'}
  body={'Excessive glare can impact any screen-viewing activity, causing serious discomfort, eye fatigue, headaches, and more. Glare reduction window film provides an effective solution for addressing glare while helping maintain natural sunlight. Improve comfort and productivity among all properties with this investment.'}
  imageSrc={'/images/window-film-contractor-reading-pennsylvania.jpg'}
  imageAlt={'window film contractor reading pennsylvania'}
  flip={false}
  altBg={false}
/>

