---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandLogos from '../components/BrandLogos.astro';
import InnerPageHero from '../components/InnerPageHero.astro';

const title = 'Window Film Blog | Tips & Guides | Window Film Philadelphia';
const description = 'Read the latest window film tips, guides, and industry news from Window Film Philadelphia. Expert advice for residential and commercial properties in the Philadelphia area.';

// Blog post registry — add new posts here as they are published
const posts = [
  {
    slug: '/2026/04/22/benefits-window-tint-philadelphia-energy-comfort-uv-defense/',
    title: 'Benefits of Window Tint in Philadelphia: Energy, Comfort, and UV Defense',
    excerpt: 'From sun-soaked glass in Center City high-rises to drafty windows in classic rowhomes, Philadelphia buildings take a beating from temperature swings, glare, and UV exposure. Discover how window tint addresses all three — without replacing your windows.',
    image: '/images/wfphilly-infographic-3e9af1ac.webp',
    imageAlt: 'Benefits of window tint in Philadelphia',
    date: 'April 22, 2026',
    category: 'Energy Efficient Window Film',
  },
];
---

<BaseLayout title={title} description={description} canonical='https://www.windowfilmphiladelphia.net/blog/'>

<InnerPageHero
  title="Window Film Blog"
  bgImage="/images/2021-08-window-film-philadelphia-benefits.webp"
  desc="Tips, guides, and industry news from Philadelphia's window film experts."
/>

<div class="ip-page-body">

  <!-- ══════════════════════════════════════
       BLOG INTRO
       ══════════════════════════════════════ -->
  <div class="blog-intro">
    <span class="section-eyebrow">Industry Insights</span>
    <h2 class="section-title">Expert Window Film <em>Advice</em></h2>
    <p class="blog-intro__sub">Stay up to date with the latest tips, product guides, and industry news from Window Film Philadelphia's certified installers.</p>
  </div>

  <!-- ══════════════════════════════════════
       BLOG GRID
       ══════════════════════════════════════ -->
  <div class="blog-grid-wrap">
    <div class="blog-grid">
      {posts.map((post) => (
        <article class="blog-card">
          <a href={post.slug} class="blog-card__img-link" tabindex="-1" aria-hidden="true">
            <div class="blog-card__img">
              <img src={post.image} alt={post.imageAlt} loading="lazy" width="760" height="420" />
            </div>
          </a>
          <div class="blog-card__body">
            <div class="blog-card__meta">
              {post.category && (
                <span class="blog-card__cat">{post.category}</span>
              )}
              <span class="blog-card__date">{post.date}</span>
            </div>
            <h2 class="blog-card__title">
              <a href={post.slug}>{post.title}</a>
            </h2>
            <p class="blog-card__excerpt">{post.excerpt}</p>
            <a href={post.slug} class="blog-card__read-more">
              Read Article <span aria-hidden="true">→</span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>

  <!-- ══════════════════════════════════════
       BRAND LOGOS + CTA
       ══════════════════════════════════════ -->
  <BrandLogos />

  <div class="ip-cta">
    <h2>Ready to transform your <em>windows?</em></h2>
    <div class="ip-cta__btns">
      <a href="/contact/" class="ip-btn ip-btn--white">Get a Free Quote</a>
      <a href="tel:+12673947980" class="ip-btn ip-btn--green">Call (267) 394-7980</a>
    </div>
  </div>

</div><!-- end ip-page-body -->

</BaseLayout>

<style>
/* ── PAGE BODY WRAPPER ── */
.ip-page-body {
  position: relative;
  background: #ffffff;
  border-top-left-radius: 40px;
  border-top-right-radius: 40px;
  border-bottom-left-radius: 40px;
  border-bottom-right-radius: 40px;
  margin-top: -40px;
  z-index: 10;
  overflow: visible;
  padding-bottom: 80px;
}

/* ── BLOG INTRO ── */
.blog-intro {
  padding: 80px 10% 48px;
  max-width: 700px;
}
.blog-intro .section-title {
  margin-bottom: 16px;
}
.blog-intro__sub {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 17px;
  color: var(--text-mid, #4a4a4a);
  line-height: 1.75;
  max-width: 580px;
  margin: 0;
}

/* ── BLOG GRID ── */
.blog-grid-wrap {
  padding: 0 5% 80px;
}
.blog-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
}

/* ── BLOG CARD ── */
.blog-card {
  background: #fff;
  border-radius: var(--radius-lg, 24px);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  border: 1px solid var(--light-gray, #EFEFED);
  transition: box-shadow 0.25s ease, transform 0.25s ease;
}
.blog-card:hover {
  box-shadow: 0 16px 48px rgba(0, 0, 0, 0.10);
  transform: translateY(-4px);
}

.blog-card__img-link {
  display: block;
  overflow: hidden;
}
.blog-card__img {
  height: 260px;
  overflow: hidden;
}
.blog-card__img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}
.blog-card:hover .blog-card__img img {
  transform: scale(1.04);
}

.blog-card__body {
  padding: 28px 28px 32px;
  background: var(--off-white, #F7F6F3);
  display: flex;
  flex-direction: column;
  flex: 1;
}

.blog-card__meta {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 14px;
  flex-wrap: wrap;
}
.blog-card__cat {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: #fff;
  background: var(--green, #81AB4C);
  padding: 4px 12px;
  border-radius: var(--radius-pill, 100px);
}
.blog-card__date {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px;
  color: var(--text-light, #888);
  font-weight: 500;
}

.blog-card__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(18px, 2vw, 22px);
  font-weight: 700;
  line-height: 1.3;
  letter-spacing: -0.3px;
  margin-bottom: 12px;
}
.blog-card__title a {
  color: var(--text-dark, #1a1a1a);
  text-decoration: none;
  transition: color 0.2s;
}
.blog-card__title a:hover {
  color: var(--green, #81AB4C);
}

.blog-card__excerpt {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px;
  color: var(--text-mid, #4a4a4a);
  line-height: 1.7;
  flex: 1;
  margin-bottom: 20px;
}

.blog-card__read-more {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 14px;
  font-weight: 700;
  color: var(--green, #81AB4C);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  transition: gap 0.2s;
  align-self: flex-start;
}
.blog-card__read-more:hover {
  gap: 8px;
}

/* ── Buttons ── */
.ip-btn {
  display: inline-block;
  padding: 14px 28px;
  border-radius: var(--radius-pill, 100px);
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px;
  font-weight: 500;
  text-decoration: none;
  transition: all 0.2s;
  border: 2px solid transparent;
  white-space: nowrap;
}
.ip-btn--white {
  background: #fff;
  color: var(--brand, #272E32);
  border-color: #fff;
  font-weight: 600;
}
.ip-btn--white:hover {
  background: var(--off-white, #F7F6F3);
  transform: translateY(-2px);
  color: var(--brand, #272E32);
}
.ip-btn--green {
  background: var(--green, #81AB4C);
  color: #fff;
  border-color: var(--green, #81AB4C);
}
.ip-btn--green:hover {
  background: #6e9640;
  transform: translateY(-2px);
  color: #fff;
}

/* ── CTA BANNER ── */
.ip-cta {
  background: var(--brand, #272E32);
  border-radius: var(--radius-xl, 40px);
  padding: 64px 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
  margin: 0 5%;
}
.ip-cta h2 {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 32px;
  font-weight: 600;
  color: #fff;
  line-height: 1.2;
  max-width: 460px;
  margin: 0;
}
.ip-cta h2 em {
  font-style: italic;
  color: var(--green, #81AB4C);
}
.ip-cta__btns {
  display: flex;
  gap: 14px;
  flex-shrink: 0;
}

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
  .blog-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
@media (max-width: 768px) {
  .blog-intro {
    padding: 56px 5% 32px;
  }
  .blog-grid-wrap {
    padding: 0 5% 56px;
  }
  .blog-grid {
    grid-template-columns: 1fr;
  }
  .ip-cta {
    flex-direction: column;
    padding: 40px 28px;
    text-align: center;
  }
  .ip-cta h2 {
    font-size: 26px;
    max-width: 100%;
  }
  .ip-cta__btns {
    flex-direction: column;
    width: 100%;
  }
}
</style>
