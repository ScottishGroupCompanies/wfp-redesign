---
/* Hallmark · redesign · macrostructure: numbered-alternating-rows · tone: professional-editorial
 * template: benefits.astro · anchor hue: green (#81AB4C) */
import BaseLayout from '../../layouts/BaseLayout.astro';
import InnerPageHero from '../../components/InnerPageHero.astro';
import BrandLogos from '../../components/BrandLogos.astro';
import { Icon } from 'astro-icon/components';

const title = '3M Window Film Philadelphia | Window Film Philadelphia';
const description = 'Upgrade your home or business with 3M window film in Philadelphia. Improve energy efficiency, privacy, aesthetics, and security with expert installation.';

const featuredSections = [
  {
    number: '01',
    heading: '3M Sun Control Window Film',
    body: '3M Sun Control Window Film is one of the most effective energy-saving upgrades available for Philadelphia residential and commercial properties. It reduces solar heat buildup by up to 79%, blocks 99.9% of UV radiation, and cuts glare — all while maintaining clear, natural views. Most properties achieve a full return on investment within three years through HVAC savings alone. Available in a range of visible light transmission levels, Sun Control film is ideal for offices, homes, retail storefronts, and any building with significant glass exposure.',
    img: '/images/3m-commercial-glare-energy-savings-dallas-scaled-1.webp',
    alt: '3M sun control window film Philadelphia',
    href: '/benefits/energy-savings/',
    cta: 'Explore Energy Savings',
  },
  {
    number: '02',
    heading: '3M Scotchshield Safety & Security Window Film',
    body: "3M Scotchshield Safety and Security Window Film is a premium polyester film engineered to hold shattered glass together on impact — protecting building occupants from injury during break-ins, severe weather, and accidents. The tear-resistant film deters smash-and-grab theft by dramatically increasing forced-entry time, provides invisible 24/7 protection, and is trusted by government facilities, schools, and commercial properties throughout Philadelphia. It's available in a range of thickness levels to match your threat profile and budget.",
    img: '/images/safety-window-film-philadelphia-1.webp',
    alt: '3M Scotchshield safety security window film Philadelphia',
    href: '/benefits/safety-and-security/',
    cta: 'Explore Safety & Security',
  },
  {
    number: '03',
    heading: '3M Fasara Decorative Window Film',
    body: '3M Fasara Decorative Window Film transforms ordinary glass into a design element — delivering frosted, etched, geometric, and custom-printed glass aesthetics without the cost or permanence of replacement glass. Fasara films are ideal for conference rooms, office partitions, retail windows, lobbies, and healthcare facilities where privacy, branding, and design all matter. Films are available in over 100 patterns and can be combined with custom digital printing for fully bespoke signage and branding applications.',
    img: '/images/custom-decorative-window-film-philadelphia-scaled-2.webp',
    alt: '3M Fasara decorative window film Philadelphia',
    href: '/benefits/decorative-promotional/',
    cta: 'Explore Decorative Film',
  },
];

const benefitItems = [
  { icon: 'lucide:thermometer',   title: '3M Sun Control',         sub: 'Cuts solar heat gain by up to 79%' },
  { icon: 'lucide:shield-check',  title: '3M Scotchshield',        sub: 'Tear-resistant safety & security film' },
  { icon: 'lucide:palette',       title: '3M Fasara Decorative',   sub: '100+ patterns, custom printing available' },
  { icon: 'lucide:wind',          title: '3M Thinsulate',          sub: 'Year-round climate control & insulation' },
  { icon: 'lucide:sun',           title: 'Daylight Redirecting',   sub: 'Channels natural light deeper indoors' },
  { icon: 'lucide:leaf',          title: 'LEED Eligible',          sub: 'Qualifies for green building credits' },
  { icon: 'lucide:trending-down', title: 'Fast ROI',               sub: 'Most properties recoup in 3 years or less' },
  { icon: 'lucide:award',         title: '3M Certified Install',   sub: 'Manufacturer-backed warranty on all work' },
];
---

<BaseLayout title={title} description={description} canonical="https://www.windowfilmphiladelphia.net/products/3m-window-film/">

<InnerPageHero
  title="3M Window Film Philadelphia"
  bgImage="/images/window-film-warranty-philadelphia.webp"
  desc="Advanced window film solutions for homes and businesses across Philadelphia."
/>

<div class="ip-page-body">

<!-- ══════════════════════════════════════
     INTRO — 2-col: big heading left, text + CTAs right
     ══════════════════════════════════════ -->
<section class="pp-intro">
  <div class="pp-intro__inner">
    <div class="pp-intro__left">
      <span class="pp-eyebrow">3M Products</span>
      <h1 class="pp-intro__title">The World's Most Trusted Window Film Brand.</h1>
    </div>
    <div class="pp-intro__right">
      <p class="pp-intro__lead">3M has been engineering high-performance window films for decades — and Window Film Philadelphia is the region's trusted 3M installer. From Sun Control and Thinsulate films that slash energy costs, to Scotchshield security film and Fasara decorative collections, the 3M lineup covers every goal a Philadelphia property owner could have. One brand. One installer. Exceptional results.</p>
      <div class="pp-intro__ctas">
        <a href="/contact/" class="pp-btn pp-btn--primary">Get a Free Quote</a>
        <a href="/products/" class="pp-btn pp-btn--ghost">All Products</a>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     FEATURED SECTIONS — 3 numbered alternating rows
     ══════════════════════════════════════ -->
<section class="pp-featured">
  <div class="pp-featured__hd">
    <span class="pp-eyebrow">Product Lines</span>
    <h2 class="pp-featured__title">Three flagship 3M films for<br/>Philadelphia properties</h2>
  </div>

  {featuredSections.map((s, i) => (
    <div class={`pp-feat-row fade-in${i % 2 === 1 ? ' pp-feat-row--rev' : ''}`}>
      <div class="pp-feat-row__img">
        <img src={s.img} alt={s.alt} width="600" height="480" loading="lazy" />
        <span class="pp-feat-row__pill">{s.heading}</span>
      </div>
      <div class="pp-feat-row__content">
        <span class="pp-feat-row__num">{s.number}</span>
        <h3 class="pp-feat-row__heading">{s.heading}</h3>
        <p class="pp-feat-row__body">{s.body}</p>
        <a href={s.href} class="pp-feat-row__cta">
          {s.cta}
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/></svg>
        </a>
      </div>
    </div>
  ))}
</section>

<!-- ══════════════════════════════════════
     PRODUCT GRID — 4-col dark icon grid
     ══════════════════════════════════════ -->
<section class="pp-why">
  <div class="pp-why__hd">
    <span class="pp-eyebrow">Full Product Range</span>
    <h2 class="pp-why__title">The complete 3M window film lineup</h2>
  </div>
  <div class="pp-why__grid">
    {benefitItems.map((item) => (
      <div class="pp-why__item fade-in">
        <div class="pp-why__icon"><Icon name={item.icon} width="32" height="32" /></div>
        <div class="pp-why__divider"></div>
        <h4 class="pp-why__item-title">{item.title}</h4>
        <p class="pp-why__item-sub">{item.sub}</p>
      </div>
    ))}
  </div>
</section>

<!-- ══════════════════════════════════════
     FAQ ACCORDION
     ══════════════════════════════════════ -->
<section class="pp-faq">
  <div class="pp-faq__hd">
    <span class="pp-eyebrow">FAQ</span>
    <h2 class="pp-faq__title">Common questions about 3M window film</h2>
  </div>
  <div class="pp-faq__item pp-faq__item--open">
    <div class="pp-faq__q">What 3M window film products does Window Film Philadelphia install? <span class="pp-faq__toggle">+</span></div>
    <div class="pp-faq__a">We install the full 3M architectural window film lineup, including Sun Control (solar/energy), Thinsulate Climate Control (insulation), Scotchshield Safety & Security, Fasara Decorative, Daylight Redirecting, and Night Vision films. We carry both residential-grade and commercial-grade products for every application and budget.</div>
  </div>
  <div class="pp-faq__item">
    <div class="pp-faq__q">How long does 3M window film last, and does it come with a warranty? <span class="pp-faq__toggle">+</span></div>
    <div class="pp-faq__a">3M window films are designed to last 10–20+ years depending on the product, glass type, and sun exposure. All 3M films installed by Window Film Philadelphia include a manufacturer-backed warranty covering film performance, adhesion, and color stability. Residential installations typically carry a lifetime warranty; commercial installations vary by product series.</div>
  </div>
  <div class="pp-faq__item">
    <div class="pp-faq__q">What is the difference between 3M Sun Control and 3M Thinsulate? <span class="pp-faq__toggle">+</span></div>
    <div class="pp-faq__a">3M Sun Control film is primarily a summer product — it rejects solar heat to reduce cooling costs and glare. 3M Thinsulate Climate Control film is engineered for year-round performance, adding an insulating layer that retains interior heat in winter while still rejecting solar heat in summer. For Philadelphia's four-season climate, Thinsulate often delivers a better year-round ROI, while Sun Control is ideal for high-sun southern and western exposures.</div>
  </div>
  <div class="pp-faq__item">
    <div class="pp-faq__q">Can 3M window film be applied to double-pane insulated glass? <span class="pp-faq__toggle">+</span></div>
    <div class="pp-faq__a">Yes — 3M makes specific film series designed for insulated glass units (IGUs). Selecting the wrong film for double-pane glass can cause thermal stress and seal failure, which is why professional assessment matters. Our team evaluates your glass type, orientation, and goals before recommending a film, ensuring you stay within 3M's approved specifications and don't void your window manufacturer's warranty.</div>
  </div>
  <div class="pp-faq__item">
    <div class="pp-faq__q">How does 3M Daylight Redirecting film work, and where is it most useful? <span class="pp-faq__toggle">+</span></div>
    <div class="pp-faq__a">3M Daylight Redirecting film uses a microstructured prismatic surface to redirect incoming sunlight upward toward the ceiling, distributing natural light deep into a room — up to 40 feet from the window. This reduces the need for artificial lighting near window walls and dramatically improves daylighting in spaces like open-plan offices, classrooms, and healthcare facilities. It's particularly effective on south- and west-facing facades.</div>
  </div>
  <div class="pp-faq__item">
    <div class="pp-faq__q">How quickly will I see a return on investment from 3M window film? <span class="pp-faq__toggle">+</span></div>
    <div class="pp-faq__a">Commercial properties with large glazing areas typically see full ROI within 2–3 years through energy savings alone. Residential properties typically see ROI within 3–5 years. For security films like Scotchshield, the ROI calculation also includes avoided theft losses, reduced insurance premiums (in some cases), and deferred glass replacement costs. Our team can provide a customized projection during your free consultation.</div>
  </div>
</section>

<!-- ══════════════════════════════════════
     BRAND LOGOS
     ══════════════════════════════════════ -->
<BrandLogos />

<!-- ══════════════════════════════════════
     CTA BANNER
     ══════════════════════════════════════ -->
<div class="pp-cta fade-in">
  <h2>Ready to upgrade your property with <em>3M window film?</em></h2>
  <div class="pp-cta__btns">
    <a href="/contact/" class="pp-btn pp-btn--white">Get a Free Quote</a>
    <a href="tel:+12673947980" class="pp-btn pp-btn--green">Call (267) 394-7980</a>
  </div>
</div>

</div><!-- end ip-page-body -->
</BaseLayout>

<style>
/* ── PAGE BODY WRAPPER ── */
.ip-page-body {
  position: relative;
  background: #ffffff;
  border-top-left-radius: 40px;
  border-top-right-radius: 40px;
  border-bottom-left-radius: 40px;
  border-bottom-right-radius: 40px;
  margin-top: -40px;
  z-index: 10;
  overflow: visible;
  padding-bottom: 80px;
}

/* ── EYEBROW ── */
.pp-eyebrow {
  display: inline-block;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--green, #81AB4C);
  margin-bottom: 16px;
}

/* ── BUTTONS ── */
.pp-btn {
  display: inline-block; padding: 14px 28px;
  border-radius: var(--radius-pill, 100px);
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; font-weight: 500;
  text-decoration: none; transition: all 0.2s;
  border: 2px solid transparent; white-space: nowrap;
}
.pp-btn--primary { background: var(--green, #81AB4C); color: #fff; border-color: var(--green, #81AB4C); }
.pp-btn--primary:hover { background: #6e9640; border-color: #6e9640; transform: translateY(-2px); color: #fff; }
.pp-btn--ghost { background: transparent; color: var(--brand, #272E32); border-color: var(--brand, #272E32); }
.pp-btn--ghost:hover { background: var(--brand, #272E32); color: #fff; transform: translateY(-2px); }
.pp-btn--white { background: #fff; color: var(--brand, #272E32); border-color: #fff; font-weight: 600; }
.pp-btn--white:hover { background: var(--off-white, #F7F6F3); transform: translateY(-2px); }
.pp-btn--green { background: var(--green, #81AB4C); color: #fff; border-color: var(--green, #81AB4C); }
.pp-btn--green:hover { background: #6e9640; transform: translateY(-2px); color: #fff; }

/* ── INTRO ── */
.pp-intro {
  padding: 80px 10%;
  border-top-left-radius: 40px;
  border-top-right-radius: 40px;
  overflow: hidden;
}
.pp-intro__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}
.pp-intro__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(36px, 4.5vw, 58px);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -1px;
  color: var(--text-dark, #1a1a1a);
  margin: 0;
}
.pp-intro__lead {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 17px;
  color: var(--text-mid, #4a4a4a);
  line-height: 1.75;
  margin-bottom: 32px;
}
.pp-intro__ctas { display: flex; gap: 14px; flex-wrap: wrap; }

/* ── FEATURED SECTIONS ── */
.pp-featured {
  padding: 100px 10%;
  background: var(--off-white, #F7F6F3);
}
.pp-featured__hd { margin-bottom: 72px; }
.pp-featured__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(32px, 4vw, 52px);
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: -0.5px;
  color: var(--text-dark, #1a1a1a);
  margin: 0;
}
.pp-feat-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  margin-bottom: 100px;
}
.pp-feat-row:last-child { margin-bottom: 0; }
.pp-feat-row--rev .pp-feat-row__img { order: 2; }
.pp-feat-row--rev .pp-feat-row__content { order: 1; }
.pp-feat-row__img {
  position: relative;
  height: 480px;
  border-radius: 32px;
  overflow: hidden;
}
.pp-feat-row__img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.pp-feat-row__pill {
  position: absolute; bottom: 24px; left: 24px;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(8px);
  padding: 10px 18px;
  border-radius: 100px;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px; font-weight: 600;
  color: var(--brand, #272E32);
  box-shadow: 0 4px 16px rgba(0,0,0,0.1);
}
.pp-feat-row__num {
  display: block;
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 72px; font-weight: 700;
  color: var(--green, #81AB4C);
  line-height: 1; opacity: 0.25;
  margin-bottom: -8px;
}
.pp-feat-row__heading {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(24px, 3vw, 36px);
  font-weight: 700;
  color: var(--text-dark, #1a1a1a);
  line-height: 1.2;
  margin-bottom: 20px;
  letter-spacing: -0.3px;
}
.pp-feat-row__body {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 16px;
  color: var(--text-mid, #4a4a4a);
  line-height: 1.8;
  margin-bottom: 28px;
}
.pp-feat-row__cta {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; font-weight: 600;
  color: var(--green, #81AB4C);
  text-decoration: none;
  transition: gap 0.2s;
}
.pp-feat-row__cta:hover { gap: 14px; }

/* ── PRODUCT GRID (dark) ── */
.pp-why {
  background: var(--brand, #272E32);
  padding: 100px 10%;
}
.pp-why__hd { margin-bottom: 64px; }
.pp-why__hd .pp-eyebrow { color: var(--green, #81AB4C); }
.pp-why__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(28px, 3.5vw, 48px);
  font-weight: 700;
  color: #ffffff;
  line-height: 1.15;
  letter-spacing: -0.5px;
  margin: 0;
  max-width: 600px;
}
.pp-why__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
}
.pp-why__item {
  padding: 32px 28px;
  border-right: 1px solid rgba(255,255,255,0.1);
  border-bottom: 1px solid rgba(255,255,255,0.1);
}
.pp-why__item:nth-child(4n) { border-right: none; }
.pp-why__item:nth-child(n+5) { border-bottom: none; }
.pp-why__icon {
  color: var(--green, #81AB4C);
  margin-bottom: 16px;
  display: flex; align-items: center; line-height: 1;
}
.pp-why__icon svg { display: block; }
.pp-why__divider {
  width: 32px; height: 2px;
  background: var(--green, #81AB4C);
  margin-bottom: 16px;
}
.pp-why__item-title {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; font-weight: 700;
  color: #ffffff;
  margin-bottom: 6px;
}
.pp-why__item-sub {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px;
  color: rgba(255,255,255,0.5);
  margin: 0; line-height: 1.5;
}

/* ── FAQ ── */
.pp-faq { padding: 100px 10%; background: #ffffff; }
.pp-faq__hd { margin-bottom: 48px; }
.pp-faq__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(28px, 3.5vw, 48px);
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: -0.5px;
  color: var(--text-dark, #1a1a1a);
  max-width: 560px; margin: 0;
}
.pp-faq__item {
  border-bottom: 1px solid var(--light-gray, #EFEFED);
  padding: 24px 0;
  cursor: pointer;
  max-width: 900px;
}
.pp-faq__item:first-of-type { border-top: 1px solid var(--light-gray, #EFEFED); }
.pp-faq__q {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 17px; font-weight: 600;
  color: var(--text-dark, #1a1a1a);
  display: flex; justify-content: space-between; align-items: center; gap: 12px;
}
.pp-faq__toggle { color: var(--green, #81AB4C); font-size: 22px; flex-shrink: 0; transition: transform 0.2s; }
.pp-faq__a {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; color: var(--text-mid, #4a4a4a); line-height: 1.75;
  margin-top: 14px; display: none;
}
.pp-faq__item--open .pp-faq__a { display: block; }
.pp-faq__item--open .pp-faq__toggle { transform: rotate(45deg); }

/* ── CTA BANNER ── */
.pp-cta {
  background: var(--brand, #272E32);
  border-radius: 40px;
  padding: 64px 60px;
  display: flex; align-items: center;
  justify-content: space-between;
  gap: 40px;
  margin: 0 5% 0;
}
.pp-cta h2 {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 32px; font-weight: 700;
  color: #fff; line-height: 1.2;
  max-width: 460px; margin: 0;
}
.pp-cta h2 em { font-style: italic; color: var(--green, #81AB4C); }
.pp-cta__btns { display: flex; gap: 14px; flex-shrink: 0; }

/* ── FADE IN ── */
.fade-in { opacity: 0; transform: translateY(24px); transition: opacity 0.65s ease, transform 0.65s ease; }
.fade-in.visible { opacity: 1; transform: translateY(0); }

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
  .pp-intro__inner { grid-template-columns: 1fr; gap: 40px; }
  .pp-feat-row { grid-template-columns: 1fr; gap: 40px; }
  .pp-feat-row--rev .pp-feat-row__img { order: 0; }
  .pp-feat-row--rev .pp-feat-row__content { order: 1; }
  .pp-why__grid { grid-template-columns: repeat(2, 1fr); }
  .pp-why__item:nth-child(4n) { border-right: 1px solid rgba(255,255,255,0.1); }
  .pp-why__item:nth-child(2n) { border-right: none; }
}
@media (max-width: 768px) {
  .pp-intro { padding: 60px 5%; }
  .pp-featured { padding: 60px 5%; }
  .pp-why { padding: 60px 5%; }
  .pp-faq { padding: 60px 5%; }
  .pp-feat-row__img { height: 300px; }
  .pp-why__grid { grid-template-columns: 1fr; }
  .pp-cta { flex-direction: column; padding: 40px 28px; text-align: center; }
  .pp-cta h2 { font-size: 26px; max-width: 100%; }
  .pp-cta__btns { flex-direction: column; width: 100%; }
}
@media (max-width: 480px) {
  .pp-intro__ctas { flex-direction: column; }
}
</style>

<script>
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-in').forEach(el => obs.observe(el));

  document.querySelectorAll('.pp-faq__item').forEach(item => {
    item.querySelector('.pp-faq__q')?.addEventListener('click', () => {
      const isOpen = item.classList.contains('pp-faq__item--open');
      document.querySelectorAll('.pp-faq__item').forEach(i => i.classList.remove('pp-faq__item--open'));
      if (!isOpen) item.classList.add('pp-faq__item--open');
    });
  });
</script>
