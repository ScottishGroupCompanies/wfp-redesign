---
/* Hallmark · redesign · macrostructure: numbered-alternating-rows · tone: professional-editorial
 * template: benefits.astro · anchor hue: green (#81AB4C) */
import BaseLayout from '../../layouts/BaseLayout.astro';
import InnerPageHero from '../../components/InnerPageHero.astro';
import BrandLogos from '../../components/BrandLogos.astro';
import { Icon } from 'astro-icon/components';

const title = 'HDClear Window Film Philadelphia | Window Film Philadelphia';
const description = 'Elevate interiors with HDClear Window Film in Philadelphia, featuring custom designs, added privacy, and improved aesthetics for any space.';

const featuredSections = [
  {
    number: '01',
    heading: 'HDClear Custom Decorative Window Film',
    body: 'HDClear Decorative uses optically clear polyester films with multiple HD graphics layers and UV-resistant inks. Available in double-sided, translucent, and transparent configurations with custom printing — perfect for storefront displays, marketing graphics, branded interior privacy solutions, and conference room partitions. Over 100 design options are available, and the Window Film Philadelphia team handles the complete design-to-installation workflow.',
    img: '/images/frosted-privacy-window-film-scaled-5.jpeg',
    alt: 'HDClear custom decorative window film Philadelphia',
    href: '/benefits/decorative-promotional/',
    cta: 'Explore Decorative Film',
  },
  {
    number: '02',
    heading: 'HDSolar Energy Reduction Window Film',
    body: 'HDSolar is an optically clear solar heat solution that delivers energy savings without impacting your building\'s aesthetics. It provides a full payback in 2–5 years, blocks 97% of infrared heat, and rejects 99.9% of UV radiation — all while minimizing glare and maintaining natural light. Ideal for Philadelphia offices and commercial properties with high solar exposure and energy-efficiency goals.',
    img: '/images/hdclear-custom-decorative-window-film-philadelphia.jpg',
    alt: 'HDSolar energy reduction window film Philadelphia',
    href: '/benefits/energy-savings/',
    cta: 'Explore Energy Savings',
  },
  {
    number: '03',
    heading: 'HDSafety Security Window Film',
    body: 'HDSafety Security Window Film is thick, durable, and provides high-impact resistance for glass surfaces. It helps prevent break-ins by providing additional response time, mitigates broken glass hazards from severe weather and accidents, and minimizes property damage from forced entry attempts. Available in multiple thickness levels for different security profiles, HDSafety is a reliable choice for Philadelphia commercial and residential properties.',
    img: '/images/safety-and-security-window-film-philadelphia.png',
    alt: 'HDSafety security window film Philadelphia',
    href: '/benefits/safety-and-security/',
    cta: 'Explore Safety & Security',
  },
];

const benefitItems = [
  { icon: 'lucide:palette', title: 'HD Decorative', sub: 'Vibrant one-way graphics and custom printing' },
  { icon: 'lucide:thermometer', title: 'HDSolar', sub: 'Blocks 97% of infrared heat' },
  { icon: 'lucide:shield-check', title: 'HDSafety', sub: 'High-impact security film' },
  { icon: 'lucide:sun', title: 'UV Protection', sub: 'Blocks 99.9% UV radiation' },
  { icon: 'lucide:printer', title: 'Custom Print', sub: 'Double-sided and translucent options' },
  { icon: 'lucide:trending-down', title: 'Energy ROI', sub: 'Payback in 2–5 years' },
  { icon: 'lucide:eye-off', title: 'Privacy', sub: 'One-way view and frosted options' },
  { icon: 'lucide:layers', title: 'Multi-Layer', sub: 'UV-resistant ink technology' },
];
---

<BaseLayout title={title} description={description} canonical="https://www.windowfilmphiladelphia.net/products/hdclear-window-film/">

<InnerPageHero
  title="HDClear Window Film Philadelphia"
  bgImage="/images/hdclear-window-film-philadelphia-1.png"
  desc="Precision graphics, solar performance, and security in one brand."
/>

<div class="ip-page-body">

<section class="pp-intro">
  <div class="pp-intro__inner">
    <div class="pp-intro__left">
      <span class="pp-eyebrow">HDClear Films</span>
      <h1 class="pp-intro__title">Precision Graphics. Proven Performance.</h1>
    </div>
    <div class="pp-intro__right">
      <p class="pp-intro__lead">HDClear is a premium window film brand offering three purpose-built product lines: HDClear Decorative for custom graphics and privacy, HDSolar for energy savings and UV protection, and HDSafety for security and impact resistance. Window Film Philadelphia installs the full HDClear lineup for residential and commercial properties throughout Philadelphia.</p>
      <div class="pp-intro__ctas">
        <a href="/contact/" class="pp-btn pp-btn--primary">Get a Free Quote</a>
        <a href="/products/" class="pp-btn pp-btn--ghost">All Products</a>
      </div>
    </div>
  </div>
</section>

<section class="pp-featured">
  <div class="pp-featured__hd">
    <span class="pp-eyebrow">Product Lines</span>
    <h2 class="pp-featured__title">Three HDClear film series for Philadelphia properties</h2>
  </div>

  {featuredSections.map((s, i) => (
    <div class={`pp-feat-row fade-in${i % 2 === 1 ? ' pp-feat-row--rev' : ''}`}>
      <div class="pp-feat-row__img">
        <img src={s.img} alt={s.alt} width="600" height="480" loading="lazy" />
        <span class="pp-feat-row__pill">{s.heading}</span>
      </div>
      <div class="pp-feat-row__content">
        <span class="pp-feat-row__num">{s.number}</span>
        <h3 class="pp-feat-row__heading">{s.heading}</h3>
        <p class="pp-feat-row__body">{s.body}</p>
        <a href={s.href} class="pp-feat-row__cta">
          {s.cta}
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/></svg>
        </a>
      </div>
    </div>
  ))}
</section>

<section class="pp-why">
  <div class="pp-why__hd">
    <span class="pp-eyebrow">Product Range</span>
    <h2 class="pp-why__title">The complete HDClear product lineup</h2>
  </div>
  <div class="pp-why__grid">
    {benefitItems.map((item) => (
      <div class="pp-why__item fade-in">
        <div class="pp-why__icon"><Icon name={item.icon} width="32" height="32" /></div>
        <div class="pp-why__divider"></div>
        <h4 class="pp-why__item-title">{item.title}</h4>
        <p class="pp-why__item-sub">{item.sub}</p>
      </div>
    ))}
  </div>
</section>

<section class="pp-faq">
  <div class="pp-faq__hd">
    <span class="pp-eyebrow">FAQ</span>
    <h2 class="pp-faq__title">Common questions about HDClear window film</h2>
  </div>
  <div class="pp-faq__item pp-faq__item--open">
    <div class="pp-faq__q">What is the difference between HDClear, HDSolar, and HDSafety? <span class="pp-faq__toggle">+</span></div>
    <div class="pp-faq__a">HDClear Decorative is designed for custom graphics, branding, and privacy solutions. HDSolar is an energy and solar performance film that blocks infrared heat and UV radiation. HDSafety is a security and impact resistance film designed to hold glass together during forced entry, accidents, or severe weather. Each is a distinct product line optimized for a different purpose.</div>
  </div>
  <div class="pp-faq__item">
    <div class="pp-faq__q">Can HDClear Decorative film include my company's logo or brand colors? <span class="pp-faq__toggle">+</span></div>
    <div class="pp-faq__a">Yes. HDClear Decorative supports fully custom printing with UV-resistant inks. The Window Film Philadelphia team handles the complete design-to-installation workflow — from artwork preparation through final installation.</div>
  </div>
  <div class="pp-faq__item">
    <div class="pp-faq__q">How energy-efficient is HDSolar compared to other films? <span class="pp-faq__toggle">+</span></div>
    <div class="pp-faq__a">HDSolar delivers best-in-class infrared heat rejection at 97%, while maintaining optical clarity — meaning your building's appearance is unchanged. Most installations achieve full payback in 2–5 years through reduced cooling and heating costs.</div>
  </div>
  <div class="pp-faq__item">
    <div class="pp-faq__q">Is HDSafety film visible on the glass? <span class="pp-faq__toggle">+</span></div>
    <div class="pp-faq__a">No. HDSafety is clear and invisible — the appearance of the glass is unchanged after installation. It provides passive, invisible protection that works silently around the clock without altering your windows' look.</div>
  </div>
  <div class="pp-faq__item">
    <div class="pp-faq__q">Can I combine an HDClear decorative film with solar or security performance? <span class="pp-faq__toggle">+</span></div>
    <div class="pp-faq__a">Yes. Certain configurations allow decorative and functional layers to be combined — for example, a frosted decorative film with solar control properties. The Window Film Philadelphia team will advise on the right combination for your specific goals during the consultation.</div>
  </div>
  <div class="pp-faq__item">
    <div class="pp-faq__q">How long does HDClear window film last? <span class="pp-faq__toggle">+</span></div>
    <div class="pp-faq__a">HDClear products typically last 10–20+ years with professional installation. A manufacturer warranty is included on all HDClear products covering performance and adhesion.</div>
  </div>
</section>

<BrandLogos />

<div class="pp-cta fade-in">
  <h2>Ready to upgrade your property with <em>HDClear window film?</em></h2>
  <div class="pp-cta__btns">
    <a href="/contact/" class="pp-btn pp-btn--white">Get a Free Quote</a>
    <a href="tel:+12673947980" class="pp-btn pp-btn--green">Call (267) 394-7980</a>
  </div>
</div>

</div>
</BaseLayout>

<style>
/* ── PAGE BODY WRAPPER ── */
.ip-page-body {
  position: relative;
  background: #ffffff;
  border-top-left-radius: 40px;
  border-top-right-radius: 40px;
  border-bottom-left-radius: 40px;
  border-bottom-right-radius: 40px;
  margin-top: -40px;
  z-index: 10;
  overflow: visible;
  padding-bottom: 80px;
}
.pp-eyebrow {
  display: inline-block;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 11px; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--green, #81AB4C); margin-bottom: 16px;
}
.pp-btn {
  display: inline-block; padding: 14px 28px;
  border-radius: var(--radius-pill, 100px);
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; font-weight: 500;
  text-decoration: none; transition: all 0.2s;
  border: 2px solid transparent; white-space: nowrap;
}
.pp-btn--primary { background: var(--green, #81AB4C); color: #fff; border-color: var(--green, #81AB4C); }
.pp-btn--primary:hover { background: #6e9640; border-color: #6e9640; transform: translateY(-2px); color: #fff; }
.pp-btn--ghost { background: transparent; color: var(--brand, #272E32); border-color: var(--brand, #272E32); }
.pp-btn--ghost:hover { background: var(--brand, #272E32); color: #fff; transform: translateY(-2px); }
.pp-btn--white { background: #fff; color: var(--brand, #272E32); border-color: #fff; font-weight: 600; }
.pp-btn--white:hover { background: var(--off-white, #F7F6F3); transform: translateY(-2px); }
.pp-btn--green { background: var(--green, #81AB4C); color: #fff; border-color: var(--green, #81AB4C); }
.pp-btn--green:hover { background: #6e9640; transform: translateY(-2px); color: #fff; }
.pp-intro { padding: 80px 10%; border-top-left-radius: 40px; border-top-right-radius: 40px; overflow: hidden; }
.pp-intro__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
.pp-intro__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(36px, 4.5vw, 58px); font-weight: 700;
  line-height: 1.1; letter-spacing: -1px;
  color: var(--text-dark, #1a1a1a); margin: 0;
}
.pp-intro__lead {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 17px; color: var(--text-mid, #4a4a4a);
  line-height: 1.75; margin-bottom: 32px;
}
.pp-intro__ctas { display: flex; gap: 14px; flex-wrap: wrap; }
.pp-featured { padding: 100px 10%; background: var(--off-white, #F7F6F3); }
.pp-featured__hd { margin-bottom: 72px; }
.pp-featured__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(32px, 4vw, 52px); font-weight: 700;
  line-height: 1.15; letter-spacing: -0.5px;
  color: var(--text-dark, #1a1a1a); margin: 0;
}
.pp-feat-row { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; margin-bottom: 100px; }
.pp-feat-row:last-child { margin-bottom: 0; }
.pp-feat-row--rev .pp-feat-row__img { order: 2; }
.pp-feat-row--rev .pp-feat-row__content { order: 1; }
.pp-feat-row__img { position: relative; height: 480px; border-radius: 32px; overflow: hidden; }
.pp-feat-row__img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.pp-feat-row__pill {
  position: absolute; bottom: 24px; left: 24px;
  background: rgba(255,255,255,0.92); backdrop-filter: blur(8px);
  padding: 10px 18px; border-radius: 100px;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px; font-weight: 600; color: var(--brand, #272E32);
  box-shadow: 0 4px 16px rgba(0,0,0,0.1);
}
.pp-feat-row__num {
  display: block; font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 72px; font-weight: 700; color: var(--green, #81AB4C);
  line-height: 1; opacity: 0.25; margin-bottom: -8px;
}
.pp-feat-row__heading {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(24px, 3vw, 36px); font-weight: 700;
  color: var(--text-dark, #1a1a1a); line-height: 1.2;
  margin-bottom: 20px; letter-spacing: -0.3px;
}
.pp-feat-row__body {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 16px; color: var(--text-mid, #4a4a4a);
  line-height: 1.8; margin-bottom: 28px;
}
.pp-feat-row__cta {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; font-weight: 600; color: var(--green, #81AB4C);
  text-decoration: none; transition: gap 0.2s;
}
.pp-feat-row__cta:hover { gap: 14px; }
.pp-why { background: var(--brand, #272E32); padding: 100px 10%; }
.pp-why__hd { margin-bottom: 64px; }
.pp-why__hd .pp-eyebrow { color: var(--green, #81AB4C); }
.pp-why__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(28px, 3.5vw, 48px); font-weight: 700;
  color: #ffffff; line-height: 1.15; letter-spacing: -0.5px;
  margin: 0; max-width: 600px;
}
.pp-why__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; }
.pp-why__item { padding: 32px 28px; border-right: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1); }
.pp-why__item:nth-child(4n) { border-right: none; }
.pp-why__item:nth-child(n+5) { border-bottom: none; }
.pp-why__icon { color: var(--green, #81AB4C); margin-bottom: 16px; display: flex; align-items: center; line-height: 1; }
.pp-why__icon svg { display: block; }
.pp-why__divider { width: 32px; height: 2px; background: var(--green, #81AB4C); margin-bottom: 16px; }
.pp-why__item-title { font-family: var(--font-body, 'DM Sans', sans-serif); font-size: 15px; font-weight: 700; color: #ffffff; margin-bottom: 6px; }
.pp-why__item-sub { font-family: var(--font-body, 'DM Sans', sans-serif); font-size: 13px; color: rgba(255,255,255,0.5); margin: 0; line-height: 1.5; }
.pp-faq { padding: 100px 10%; background: #ffffff; }
.pp-faq__hd { margin-bottom: 48px; }
.pp-faq__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(28px, 3.5vw, 48px); font-weight: 700;
  line-height: 1.15; letter-spacing: -0.5px;
  color: var(--text-dark, #1a1a1a); max-width: 560px; margin: 0;
}
.pp-faq__item { border-bottom: 1px solid var(--light-gray, #EFEFED); padding: 24px 0; cursor: pointer; max-width: 900px; }
.pp-faq__item:first-of-type { border-top: 1px solid var(--light-gray, #EFEFED); }
.pp-faq__q { font-family: var(--font-body, 'DM Sans', sans-serif); font-size: 17px; font-weight: 600; color: var(--text-dark, #1a1a1a); display: flex; justify-content: space-between; align-items: center; gap: 12px; }
.pp-faq__toggle { color: var(--green, #81AB4C); font-size: 22px; flex-shrink: 0; transition: transform 0.2s; }
.pp-faq__a { font-family: var(--font-body, 'DM Sans', sans-serif); font-size: 15px; color: var(--text-mid, #4a4a4a); line-height: 1.75; margin-top: 14px; display: none; }
.pp-faq__item--open .pp-faq__a { display: block; }
.pp-faq__item--open .pp-faq__toggle { transform: rotate(45deg); }
.pp-cta {
  background: var(--brand, #272E32); border-radius: 40px;
  padding: 64px 60px; display: flex; align-items: center;
  justify-content: space-between; gap: 40px; margin: 0 5% 0;
}
.pp-cta h2 { font-family: var(--font-serif, 'Playfair Display', serif); font-size: 32px; font-weight: 700; color: #fff; line-height: 1.2; max-width: 460px; margin: 0; }
.pp-cta h2 em { font-style: italic; color: var(--green, #81AB4C); }
.pp-cta__btns { display: flex; gap: 14px; flex-shrink: 0; }
.fade-in { opacity: 0; transform: translateY(24px); transition: opacity 0.65s ease, transform 0.65s ease; }
.fade-in.visible { opacity: 1; transform: translateY(0); }
@media (max-width: 1024px) {
  .pp-intro__inner { grid-template-columns: 1fr; gap: 40px; }
  .pp-feat-row { grid-template-columns: 1fr; gap: 40px; }
  .pp-feat-row--rev .pp-feat-row__img { order: 0; }
  .pp-feat-row--rev .pp-feat-row__content { order: 1; }
  .pp-why__grid { grid-template-columns: repeat(2, 1fr); }
  .pp-why__item:nth-child(4n) { border-right: 1px solid rgba(255,255,255,0.1); }
  .pp-why__item:nth-child(2n) { border-right: none; }
}
@media (max-width: 768px) {
  .pp-intro { padding: 60px 5%; }
  .pp-featured { padding: 60px 5%; }
  .pp-why { padding: 60px 5%; }
  .pp-faq { padding: 60px 5%; }
  .pp-feat-row__img { height: 300px; }
  .pp-why__grid { grid-template-columns: 1fr; }
  .pp-cta { flex-direction: column; padding: 40px 28px; text-align: center; }
  .pp-cta h2 { font-size: 26px; max-width: 100%; }
  .pp-cta__btns { flex-direction: column; width: 100%; }
}
@media (max-width: 480px) {
  .pp-intro__ctas { flex-direction: column; }
}
</style>

<script>
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-in').forEach(el => obs.observe(el));

  document.querySelectorAll('.pp-faq__item').forEach(item => {
    item.querySelector('.pp-faq__q')?.addEventListener('click', () => {
      const isOpen = item.classList.contains('pp-faq__item--open');
      document.querySelectorAll('.pp-faq__item').forEach(i => i.classList.remove('pp-faq__item--open'));
      if (!isOpen) item.classList.add('pp-faq__item--open');
    });
  });
</script>
