---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackAndForthSection from '../../components/BackAndForthSection.astro';
import BrandLogos from '../../components/BrandLogos.astro';
import CTAStrip from '../../components/CTAStrip.astro';

const title = 'Nanotint Window Film Philadelphia | Window Film Philadelphia';
const description = 'Experience superior comfort with Nanotint in Philadelphia, a clear coating that improves insulation, blocks UV rays, and fits curved glass.';
---

<BaseLayout title={title} description={description} canonical='https://www.windowfilmphiladelphia.net/products/nanotint-window-film/'>

  <section class="page-hero" style="background-image: linear-gradient(rgba(40,40,40,0.62), rgba(40,40,40,0.80)), url('/images/drywired-liquid-nanotint-window-film-philadelphia.png'); background-size: cover; background-position: center;">
    <div class="container">
      <h1>Nanotint Window Film in Philadelphia</h1>
    </div>
  </section>

  <BackAndForthSection
    heading={'Nanotint Window Film in Philadelphia'}
    body={'Drywired Liquid NanoTint is a transparent, energy-efficient coating for windows that cannot accommodate traditional film. It maintains full optical clarity while improving thermal insulation — ideal for skylights, curved glass, hard-to-reach areas, and any property requiring a non-RF-blocking formula.'}
    imageSrc={'/images/drywired-liquid-nanotint-window-film-philadelphia.png'}
    imageAlt={'Nanotint window film Philadelphia'}
    flip={false}
    altBg={false}
  />

  <BackAndForthSection
    heading={'About Drywired Liquid NanoTint'}
    body={'Drywired Liquid NanoTint provides effective thermal insulation for glass features along with UV protection. It is ideal for abnormal-shaped windows and skylights, and is optically clear without impacting radio transmission frequencies — making it the perfect solution for commercial properties requiring full radio signaling.'}
    imageSrc={'/images/liquid-nanotint-philadelphia-1.jpg'}
    imageAlt={'Drywired liquid NanoTint Philadelphia'}
    flip={true}
    altBg={true}
  />

  <BackAndForthSection
    heading={'The Benefits of Drywired Liquid NanoTint for Philadelphia Properties'}
    body={'Drywired Liquid NanoTint provides outstanding benefits including: blocking up to 95% of infrared heat while allowing 90% visible light transmission, rejecting up to 99.9% of UVA and UVB radiation, not cracking, peeling, or fading for up to a decade, not impacting radio transmission frequencies, and providing year-round climate control and energy efficiency.'}
    imageSrc={'/images/drywired-liquid-nanotint-philadelphia-1.jpg'}
    imageAlt={'NanoTint benefits Philadelphia'}
    flip={false}
    altBg={false}
  />

  <BackAndForthSection
    heading={'Partner With Philadelphia\'s Trusted Liquid NanoTint Specialists'}
    body={'Window Film Philadelphia provides professional Drywired Liquid NanoTint installation for Philadelphia properties with unusual window designs, skylights, or curved glass. Our team delivers UV protection, greater comfort, and energy savings to even the most challenging installations. Contact us today.'}
    imageSrc={'/images/2021-10-window-film-installation-philadelphia.jpg'}
    imageAlt={'NanoTint specialist Philadelphia'}
    flip={true}
    altBg={true}
    ctaLabel={'Get a Free Quote'}
    ctaHref={'/contact/'}
  />

  <BrandLogos />
  <CTAStrip />

</BaseLayout>
