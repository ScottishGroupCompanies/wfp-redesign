---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackAndForthSection from '../../components/BackAndForthSection.astro';

const title = 'Commercial Window Film Specifications | Window Film Philadelphia';
const description = 'Window Film Philadelphia is happy to provide commercial window film specifications for your upcoming project. Get your free quote today!';
import BrandLogos from '../../components/BrandLogos.astro';
import CTAStrip from '../../components/CTAStrip.astro';
---

<BaseLayout title={title} description={description} canonical='https://www.windowfilmphiladelphia.net/resources/architects-builders/'>
  <section class="page-hero" style="background-image: linear-gradient(rgba(40,40,40,0.62), rgba(40,40,40,0.80)), url('/images/commercial-window-film-specs-philadelphia.png'); background-size: cover; background-position: center;">
    <div class="container">
      <h1>Window Film Specifications for Philadelphia Architects and Custom Builders</h1>
    </div>
  </section>

  <BackAndForthSection
  heading={'Window Film Specifications for Philadelphia Architects and Custom Builders'}
  body={'For architects and custom builders in the Philadelphia area, we’re happy to provide a comprehensive list of window film specifications for your upcoming project. If you don’t see the specifications for a certain window film product that you’re interested in, please contact us for more details. Our team is always happy to work alongside other contractors in order to optimize your commercial project.'}
  imageSrc={'/images/commercial-window-film-specs-philadelphia.png'}
  imageAlt={'commercial window film specs philadelphia'}
  flip={false}
  altBg={false}
/>

  <BackAndForthSection
  heading={'3M'}
  body={'3m-thinsulate-window-film-climate-control-philadelphia 3M-Fasara-Window-Film-Brochure-philadelphia 3M-Fasara-Window-Film-Collection-philadelphia 3M-Fasara-Window-Films-Data-Sheet-philadelphia 3M-Fasara-Window-Film-Glass-Finishes-philadelphia 3m-thinsulate-window-film-philadelphia-brochure 3m-daylight-redirecting-window-film-philadelphia-case-'}
  imageSrc={'/images/commercial-window-film-specifications-philadelphia.jpg'}
  imageAlt={'commercial window film specifications philadelphia'}
  flip={true}
  altBg={true}
/>

  <BackAndForthSection
  heading={'Casper'}
  body={'casper-cloaking-film-technical-sheet-philadelphia'}
  imageSrc={'/images/window-film-specs-philadelphia.jpg'}
  imageAlt={'window film specs philadelphia'}
  flip={false}
  altBg={false}
/>

  <section class="section-pad">
  <div class="container">
    <h2>Hanita Coatings</h2>
    <p>Hanita_Coatings_Architectural_Tint_Specs Hanita_Coatings_SolarZone_Datasheets Hanita_Coatings_SafetyZone_Datasheets Hanita_Coatings_Performance_Data Hanita_Coatings_compatibility_chart</p>
  </div>
</section>

  <section class="section-pad">
  <div class="container">
    <h2>Huper Optik</h2>
    <p>HuperOptik_Shield_Specs_philadelphia HuperOptiks_ThermX_Specs_philadelphia HuperOptik_Decorative_Film_Specs_philadelphia HuperOptiks_Fusion_Specs_philadelphia HuperOptiks_Select_Series_Specifications_philadelphia HuperOptiks_Traditional_Specs_philadelphia</p>
  </div>
</section>

  <section class="section-pad">
  <div class="container">
    <h2>C-Bond</h2>
    <p>C-Bond-System-I-Specs-philadelphia C-Bond-Test-Report-2-philadelphia C-Bond-Test-Report-1-philadelphia C-Bond-System-Safety-Data-Sheet-philadelphia C-Bond-System-II-Specs-philadelphia</p>
  </div>
</section>

  <section class="section-pad">
  <div class="container">
    <h2>Solar Gard</h2>
    <p>Solar-Gard-Graffitigard-Data-Sheet-philadelphia</p>
  </div>
</section>

  <section class="section-pad">
  <div class="container">
    <h2>LLumar</h2>
    <p>llumar-safety-securty-window-film-specs-philadelphia llumar-solar-control-window-tint-specs-philadelphia llumar_safety_security_film_testing_data_sheet_philadelphia llumar-anti-graffiti-film-specs-philadelphia</p>
  </div>
</section>

  <BrandLogos />
  <CTAStrip />
</BaseLayout>
