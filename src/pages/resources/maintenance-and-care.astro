---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackAndForthSection from '../../components/BackAndForthSection.astro';

const title = 'Maintenance & Care | Window Film Philadelphia | Leading Window Film';
const description = 'Window Film Philadelphia is happy to share the latest resources on proper window film maintenance and care. Get your free quote today!';
---

<BaseLayout title={title} description={description} canonical='https://www.windowfilmphiladelphia.net/resources/maintenance-and-care/'>
  <section class="page-hero" style="background-image: linear-gradient(rgba(40,40,40,0.62), rgba(40,40,40,0.80)), url('/images/window-film-maintenance-philadelphia.png'); background-size: cover; background-position: center;">
    <div class="container">
      <h1>Window Film Maintenance and Care Instructions for Philadelphia Properties</h1>
    </div>
  </section>

  <BackAndForthSection
  heading={'Window Film Maintenance and Care Instructions for Philadelphia Properties'}
  body={'Window Film Philadelphia is honored to provide leading maintenance and care instructions for your Philadelphia clients. Window film is a great, low-maintenance investment but does require some specified care and cleaning. In order to make the most out of your investment and to experience the wealth of benefits it has to offer, make sure to follow the following instructions for maintenance and care.'}
  imageSrc={'/images/window-film-maintenance-philadelphia.png'}
  imageAlt={'window film maintenance philadelphia'}
  flip={false}
  altBg={false}
/>

  <BackAndForthSection
  heading={'Window Film Care and Cleaning Instructions for Philadelphia Properties'}
  body={'**DO NOT CLEAN YOUR WINDOW FILM FOR 30 DAYS AFTER INSTALLATION!** Window film requires 30 days to fully cure. During this time period, your window film may appear foggy due to condensation buildup but don’t worry- this will dissipate over the first week. Do not clean your window film during the first month post-installation in order to let it properly cure. Please note, bubbles can also occur– do not pop any bubbles since it can impact the structural integrity of your film. If you happen to pop a bubble, contact us immediately! After this 30 day period, you can clean your window film periodically. Window film is less porous than glass, meaning it’ll require fewer cleanings. Always use a soft, non-abrasive cloth or paper towel paired with any commercial cleaner or a mixture of mild detergen'}
  imageSrc={'/images/window-film-care-philadelphia.jpg'}
  imageAlt={'window film care philadelphia'}
  flip={true}
  altBg={true}
/>

  <BackAndForthSection
  heading={'Work With Philadelphia’s Trusted Window Film Expert'}
  body={'Window Film Philadelphia is honored to be the trusted window film expert serving the state of Pennsylvania. Our team is happy to help provide you with leading maintenance and care instructions for your new investment.'}
  imageSrc={'/images/window-film-cleaning-instructions-philadelphia.jpg'}
  imageAlt={'window film cleaning instructions philadelphia'}
  flip={false}
  altBg={false}
/>

  <section class="cta-strip">
    <div class="container">
      <h2>Get Your Free Quote Today</h2>
      <p>Philadelphia&#39;s leading window film contractor. Contact us for a free consultation and estimate.</p>
      <a href="/contact/" class="btn btn--accent">Contact Us</a>
    </div>
  </section>
</BaseLayout>
