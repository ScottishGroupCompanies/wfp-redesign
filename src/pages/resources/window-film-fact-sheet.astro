---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackAndForthSection from '../../components/BackAndForthSection.astro';
import BrandLogos from '../../components/BrandLogos.astro';
import CTAStrip from '../../components/CTAStrip.astro';

const title = 'Window Film Fact Sheet | Window Film Philadelphia | Leading Solutions';
const description = 'Window Film Philadelphia is happy to provide a comprehensive window film fact sheet for your upcoming project. Get your free quote today!';
---

<BaseLayout title={title} description={description} canonical='https://www.windowfilmphiladelphia.net/resources/window-film-fact-sheet/'>

  <section class="page-hero" style="background-image: linear-gradient(rgba(40,40,40,0.62), rgba(40,40,40,0.80)), url('/images/window-film-fact-sheet-philadelphia.png'); background-size: cover; background-position: center;">
    <div class="container">
      <h1>Window Film Fact Sheet for Philadelphia Properties</h1>
    </div>
  </section>

  <BackAndForthSection
    heading={'Window Film Fact Sheet for Philadelphia Properties'}
    body={'Window film is a highly celebrated product for both residential and commercial properties. With quick installation times, minimized operational downtime, exclusive benefits, and effective properties, window film is the perfect addition for countless projects. In order to make the most informed decision for your upcoming home or business renovation, here is a comprehensive list of window film facts for Philadelphia property owners.'}
    imageSrc={'/images/window-film-fact-sheet-philadelphia.png'}
    imageAlt={'Window film fact sheet Philadelphia'}
    flip={false}
    altBg={false}
  />

  <section class="section-pad resource-section">
    <div class="container">
      <h2>Window Film Facts and Statistics for Philadelphia Properties</h2>
      <ul class="facts-list">
        <li>Window film can reject up to 97% of infrared radiation emitted from the sun</li>
        <li>Window film can block up to 60% of solar heat from entering a building through its glass windows and doors</li>
        <li>Window film provides fade protection and health benefits by blocking up to 99.9% of UV rays</li>
        <li>Window film offers a sustainable solution — approximately every 16 feet of window film installed equals energy savings that total one barrel of oil each year</li>
        <li>Businesses on average can get a full return on investment from window film within six months to three years, depending on the type of film, glass type, and building size</li>
        <li>Solar heat gain and radiant heat loss account for approximately one-third of a home's energy costs</li>
        <li>Approximately 40% of energy lost is through a residential or commercial property's windows</li>
        <li>Window film has been identified by the Department of Energy as a "first-tier technology"</li>
        <li>Window film can improve the energy efficiency of glass by up to 92%</li>
        <li>Property owners can save about $1 to $2 for every square foot of window film installed, resulting in as much as 19 kWh per square foot of glass</li>
        <li>Window film can reduce heat gain during the summer months by up to 79%</li>
        <li>Residential property owners typically see an average of 30% savings on energy costs during the summer and around 10% to 15% savings in the winter</li>
        <li>An 8.8% carbon emission reduction would occur if every home in California installed window film</li>
        <li>Window films can offer carbon-negative benefits in as fast as six months from the day they are installed</li>
        <li>Window film can reduce the temperature of direct sunlight by as much as 9 degrees Fahrenheit</li>
      </ul>
    </div>
  </section>

  <BackAndForthSection
    heading={"Work With Philadelphia's Trusted Window Film Expert"}
    body={'Window Film Philadelphia is honored to be the trusted window film expert serving the state of Pennsylvania. Our team is happy to help guide you through various window film facts and statistics so that you can make the most informed decision on your upcoming project.'}
    imageSrc={'/images/window-film-statistics-philadelphia.jpg'}
    imageAlt={'Window film expert Philadelphia'}
    flip={false}
    altBg={false}
    ctaLabel={'Get a Free Quote'}
    ctaHref={'/contact/'}
  />

  <BrandLogos />
  <CTAStrip />

</BaseLayout>

<style>
.resource-section { background: var(--color-bg-section); }
.resource-section h2 { margin-bottom: 1.25rem; }
.facts-list {
  list-style: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}
.facts-list li {
  padding: 0.8rem 1.1rem 0.8rem 1.5rem;
  background: var(--color-bg-white);
  border-left: 4px solid var(--color-brand);
  border-radius: 0 6px 6px 0;
  color: var(--color-text-secondary);
  line-height: 1.6;
  font-size: 0.95rem;
  position: relative;
}
.facts-list li::before {
  content: '✓';
  position: absolute;
  left: 0.4rem;
  color: var(--color-brand);
  font-weight: 700;
}
</style>
