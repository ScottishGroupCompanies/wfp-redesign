---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackAndForthSection from '../../components/BackAndForthSection.astro';

const title = 'Window Film Fact Sheet | Window Film Philadelphia | Leading Solutions';
const description = 'Window Film Philadelphia is happy to provide a comprehensive window film fact sheet for your upcoming project. Get your free quote today!';
import BrandLogos from '../../components/BrandLogos.astro';
import CTAStrip from '../../components/CTAStrip.astro';
---

<BaseLayout title={title} description={description} canonical='https://www.windowfilmphiladelphia.net/resources/window-film-fact-sheet/'>
  <section class="page-hero" style="background-image: linear-gradient(rgba(40,40,40,0.62), rgba(40,40,40,0.80)), url('/images/window-film-fact-sheet-philadelphia.png'); background-size: cover; background-position: center;">
    <div class="container">
      <h1>Window Film Fact Sheet for Philadelphia Properties</h1>
    </div>
  </section>

  <BackAndForthSection
  heading={'Window Film Fact Sheet for Philadelphia Properties'}
  body={'Window film is a highly celebrated product for both residential and commercial properties. With quick installation times, minimized operational downtime, exclusive benefits, and effective properties, window film is the perfect addition for countless projects. In order to make the most informed decision for your upcoming home or business renovation, here’s a comprehensive list of window film facts for Philadelphia property owners.'}
  imageSrc={'/images/window-film-fact-sheet-philadelphia.png'}
  imageAlt={'window film fact sheet philadelphia'}
  flip={false}
  altBg={false}
/>

  <BackAndForthSection
  heading={'Window Fim Facts and Statistics for Philadelphia Properties'}
  body={'Discover more on window film figures and facts for your upcoming project: Window film can reject up to 97% of infrared radiation that’s emitted from the sun Window film can block up to 60% of solar heat from entering a building from its glass windows and doors Window film provides fade protection and health benefits by blocking out up to 99.9% of UV rays Window film offers a sustainable solution– approximately every 16 feet of window film installed equals energy savings that total one barrel of oil each year Businesses on average can get a full return on investment from window film within six months to three years– this figure depends on the type of film, glass type, and building size Solar heat gain and radiant heat loss account for approximately one-third of a home’s energy costs Approxi'}
  imageSrc={'/images/window-film-facts-philadelphia.jpg'}
  imageAlt={'window film facts philadelphia'}
  flip={true}
  altBg={true}
/>

  <BackAndForthSection
  heading={'Work With Philadelphia’s Trusted Window Film Expert'}
  body={'Window Film Philadelphia is honored to be the trusted window film expert serving the state of Pennsylvania. Our team is happy to help guide you through various window film facts and statistics so that you can make the most informed decision on your upcoming project.'}
  imageSrc={'/images/window-film-statistics-philadelphia.jpg'}
  imageAlt={'window film statistics philadelphia'}
  flip={false}
  altBg={false}
/>

  <BrandLogos />
  <CTAStrip />
</BaseLayout>
