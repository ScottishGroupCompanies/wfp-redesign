---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackAndForthSection from '../../components/BackAndForthSection.astro';

const title = 'Schools & Universities | Window Film Philadelphia | Leading Window Film';
const description = 'Window Film Philadelphia is honored to providing leading window film solutions for schools. Schedule your free consultation today!';
import CTAStrip from '../../components/CTAStrip.astro';
---

<BaseLayout title={title} description={description} canonical='https://www.windowfilmphiladelphia.net/applications/schools-universities/'>
  <section class="page-hero" style="background-image: linear-gradient(rgba(40,40,40,0.62), rgba(40,40,40,0.80)), url('/images/school-window-film-philadelphia.webp'); background-size: cover; background-position: center;">
    <div class="container">
      <h1>School Window Film in Philadelphia</h1>
    </div>
  </section>

  <BackAndForthSection
  heading={'School Window Film in Philadelphia'}
  body={'Educational institutions benefit greatly from school window film in Philadelphia because it naturally helps create safer, brighter, and more comfortable learning environments without disrupting daily routines. These films control heat, reduce glare, and maintain a balanced atmosphere in classrooms, allowing students to stay focused and productive. At the same time, the added privacy and security features give campuses the extra protection they need in today’s educational settings.'}
  imageSrc={'/images/school-window-film-philadelphia.webp'}
  imageAlt={'Classroom with company logo'}
  flip={false}
  altBg={false}
/>

  <BackAndForthSection
  heading={'The Benefits of Window Film for Your Philadelphia School'}
  body={'Window film provides lasting improvements in comfort, performance, and overall safety for schools and universities throughout the region including:'}
  imageSrc={'/images/university-window-film-philadelphia.webp'}
  imageAlt={'University Window Film Philadelphia'}
  flip={true}
  altBg={true}
/>

  <BackAndForthSection
  heading={'Privacy'}
  body={'Privacy window tinting is an important feature as it ultimately improves the safety and security of your campus. Block unwanted views in while maintaining clear views from the inside out. Privacy tinting can also provide other upgrades for your school. Learn More'}
  imageSrc={'/images/window-film-philadelphia-school.jpg'}
  imageAlt={'Students raising hands in classroom'}
  flip={false}
  altBg={false}
/>

  <section class="section-pad">
  <div class="container">
    <h2>Safety and Security</h2>
    <p>Keep your students and teachers safe with this cost-effective security solution. Prevent broken glass hazards from impacting building occupant safety during natural disasters, break-ins, and other high-impact events. Learn More</p>
  </div>
</section>

  <section class="section-pad">
  <div class="container">
    <h2>Glare Reduction</h2>
    <p>For properties lacking foliage, glare can be a common concern throughout certain times of the day. Don’t let glare impact productivity by increasing headaches, eye fatigue, and more. Glare reduction film effectively reduces glare to create a more comfortable screen-viewing environment. Learn More</p>
  </div>
</section>

  <section class="section-pad">
  <div class="container">
    <h2>Work With Philadelphia’s Leading School Window Film Contractor</h2>
    <p>Window Film Philadelphia is honored to provide leading window film solutions for schools in Philadephia. Our team has worked with numerous campuses in order to create a better, safer learning environment and would love the opportunity to help you improve your space. Contact us for more information! For more information, check out this resource: Case Study for School Window Film in Philadelphia</p>
  </div>
</section>

  <CTAStrip />
</BaseLayout>
