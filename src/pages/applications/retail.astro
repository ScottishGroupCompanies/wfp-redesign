---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InnerPageHero from '../../components/InnerPageHero.astro';
import BrandLogos from '../../components/BrandLogos.astro';
import { Icon } from 'astro-icon/components';

const title = 'Retail Window Film in Philadelphia | Window Film Philadelphia';
const description = 'Enhance privacy and reduce glare with custom retail window film in Philadelphia. Contact Window Film Philadelphia for a free consultation!';

const featuredSections = [
  {
    number: '01',
    heading: 'UV Protection for Displays & Merchandise',
    body: 'Keep your investments and storefront displays safe with UV-blocking window film. Perfect for maintaining an optically clear glass display while ensuring everything inside stays safe from harmful UV damage.',
    img: '/images/mall-window-film-philadelphia.jpg',
    alt: 'UV protection retail window film Philadelphia',
    href: '/benefits/uv-blocking-window-film-philadelphia/',
    cta: 'Explore UV Protection Film',
  },
  {
    number: '02',
    heading: 'Safety & Security Against Smash-and-Grab',
    body: 'Deter intruders and guard against smash-and-grabs with safety and security window film. This innovative, durable film works by adding a thick layer of protection to your glass windows and doors. Mitigate glass hazards with this 24/7 passive security system.',
    img: '/images/security-window-film-philadelphia.jpg',
    alt: 'Safety security retail window film Philadelphia',
    href: '/benefits/safety-and-security/',
    cta: 'Explore Safety & Security Film',
  },
  {
    number: '03',
    heading: 'Bird Strike Prevention for Storefronts',
    body: 'For properties prone to bird collisions, these events can be disruptive and troublesome for building occupants. Bird strike prevention window film helps alert birds of the location of your glass windows and doors to help promote bird conservation and minimize maintenance needs.',
    img: '/images/bird-divert-film-philadelphia.jpg',
    alt: 'Bird strike prevention retail Philadelphia',
    href: '/benefits/bird-strike-prevention/',
    cta: 'Explore Bird Strike Film',
  },
];

const whyItems = [
  { icon: 'lucide:award',       title: '15+ Years Experience',        sub: 'Serving Philadelphia since 2008' },
  { icon: 'lucide:badge-check', title: 'Factory-Certified Installers', sub: '3M, LLumar, Vista, Solar Gard' },
  { icon: 'lucide:file-check',  title: 'Lifetime Warranty',            sub: 'On all residential & commercial films' },
  { icon: 'lucide:calendar',    title: 'Free Consultations',           sub: 'On-site estimates, no obligation' },
  { icon: 'lucide:star',        title: '4.9 Google Rating',            sub: '5,000+ projects completed' },
  { icon: 'lucide:map-pin',     title: 'Philadelphia-Based',           sub: 'Local crews, same-week scheduling' },
  { icon: 'lucide:layers',      title: 'Premium Film Brands',          sub: '3M, LLumar, Vista, Solar Gard, Madico' },
  { icon: 'lucide:umbrella',    title: 'Fully Insured',              sub: 'Licensed & insured in PA and NJ' },
];
---

<BaseLayout title={title} description={description} canonical="https://www.windowfilmphiladelphia.net/applications/retail/">

<InnerPageHero
  title="Retail Window Film Philadelphia"
  bgImage="/images/wfp-retail-hero.jpg"
  desc="Custom window film solutions for Philadelphia retail shops, storefronts, and malls."
/>

<div class="ip-page-body">

<!-- ══════════════════════════════════════
     INTRO — 2-col: big heading left, text + CTAs right
     ══════════════════════════════════════ -->
<section class="bp-intro">
  <div class="bp-intro__inner">
    <div class="bp-intro__left">
      <span class="bp-eyebrow">Retail & Storefront</span>
      <h1 class="bp-intro__title">Window Film Solutions for Philadelphia Retail</h1>
    </div>
    <div class="bp-intro__right">
      <p class="bp-intro__lead">Window Film Philadelphia has helped numerous brick-and-mortar businesses in the retail industry create incredible shopping experiences for their customers. Whether you are looking for loss prevention security film for your East Falls boutique or custom decorative branding for your Northern Liberties storefront, we have got you covered.</p>
      <div class="bp-intro__ctas">
        <a href="/contact/" class="bp-btn bp-btn--primary">Get a Free Quote</a>
        <a href="/benefits/" class="bp-btn bp-btn--ghost">View Film Benefits</a>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     FEATURED — numbered alternating rows
     ══════════════════════════════════════ -->
<section class="bp-featured">
  <div class="bp-featured__hd">
    <span class="bp-eyebrow">Top Benefits</span>
    <h2 class="bp-featured__title">Why Philadelphia retailers choose<br/>window film</h2>
  </div>

  {featuredSections.map((a, i) => (
    <div class={`bp-feat-row fade-in${i % 2 === 1 ? ' bp-feat-row--rev' : ''}`}>
      <div class="bp-feat-row__img">
        <img src={a.img} alt={a.alt} width="600" height="480" loading="lazy" />
        <span class="bp-feat-row__pill">{a.heading}</span>
      </div>
      <div class="bp-feat-row__content">
        <span class="bp-feat-row__num">{a.number}</span>
        <h3 class="bp-feat-row__heading">{a.heading}</h3>
        <p class="bp-feat-row__body">{a.body}</p>
        <a href={a.href} class="bp-feat-row__cta">
          {a.cta}
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/></svg>
        </a>
      </div>
    </div>
  ))}
</section>

<!-- ══════════════════════════════════════
     WHY US — 4-col icon grid
     ══════════════════════════════════════ -->
<section class="bp-why">
  <div class="bp-why__hd">
    <span class="bp-eyebrow">Why Window Film Philadelphia</span>
    <h2 class="bp-why__title">Genuine partner in every aspect of your project</h2>
  </div>
  <div class="bp-why__grid">
    {whyItems.map((item) => (
      <div class="bp-why__item fade-in">
        <div class="bp-why__icon"><Icon name={item.icon} width="32" height="32" /></div>
        <div class="bp-why__divider"></div>
        <h4 class="bp-why__item-title">{item.title}</h4>
        <p class="bp-why__item-sub">{item.sub}</p>
      </div>
    ))}
  </div>
</section>

<!-- ══════════════════════════════════════
     FAQ ACCORDION
     ══════════════════════════════════════ -->
<section class="bp-faq">
  <div class="bp-faq__hd">
    <span class="bp-eyebrow">FAQ</span>
    <h2 class="bp-faq__title">Common questions about retail window film</h2>
  </div>
  <div class="bp-faq__item bp-faq__item--open">
    <div class="bp-faq__q">Can window film protect merchandise and displays from UV fading? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Yes. Our UV-blocking window film filters out up to 99% of harmful ultraviolet rays that cause merchandise fading, fabric degradation, and damage to sensitive products on display. This is especially important for storefronts with large glass areas and products displayed near windows — preserving the quality and appearance of your inventory.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">How does safety and security film help prevent smash-and-grab theft? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Security window film bonds to glass with a heavy-duty adhesive layer that holds shattered glass together on impact. When a would-be intruder strikes the glass, the film prevents it from splintering and falling away — slowing entry, triggering alarms faster, and deterring opportunistic theft. It is a passive 24/7 layer of protection with no electronics or maintenance required.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">Will window film affect the appearance of our storefront from the street? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Modern window films are designed to be virtually invisible or to maintain a clean, consistent appearance that enhances your storefront's look. We offer a range of visible light transmission levels and reflective options so you can match the aesthetic of your building while gaining UV protection, glare reduction, or security benefits.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">Do you offer custom branding or decorative film for retail interiors? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Absolutely. We offer custom frosted patterns, etched glass effects, branded graphics, and decorative film for interior partitions, fitting rooms, lobby glass, and storefronts. Custom designs are produced by our in-house team — no minimum order quantity, and no need to replace existing glass.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">How long does a retail installation take and will it disrupt our store? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">Most standard retail storefront installations are completed within a single day with minimal disruption to your operations. We can also schedule installations before opening or after hours for high-traffic locations. Our team works efficiently and cleanly so your business can continue serving customers throughout the process.</div>
  </div>
  <div class="bp-faq__item">
    <div class="bp-faq__q">What warranty coverage comes with a commercial retail installation? <span class="bp-faq__toggle">+</span></div>
    <div class="bp-faq__a">All our commercial installations include a lifetime manufacturer warranty covering peeling, bubbling, delamination, and color fade for the original property owner. We also provide a workmanship guarantee on every installation — backed by our 15+ years of experience serving Philadelphia-area businesses.</div>
  </div>
</section>

<!-- ══════════════════════════════════════
     BRAND LOGOS
     ══════════════════════════════════════ -->
<BrandLogos />

<!-- ══════════════════════════════════════
     CTA BANNER
     ══════════════════════════════════════ -->
<div class="bp-cta fade-in">
  <h2>Ready to upgrade your <em>Philadelphia storefront?</em></h2>
  <div class="bp-cta__btns">
    <a href="/contact/" class="bp-btn bp-btn--white">Get a Free Quote</a>
    <a href="tel:+12673947980" class="bp-btn bp-btn--green">Call (267) 394-7980</a>
  </div>
</div>

</div><!-- end ip-page-body -->

</BaseLayout>

<style>
/* ── PAGE BODY WRAPPER ── */
.ip-page-body {
  position: relative;
  background: #ffffff;
  border-top-left-radius: 40px;
  border-top-right-radius: 40px;
  border-bottom-left-radius: 40px;
  border-bottom-right-radius: 40px;
  margin-top: -40px;
  z-index: 10;
  overflow: visible;
  padding-bottom: 80px;
}

/* ── EYEBROW ── */
.bp-eyebrow {
  display: inline-block;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--green, #81AB4C);
  margin-bottom: 16px;
}

/* ── BUTTONS ── */
.bp-btn {
  display: inline-block; padding: 14px 28px;
  border-radius: var(--radius-pill, 100px);
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; font-weight: 500;
  text-decoration: none; transition: all 0.2s;
  border: 2px solid transparent; white-space: nowrap;
}
.bp-btn--primary { background: var(--green, #81AB4C); color: #fff; border-color: var(--green, #81AB4C); }
.bp-btn--primary:hover { background: #6e9640; border-color: #6e9640; transform: translateY(-2px); color: #fff; }
.bp-btn--ghost { background: transparent; color: var(--brand, #272E32); border-color: var(--brand, #272E32); }
.bp-btn--ghost:hover { background: var(--brand, #272E32); color: #fff; transform: translateY(-2px); }
.bp-btn--white { background: #fff; color: var(--brand, #272E32); border-color: #fff; font-weight: 600; }
.bp-btn--white:hover { background: var(--off-white, #F7F6F3); transform: translateY(-2px); }
.bp-btn--green { background: var(--green, #81AB4C); color: #fff; border-color: var(--green, #81AB4C); }
.bp-btn--green:hover { background: #6e9640; transform: translateY(-2px); color: #fff; }

/* ── INTRO ── */
.bp-intro {
  padding: 80px 10%;
  border-top-left-radius: 40px;
  border-top-right-radius: 40px;
  overflow: hidden;
}
.bp-intro__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}
.bp-intro__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(36px, 4.5vw, 58px);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -1px;
  color: var(--text-dark, #1a1a1a);
  margin: 0;
}
.bp-intro__lead {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 17px;
  color: var(--text-mid, #4a4a4a);
  line-height: 1.75;
  margin-bottom: 32px;
}
.bp-intro__ctas { display: flex; gap: 14px; flex-wrap: wrap; }

/* ── FEATURED ── */
.bp-featured {
  padding: 100px 10%;
  background: var(--off-white, #F7F6F3);
}
.bp-featured__hd {
  margin-bottom: 72px;
}
.bp-featured__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(32px, 4vw, 52px);
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: -0.5px;
  color: var(--text-dark, #1a1a1a);
  margin: 0;
}
.bp-feat-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  margin-bottom: 100px;
}
.bp-feat-row:last-child { margin-bottom: 0; }
.bp-feat-row--rev .bp-feat-row__img { order: 2; }
.bp-feat-row--rev .bp-feat-row__content { order: 1; }
.bp-feat-row__img {
  position: relative;
  height: 480px;
  border-radius: 32px;
  overflow: hidden;
}
.bp-feat-row__img img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}
.bp-feat-row__pill {
  position: absolute; bottom: 24px; left: 24px;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(8px);
  padding: 10px 18px;
  border-radius: 100px;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px; font-weight: 600;
  color: var(--brand, #272E32);
  box-shadow: 0 4px 16px rgba(0,0,0,0.1);
}
.bp-feat-row__num {
  display: block;
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 72px;
  font-weight: 700;
  color: var(--green, #81AB4C);
  line-height: 1;
  opacity: 0.25;
  margin-bottom: -8px;
}
.bp-feat-row__heading {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(24px, 3vw, 36px);
  font-weight: 700;
  color: var(--text-dark, #1a1a1a);
  line-height: 1.2;
  margin-bottom: 20px;
  letter-spacing: -0.3px;
}
.bp-feat-row__body {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 16px;
  color: var(--text-mid, #4a4a4a);
  line-height: 1.8;
  margin-bottom: 28px;
}
.bp-feat-row__cta {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; font-weight: 600;
  color: var(--green, #81AB4C);
  text-decoration: none;
  transition: gap 0.2s;
}
.bp-feat-row__cta:hover { gap: 14px; }

/* ── WHY US GRID ── */
.bp-why {
  background: var(--brand, #272E32);
  padding: 100px 10%;
}
.bp-why__hd {
  margin-bottom: 64px;
}
.bp-why__hd .bp-eyebrow { color: var(--green, #81AB4C); }
.bp-why__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(28px, 3.5vw, 48px);
  font-weight: 700;
  color: #ffffff;
  line-height: 1.15;
  letter-spacing: -0.5px;
  margin: 0;
  max-width: 600px;
}
.bp-why__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
}
.bp-why__item {
  padding: 32px 28px;
  border-right: 1px solid rgba(255,255,255,0.1);
  border-bottom: 1px solid rgba(255,255,255,0.1);
}
.bp-why__item:nth-child(4n) { border-right: none; }
.bp-why__item:nth-child(n+5) { border-bottom: none; }
.bp-why__icon {
  color: var(--green, #81AB4C);
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  line-height: 1;
}
.bp-why__icon svg { display: block; }
.bp-why__divider {
  width: 32px; height: 2px;
  background: var(--green, #81AB4C);
  margin-bottom: 16px;
}
.bp-why__item-title {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; font-weight: 700;
  color: #ffffff;
  margin-bottom: 6px;
}
.bp-why__item-sub {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 13px;
  color: rgba(255,255,255,0.5);
  margin: 0;
  line-height: 1.5;
}

/* ── FAQ ── */
.bp-faq { padding: 100px 10%; background: #ffffff; }
.bp-faq__hd { margin-bottom: 48px; }
.bp-faq__title {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: clamp(28px, 3.5vw, 48px);
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: -0.5px;
  color: var(--text-dark, #1a1a1a);
  max-width: 560px;
  margin: 0;
}
.bp-faq__item {
  border-bottom: 1px solid var(--light-gray, #EFEFED);
  padding: 24px 0;
  cursor: pointer;
  max-width: 900px;
}
.bp-faq__item:first-of-type { border-top: 1px solid var(--light-gray, #EFEFED); }
.bp-faq__q {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 17px; font-weight: 600;
  color: var(--text-dark, #1a1a1a);
  display: flex; justify-content: space-between; align-items: center; gap: 12px;
}
.bp-faq__toggle { color: var(--green, #81AB4C); font-size: 22px; flex-shrink: 0; transition: transform 0.2s; }
.bp-faq__a {
  font-family: var(--font-body, 'DM Sans', sans-serif);
  font-size: 15px; color: var(--text-mid, #4a4a4a); line-height: 1.75;
  margin-top: 14px; display: none;
}
.bp-faq__a a { color: var(--green, #81AB4C); }
.bp-faq__item--open .bp-faq__a { display: block; }
.bp-faq__item--open .bp-faq__toggle { transform: rotate(45deg); }

/* ── CTA BANNER ── */
.bp-cta {
  background: var(--brand, #272E32);
  border-radius: 40px;
  padding: 64px 60px;
  display: flex; align-items: center;
  justify-content: space-between;
  gap: 40px;
  margin: 0 5% 0;
}
.bp-cta h2 {
  font-family: var(--font-serif, 'Playfair Display', serif);
  font-size: 32px; font-weight: 700;
  color: #fff; line-height: 1.2;
  max-width: 460px; margin: 0;
}
.bp-cta h2 em { font-style: italic; color: var(--green, #81AB4C); }
.bp-cta__btns { display: flex; gap: 14px; flex-shrink: 0; }

/* ── FADE IN ── */
.fade-in { opacity: 0; transform: translateY(24px); transition: opacity 0.65s ease, transform 0.65s ease; }
.fade-in.visible { opacity: 1; transform: translateY(0); }

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
  .bp-intro__inner { grid-template-columns: 1fr; gap: 40px; }
  .bp-feat-row { grid-template-columns: 1fr; gap: 40px; }
  .bp-feat-row--rev .bp-feat-row__img { order: 0; }
  .bp-feat-row--rev .bp-feat-row__content { order: 1; }
  .bp-why__grid { grid-template-columns: repeat(2, 1fr); }
  .bp-why__item:nth-child(4n) { border-right: 1px solid rgba(255,255,255,0.1); }
  .bp-why__item:nth-child(2n) { border-right: none; }
}
@media (max-width: 768px) {
  .bp-intro { padding: 60px 5%; }
  .bp-featured { padding: 60px 5%; }
  .bp-why { padding: 60px 5%; }
  .bp-faq { padding: 60px 5%; }
  .bp-why__grid { grid-template-columns: 1fr; }
  .bp-feat-row__img { height: 300px; }
  .bp-cta { flex-direction: column; padding: 40px 28px; text-align: center; }
  .bp-cta h2 { font-size: 26px; max-width: 100%; }
  .bp-cta__btns { flex-direction: column; width: 100%; }
}
@media (max-width: 480px) {
  .bp-intro__ctas { flex-direction: column; }
}
</style>

<script>
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-in').forEach(el => obs.observe(el));

  document.querySelectorAll('.bp-faq__item').forEach(item => {
    item.querySelector('.bp-faq__q')?.addEventListener('click', () => {
      const isOpen = item.classList.contains('bp-faq__item--open');
      document.querySelectorAll('.bp-faq__item').forEach(i => i.classList.remove('bp-faq__item--open'));
      if (!isOpen) item.classList.add('bp-faq__item--open');
    });
  });
</script>
